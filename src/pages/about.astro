---
import BaseLayout from '../layouts/BaseLayout.astro';
import Panel from '../components/Panel.astro';
import Reveal from '../components/Reveal.astro';
import MissionContent from '../../content/about/mission.md';
import ClinicalContent from '../../content/about/clinical.md';
import ComBContent from '../../content/about/com-b.md';
import TechnologyContent from '../../content/about/technology.md';
import FoundingTeamContent from '../../content/about/founding-team.md';
import teamData from '../../content/about/team.json';
import combData from '../../content/about/com-b.json';
import techData from '../../content/about/technology.json';

// Hand-drawn emotion-shape motifs (same system as the homepage line motifs):
// pull the raw SVG, strip the wrapper + white rect, keep just the <path>s,
// downsampled so dense shapes stay calm.
const emotionSvgs = import.meta.glob('/public/emotions/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;
const emotionPaths = (name: string, maxArcs = 8): string => {
  const raw = (emotionSvgs[`/public/emotions/${name}.svg`] ?? '')
    .replace(/<svg[^>]*>/, '')
    .replace(/<\/svg>/, '')
    .replace(/<rect[^>]*\/>/g, '');
  const paths = raw.match(/<path[\s\S]*?\/>/g) ?? [];
  if (paths.length <= maxArcs) return paths.join('');
  const kept: string[] = [];
  for (let i = 0; i < maxArcs; i++) {
    kept.push(paths[Math.round((i * (paths.length - 1)) / (maxArcs - 1))]);
  }
  return kept.join('');
};
---

<BaseLayout
  title="About"
  description="Learn about alignd's mission, coaching team, and the behavioral science behind our approach to family digital wellness."
>

  <!-- Hero / Our Mission — text left, image right (matches the homepage hero) -->
  <Panel size="sm">
    <div class="about-split about-hero">
      <div class="about-split__text">
        <Reveal><p class="eyebrow">About alignd</p></Reveal>
        <Reveal delay={50}><h1>Our Mission</h1></Reveal>
        <Reveal delay={100}>
          <div class="prose about-hero__prose">
            <MissionContent />
          </div>
        </Reveal>
      </div>
      <Reveal delay={150} class="about-split__visual">
        <figure class="about-figure">
          <div class="about-figure__frame">
            <img src="/teenageband.png" alt="Teenagers playing music together" />
          </div>
          <svg class="about-figure__motif" viewBox="0 0 298 298" fill="none" aria-hidden="true" set:html={emotionPaths('Clarity')} />
        </figure>
      </Reveal>
    </div>
  </Panel>

  <!-- Clinical Experience — photo (circle) left, text right -->
  <Panel background="surface" class="about-pad">
    <div class="about-split about-split--reverse">
      <div class="about-split__text">
        <Reveal><h2>Clinical Experience</h2></Reveal>
        <Reveal delay={100}>
          <div class="prose">
            <ClinicalContent />
          </div>
        </Reveal>
      </div>
      <Reveal delay={150} class="about-split__visual">
        <figure class="about-figure about-figure--circle">
          <div class="about-figure__frame">
            <span class="about-figure__placeholder">Photo</span>
          </div>
          <figcaption class="about-figure__caption">Dr. Michael Rich, in clinic</figcaption>
        </figure>
      </Reveal>
    </div>
  </Panel>

  <!-- About COM-B — text left, line-motif Venn right -->
  <Panel background="default" class="about-pad">
    <div class="about-split">
      <div class="about-split__text">
        <Reveal><h2>About COM-B</h2></Reveal>
        <Reveal delay={100}>
          <div class="prose">
            <ComBContent />
          </div>
        </Reveal>
      </div>
      <Reveal delay={150} class="about-split__visual">
        <div
          class="comb"
          role="img"
          aria-label="The COM-B model: Capability, Opportunity, and Motivation overlap to drive Behaviour."
        >
          <span class="comb__circle comb__circle--cap"></span>
          <span class="comb__circle comb__circle--opp"></span>
          <span class="comb__circle comb__circle--mot"></span>

          <div class="comb__label comb__label--cap">
            <svg class="comb__icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 18h6M10 21h4M12 3a6 6 0 0 0-3.6 10.8c.5.4.9 1 1 1.7l.1.5h5l.1-.5c.1-.7.5-1.3 1-1.7A6 6 0 0 0 12 3z"/>
            </svg>
            <span class="comb__title">{combData.nodes[0].label}</span>
            <span class="comb__desc">{combData.nodes[0].desc}</span>
          </div>

          <div class="comb__label comb__label--opp">
            <svg class="comb__icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 3 4 7.5v9L12 21l8-4.5v-9L12 3zM4 7.5 12 12m0 0 8-4.5M12 12v9"/>
            </svg>
            <span class="comb__title">{combData.nodes[1].label}</span>
            <span class="comb__desc">{combData.nodes[1].desc}</span>
          </div>

          <div class="comb__label comb__label--mot">
            <svg class="comb__icon comb__icon--fill" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 20s-6.5-4.3-9-8.1C1.2 9 2.6 5.6 6 5.6c2 0 3.1 1.2 4 2.3.9-1.1 2-2.3 4-2.3 3.4 0 4.8 3.4 3 6.3-2.5 3.8-9 8.1-9 8.1z"/>
            </svg>
            <span class="comb__title">{combData.nodes[2].label}</span>
            <span class="comb__desc">{combData.nodes[2].desc}</span>
          </div>

          <span class="comb__center">{combData.center}</span>
        </div>
      </Reveal>
    </div>
  </Panel>

  <!-- Our Technology — centered headline + body, schematic below -->
  <Panel background="surface" class="about-pad">
    <div class="about-section about-section--center">
      <Reveal><h2>Our Technology</h2></Reveal>
      <Reveal delay={100}>
        <div class="prose about-prose-narrow">
          <TechnologyContent />
        </div>
      </Reveal>
      <Reveal delay={150}>
        <div class="tech-flow">
          <div class="tech-col">
            <span class="tech-col__head">Inputs</span>
            {techData.inputs.map(i => <span class="tech-chip">{i}</span>)}
          </div>

          <svg class="tech-arrow" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 12h15M13 6l6 6-6 6"/>
          </svg>

          <div class="tech-engine">
            <span class="tech-engine__label">{techData.engineLabel}</span>
            <span class="tech-engine__sub">{techData.engineSub}</span>
          </div>

          <svg class="tech-arrow" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 12h15M13 6l6 6-6 6"/>
          </svg>

          <div class="tech-col">
            <span class="tech-col__head">Outputs</span>
            {techData.outputs.map(o => <span class="tech-chip">{o}</span>)}
          </div>
        </div>
      </Reveal>
    </div>
  </Panel>

  <!-- Founding Team -->
  <Panel background="default" class="about-pad">
    <div class="about-section">
      <Reveal><h2>Founding Team</h2></Reveal>
      <Reveal delay={100}>
        <div class="prose team-intro">
          <FoundingTeamContent />
        </div>
      </Reveal>
      <div class="team-grid">
        {teamData.map((member, i) => (
          <Reveal delay={i * 80}>
            <div class="team-card">
              <div class="team-avatar" aria-hidden="true">
                {member.headshot && <img src={member.headshot} alt={member.name} />}
              </div>
              <span class="team-name">{member.name}</span>
              <span class="team-title">{member.title}</span>
              <button
                class="team-bio-btn"
                data-id={member.id}
                aria-label={`View bio for ${member.name}`}
              >View Bio</button>
            </div>
          </Reveal>
        ))}
      </div>

      <!-- Bio Modal -->
      <div class="bio-modal" id="bio-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="bio-modal-name">
        <div class="bio-modal__backdrop"></div>
        <div class="bio-modal__panel">
          <button class="bio-modal__close" aria-label="Close bio">&times;</button>
          <div class="bio-modal__avatar"></div>
          <h3 class="bio-modal__name" id="bio-modal-name"></h3>
          <p class="bio-modal__title"></p>
          <p class="bio-modal__bio"></p>
          <a class="bio-modal__linkedin" href="#" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
      </div>
    </div>
  </Panel>

</BaseLayout>

<style>
  /* Content sections: tighter than the default section padding so the
     page reads at a density closer to the rest of the site */
  :global(.about-pad) {
    padding-block: var(--space-12);
  }

  /* Mission image — match the homepage hero card's corner radius */
  .about-hero .about-figure__frame {
    border-radius: var(--radius-xl);
  }

  .about-hero__prose {
    max-width: 60ch;
    margin-top: var(--space-5);
  }

  .about-section {
    align-items: start;
  }

  .about-section h2 {
    margin-top: 0;
    margin-bottom: var(--space-5);
  }

  /* Technology section: centered headline + body (schematic keeps its own layout) */
  .about-section--center { text-align: center; }
  .about-section--center .about-prose-narrow { margin-inline: auto; }
  .about-section--center .tech-flow { text-align: initial; }

  /* Body copy matches the homepage hero sub: base size, full text color */
  .prose :global(p) {
    color: var(--color-text);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
  }

  .prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(strong) {
    color: var(--color-text);
    font-weight: var(--weight-semibold);
  }

  /* ── Two-column split (text + visual) ── */
  .about-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .about-split__text h2 {
    margin-top: 0;
    margin-bottom: var(--space-5);
  }

  .about-split--reverse .about-split__text { order: 2; }
  .about-split--reverse .about-split__visual { order: 1; }

  .about-prose-narrow { max-width: 64ch; }

  /* ── Photo figure (placeholder) ── */
  .about-figure { margin: 0; position: relative; }

  /* Clarity motif — drawn over the phone in the photo, spilling past the left
     edge into the whitespace (like the homepage science-panel motif). */
  .about-figure__motif {
    position: absolute;
    left: -24%;
    bottom: -24%;
    width: 68%;
    aspect-ratio: 1 / 1;
    color: var(--pollen);
    overflow: visible;
    max-width: none;
    pointer-events: none;
    z-index: 2;
  }
  .about-figure__motif :global(path) {
    stroke: currentColor;
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .about-figure__frame {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-md);
    background: var(--color-surface-raised);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Spring-leaf tint over the Mission photo — matches the homepage hero card */
  .about-hero .about-figure__frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--spring-leaf) 25%, transparent);
    pointer-events: none;
    z-index: 1;
  }

  .about-figure__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Circular portrait variant — centered, sized down from the full column */
  .about-figure--circle {
    max-width: 360px;
    margin-inline: auto;
  }
  .about-figure--circle .about-figure__frame {
    border-radius: var(--radius-full);
  }

  .about-figure__placeholder {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-subtle);
  }

  .about-figure__caption {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
  }

  /* ── COM-B Venn (coded, not an image) ── */
  .comb {
    position: relative;
    width: 100%;
    max-width: 420px;
    margin-inline: auto;
    aspect-ratio: 1 / 1;
  }

  /* Filled translucent beige circles — overlaps darken into the Venn shape */
  .comb__circle {
    position: absolute;
    width: 64%;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-full);
    background: var(--almond-beige);
    opacity: 0.32;
  }

  .comb__circle--cap { top: 0; left: 50%; transform: translateX(-50%); }
  .comb__circle--opp { bottom: 0; left: 0; }
  .comb__circle--mot { bottom: 0; right: 0; }

  .comb__label {
    position: absolute;
    width: 40%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-1);
    pointer-events: none;
  }

  .comb__label--cap { top: 9%;  left: 50%; transform: translateX(-50%); }
  .comb__label--opp { bottom: 13%; left: 9%; }
  .comb__label--mot { bottom: 13%; right: 9%; }

  .comb__icon {
    width: 26px;
    height: 26px;
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .comb__icon--fill {
    fill: var(--color-accent);
    stroke: none;
  }

  .comb__title {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    color: var(--color-text);
  }

  .comb__desc {
    font-size: var(--text-xs);
    line-height: var(--leading-snug);
    color: var(--color-text-muted);
  }

  .comb__center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
  }

  /* ── Technology schematic (coded): inputs → AI → outputs ── */
  .tech-flow {
    margin-top: var(--space-10);
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }

  .tech-col {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .tech-col__head {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-muted);
    text-align: center;
    margin-bottom: var(--space-1);
  }

  .tech-chip {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--color-text);
    text-align: center;
  }

  .tech-arrow {
    flex: 0 0 auto;
    width: 28px;
    height: 28px;
    fill: none;
    stroke: var(--color-text-subtle);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .tech-engine {
    flex: 0 0 auto;
    align-self: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--space-1);
    background: var(--color-accent);
    color: var(--color-accent-text);
    border-radius: var(--radius-md);
    padding: var(--space-6) var(--space-5);
    min-width: 8.5rem;
  }

  .tech-engine__label {
    font-family: var(--font-heading);
    font-weight: var(--weight-heading);
    font-size: var(--text-2xl);
    line-height: 1;
  }

  .tech-engine__sub {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    opacity: 0.85;
  }

  .team-intro {
    max-width: 64ch;
    margin-bottom: var(--space-10);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .team-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
  }

  .team-avatar {
    width: clamp(150px, 15vw, 196px);
    height: clamp(150px, 15vw, 196px);
    border-radius: var(--radius-full);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    aspect-ratio: 1;
    overflow: hidden;
    margin-bottom: var(--space-2);
  }

  .team-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .team-name {
    font-weight: var(--weight-heading);
    font-size: var(--text-lg);
  }

  .team-title {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .team-bio-btn {
    margin-top: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-accent);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .team-bio-btn:hover {
    opacity: 0.7;
  }

  .team-bio-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Bio Modal */
  .bio-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: var(--z-modal, 100);
    align-items: center;
    justify-content: center;
  }

  .bio-modal[aria-hidden="false"] {
    display: flex;
  }

  .bio-modal__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--midnight) 60%, transparent);
  }

  .bio-modal__panel {
    position: relative;
    background: var(--color-surface, var(--white));
    border-radius: var(--radius-md);
    padding: var(--space-10);
    max-width: 480px;
    width: calc(100% - var(--space-8));
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-3);
  }

  .bio-modal__close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    background: none;
    border: none;
    font-size: var(--text-xl);
    line-height: 1;
    cursor: pointer;
    color: var(--color-text-muted);
  }

  .bio-modal__close:hover {
    color: var(--color-text);
  }

  .bio-modal__avatar {
    width: 96px;
    height: 96px;
    border-radius: var(--radius-full);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    overflow: hidden;
    flex-shrink: 0;
  }

  .bio-modal__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bio-modal__name {
    font-size: var(--text-xl);
    font-weight: var(--weight-heading);
    margin: 0;
  }

  .bio-modal__title {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .bio-modal__bio {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
    text-align: left;
  }

  .bio-modal__linkedin {
    font-size: var(--text-sm);
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .bio-modal__linkedin:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .about-split {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    /* Always show text above the visual when stacked */
    .about-split--reverse .about-split__text { order: 0; }
    .about-split--reverse .about-split__visual { order: 0; }

    .about-figure__frame { aspect-ratio: 3 / 2; }

    .tech-flow {
      flex-direction: column;
      align-items: stretch;
    }

    .tech-arrow {
      align-self: center;
      transform: rotate(90deg);
    }

    .tech-engine { align-self: center; }
  }

  @media (max-width: 640px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script define:vars={{ teamData }}>
  const modal = document.getElementById('bio-modal');
  const modalName = modal.querySelector('.bio-modal__name');
  const modalTitle = modal.querySelector('.bio-modal__title');
  const modalBio = modal.querySelector('.bio-modal__bio');
  const modalAvatar = modal.querySelector('.bio-modal__avatar');
  const modalLinkedin = modal.querySelector('.bio-modal__linkedin');

  function openModal(id) {
    const member = teamData.find(m => m.id === id);
    if (!member) return;
    modalName.textContent = member.name;
    modalTitle.textContent = member.title;
    modalBio.textContent = member.bio;
    modalAvatar.innerHTML = member.headshot
      ? `<img src="${member.headshot}" alt="${member.name}" />`
      : '';
    modalLinkedin.href = member.linkedin || '#';
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.team-bio-btn').forEach(btn => {
    btn.addEventListener('click', () => openModal(btn.dataset.id));
  });

  modal.querySelector('.bio-modal__close').addEventListener('click', closeModal);
  modal.querySelector('.bio-modal__backdrop').addEventListener('click', closeModal);

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') closeModal();
  });
</script>
