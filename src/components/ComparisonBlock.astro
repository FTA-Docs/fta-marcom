---
interface ComparisonRow {
  label: string;
  alignd: string;
  traditional: string;
  parentalTech: string;
}

interface Props {
  comparison: {
    eyebrow: string;
    heading: string;
    subheading?: string;
    cols: string[];
    rows: ComparisonRow[];
  };
}

const { comparison } = Astro.props;
const { cols, rows } = comparison;
---

<div class="comparison-block">
  <div class="cmp-table-scroll">
    <div class="cmp-table-wrap">
      <table class="cmp-table">
        <thead>
          <tr>
            <th scope="col"></th>
            <th scope="col" class="cmp-table__alignd">{cols[0]}</th>
            <th scope="col">{cols[1]}</th>
            <th scope="col">{cols[2]}</th>
          </tr>
        </thead>
        <tbody>
          {rows.map(row => (
            <tr>
              <th scope="row">{row.label}</th>
              <td class="cmp-table__alignd">{row.alignd}</td>
              <td>{row.traditional}</td>
              <td>{row.parentalTech}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
  <p class="cmp-scroll-hint" aria-hidden="true">
    <span>Swipe to see more</span>
    <span class="cmp-scroll-hint__arrow">→</span>
  </p>
</div>

<style>
  .comparison-block {
    padding-bottom: 0; /* panel owns the bottom space (matches #science) */
  }

  .cmp-table-wrap {
    overflow-x: auto;
  }

  /* Horizontal-scroll cue (mobile only — see the ≤767 block). On desktop the
     table fits its column, so the fade and hint stay hidden. */
  .cmp-table-scroll { position: relative; }
  .cmp-scroll-hint { display: none; }

  .cmp-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: var(--text-sm);
    /* Fits within the tablet container (≈707px inner at 768px) so the table
       never gets its own horizontal scrollbar between mobile and desktop. */
    min-width: 680px;
  }

  .cmp-table {
    table-layout: fixed;
  }

  .cmp-table th,
  .cmp-table td {
    padding: var(--space-3) var(--space-5);
    text-align: left;
    border-bottom: none;
    vertical-align: top;
    line-height: var(--leading-normal);
  }

  /* Column widths: label / alignd / traditional / parental-tech */
  .cmp-table thead th:first-child,
  .cmp-table tbody th { width: 20%; }
  .cmp-table thead th.cmp-table__alignd { width: 30%; }
  .cmp-table thead th:nth-child(3),
  .cmp-table thead th:nth-child(4) { width: 25%; }

  .cmp-table tbody tr:nth-child(odd) td,
  .cmp-table tbody tr:nth-child(odd) th {
    background: var(--light-beige);
  }

  /* Subtle darker green on filled rows so the alignd column stripes in sync */
  .cmp-table tbody tr:nth-child(odd) td.cmp-table__alignd {
    background: color-mix(in srgb, var(--spring-leaf) 95%, black);
  }

  .cmp-table thead th {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-normal);
    text-transform: none;
    color: var(--color-heading);
  }

  .cmp-table tbody th {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-normal);
    color: var(--color-text);
    vertical-align: top;
  }

  .cmp-table td {
    color: var(--color-text);
  }

  /* Highlighted alignd column */
  .cmp-table__alignd {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    background: var(--spring-leaf);
  }

  .cmp-table td.cmp-table__alignd,
  .cmp-table th.cmp-table__alignd,
  .cmp-table thead th.cmp-table__alignd {
    color: var(--light-beige);
  }

  /* alignd column body copy — one weight step lighter than the header */
  .cmp-table td.cmp-table__alignd {
    font-weight: var(--weight-medium);
  }

  .cmp-table thead th.cmp-table__alignd {
    border-radius: var(--radius-md) var(--radius-md) 0 0;
  }

  .cmp-table tbody tr:last-child td.cmp-table__alignd {
    border-radius: 0 0 var(--radius-md) var(--radius-md);
  }

  /* Mobile: keep the full comparison table but let it scroll horizontally.
     Columns are sized so the row-label + the alignd column show by default with
     a sliver of the next column as a scroll affordance (~2.25 columns). The
     label column stays pinned while the option columns scroll. */
  @media (max-width: 767px) {
    .cmp-table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .cmp-table {
      /* 116 + 3×152 → wider than the viewport, so the wrap scrolls */
      min-width: 572px;
      font-size: var(--text-sm);
    }

    .cmp-table th,
    .cmp-table td {
      padding: var(--space-3) var(--space-4);
      line-height: var(--leading-snug);
      hyphens: manual;           /* no forced mid-word breaks */
    }

    /* Narrow label column, equal option columns */
    .cmp-table thead th:first-child { width: 116px; }
    .cmp-table thead th:not(:first-child) { width: 152px; }

    /* Uniform compact type across headers + the alignd cells */
    .cmp-table thead th,
    .cmp-table tbody th,
    .cmp-table__alignd { font-size: var(--text-sm); }

    /* Pin the label column; opaque bg so option cells scroll underneath it */
    .cmp-table thead th:first-child,
    .cmp-table th[scope="row"] {
      position: sticky;
      left: 0;
      z-index: 2;
      background: var(--white);
    }
    .cmp-table tbody tr:nth-child(odd) th[scope="row"] {
      background: var(--light-beige);
    }

    /* Right-edge fade signals the table continues past the viewport; it clears
       once the reader scrolls to the end (JS toggles .is-scrolled-end). */
    .cmp-table-scroll::after {
      content: "";
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: 44px;
      background: linear-gradient(to right, transparent, var(--white));
      pointer-events: none;
      opacity: 1;
      transition: opacity var(--transition-base);
    }
    .cmp-table-scroll.is-scrolled-end::after { opacity: 0; }

    /* "Swipe to see more" hint under the table, matching the About-page modal. */
    .cmp-scroll-hint {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-2);
      margin: var(--space-4) 0 0;
      font-size: var(--text-sm);
      color: var(--color-text-muted);
      transition: opacity var(--transition-base);
    }
    .cmp-scroll-hint__arrow { animation: cmp-hint-nudge 1.4s ease-in-out infinite; }
    .cmp-table-scroll.is-scrolled-end ~ .cmp-scroll-hint { opacity: 0; }
    @keyframes cmp-hint-nudge {
      0%, 100% { transform: translateX(0); }
      50% { transform: translateX(4px); }
    }
    @media (prefers-reduced-motion: reduce) {
      .cmp-scroll-hint__arrow { animation: none; }
    }
  }
</style>

<script>
  // Show the fade + "swipe" hint until the table is scrolled to its right end.
  document.querySelectorAll<HTMLElement>('.cmp-table-scroll').forEach((scroll) => {
    const wrap = scroll.querySelector<HTMLElement>('.cmp-table-wrap');
    if (!wrap) return;
    const refresh = () => {
      const atEnd = wrap.scrollLeft + wrap.clientWidth >= wrap.scrollWidth - 4;
      scroll.classList.toggle('is-scrolled-end', atEnd);
    };
    wrap.addEventListener('scroll', refresh, { passive: true });
    window.addEventListener('resize', refresh);
    refresh();
  });
</script>
