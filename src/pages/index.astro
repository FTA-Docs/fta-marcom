---
import BaseLayout from '../layouts/BaseLayout.astro';
import Panel from '../components/Panel.astro';
import PricingBlock from '../components/PricingBlock.astro';
import ComparisonBlock from '../components/ComparisonBlock.astro';
import Reveal from '../components/Reveal.astro';
import homeData from '../../content/home.json';
import planTimeline from '../../content/plan-timeline.json';

// Wavy dotted connector for the 8-week plan timeline (coded, not an image).
// WEEK_W must match the .plan-week width in CSS so icon centres line up.
const WEEK_W = 280;
const WAVE_BASE = 44;  // y of the icon centres within the wave SVG (= track pad-top 16 + icon radius 28)
const WAVE_AMP = 22;
const planWeeks = planTimeline.weeks;
const waveW = WEEK_W * planWeeks.length;
const waveH = WAVE_BASE + WAVE_AMP + 4;
let wavePath = `M ${WEEK_W / 2} ${WAVE_BASE}`;
for (let i = 0; i < planWeeks.length - 1; i++) {
  const x0 = WEEK_W / 2 + i * WEEK_W;
  const x1 = x0 + WEEK_W;
  const peakY = i % 2 === 0 ? WAVE_BASE - WAVE_AMP : WAVE_BASE + WAVE_AMP;
  wavePath += ` C ${x0 + WEEK_W * 0.4} ${peakY}, ${x0 + WEEK_W * 0.6} ${peakY}, ${x1} ${WAVE_BASE}`;
}

// ── "Sound Familiar?" — pinned panel; each worry sits in a talk bubble
// with its negative-emotion motif drawn in pollen behind it. Scrolling
// draws each motif (line-by-line), then rewinds it as the next draws.
// Pull the real emotion SVGs in raw and keep just their <path> markup
// (drop the <svg> wrapper + white background rect). CSS recolours them.
const emotionSvgs = import.meta.glob('/public/emotions/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;
// Cap each motif's concentric arcs (evenly downsampled) so dense emotions
// don't "scribble in place" — keeps the shape's spread, calms the busyness.
const SF_MAX_ARCS = 6;
const emotionPaths = (name: string): string => {
  const raw = (emotionSvgs[`/public/emotions/${name}.svg`] ?? '')
    .replace(/<svg[^>]*>/, '')
    .replace(/<\/svg>/, '')
    .replace(/<rect[^>]*\/>/g, '');
  const paths = raw.match(/<path[\s\S]*?\/>/g) ?? [];
  if (paths.length <= SF_MAX_ARCS) return paths.join('');
  const kept: string[] = [];
  for (let i = 0; i < SF_MAX_ARCS; i++) {
    kept.push(paths[Math.round((i * (paths.length - 1)) / (SF_MAX_ARCS - 1))]);
  }
  return kept.join('');
};

// One long horizontal "pen line": each worry is a station far apart on a wide
// track; a wavy connector links them. As you scroll, the draw-front advances
// and a camera pans the track so the active station stays centred — the line
// travels, stops to scribble a shape, shows its quote, then travels on. Only
// one shape + one quote is ever in view. Geometry is px (viewBox is 1:1).
const sfCount = homeData.problem.quotes.length;
const SF_BAND_H = 580;        // track height
const SF_SCALE = 1.8;         // motif scale (native viewBox ~298, centre ~149)
const SF_C = 149 * SF_SCALE;  // motif centre after scaling
const SF_STATION_DX = 1550;   // horizontal gap between station centres (travel length)
const SF_PAD = 660;           // lead-in/out so first/last can centre
const SF_TRACK_W = SF_PAD * 2 + (sfCount - 1) * SF_STATION_DX;
const sfStationX = (i: number) => SF_PAD + i * SF_STATION_DX;
const sfStationY = () => SF_BAND_H / 2;  // shapes large + vertically centred
---

<BaseLayout title="alignd" loadGSAP={true} bodyClass="page-home">

  <!-- HERO — sticky z-index:1, CSS handles stacking -->
  <Panel id="hero" class="panel-page" background="default">
    <div class="hero-text">
      <Reveal><h1>{homeData.hero.headline}</h1></Reveal>
      <Reveal delay={100}><p class="hero__sub">{homeData.hero.subheadline}</p></Reveal>
      <Reveal delay={250}>
        <div class="hero__actions">
          <button id="watch-video-btn" class="btn btn--primary" type="button">
            {homeData.hero.cta.label}
          </button>
          <a href={homeData.hero.cta2.href} class="btn btn--secondary">
            {homeData.hero.cta2.label}
          </a>
        </div>
      </Reveal>
    </div>
    <div class="hero-media" aria-hidden="true" role="presentation">
      <div class="hero-img"></div>
      <!-- "Calm" emotion motif — colored pollen, oversized to highlight the
           player and spill past the photo edge. Strokes stay 1px at any size
           via vector-effect="non-scaling-stroke". -->
      <svg class="hero-alignment" viewBox="0 0 298 298" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M174.969 84.8067C162.361 74.6885 145.536 76.0915 131.027 84.4079C112.917 94.7883 103.254 111.628 98.6015 131.338C95.5529 144.254 94.9667 157.42 96.2646 170.826C97.6421 185.056 99.8139 198.916 104.913 212.328C109.483 224.346 116.53 233.633 129.983 235.716C139.896 237.251 150.075 238.628 159.936 236.175C174.436 232.569 183.132 222.052 188.37 208.768C194.04 194.387 195.785 179.106 197.59 163.821C199.537 147.326 197.187 131.465 192.426 115.82C189.327 105.637 184.652 96.1819 177.969 87.8067" stroke="currentColor" stroke-width="1" vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M161.969 102.807C152.223 95.2162 140.831 97.9624 129.996 105.347C115.451 115.259 109.603 129.948 107.389 146.796C105.185 163.56 105.53 180.055 110.482 196.303C113.927 207.608 119.423 217.569 131 222.229C146.196 228.346 159.773 221.78 168.508 207.33C178.023 191.591 181.89 174.379 181.324 156.311C180.813 139.986 177.594 124.178 168.131 110.197C167.126 108.712 165.236 107.795 164.969 105.807" stroke="currentColor" stroke-width="1" vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M145.469 25.3067C128.291 27.6775 113.673 35.3308 99.863 45.6653C79.5175 60.8912 70.8218 82.3086 65.5051 105.815C61.8985 121.761 60.6712 138.027 61.073 154.304C61.7332 181.052 67.2089 206.91 79.6472 230.713C86.7431 244.293 95.9167 256.636 109.952 264.337C118.716 269.146 128.24 271.688 137.977 272.107C149.857 272.617 161.775 273.129 173.522 268.958C192.674 262.158 205.751 249.607 212.949 230.799C221.365 208.808 226.28 185.891 230.434 162.8C232.346 152.177 234.272 141.559 235.558 130.817C237.135 117.641 234.624 105.279 229.447 93.316C223.381 79.2967 216.459 65.7409 207.487 53.2937C196.297 37.7701 181.099 28.645 162.445 25.447C157.102 24.531 151.469 25.3067 145.969 25.3067" stroke="currentColor" stroke-width="1" vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M153.969 52.8066C126.203 55.8944 108.867 73.3695 95.5786 95.8715C89.1109 106.823 84.7557 118.816 81.9563 131.304C79.9061 140.449 80.5408 149.684 81.5761 158.794C83.3893 174.75 85.2757 190.751 89.5309 206.29C92.9633 218.823 97.882 230.91 106.603 240.687C113.208 248.092 122.035 252.569 131.971 254.292C166.36 260.255 195.788 237.582 203.515 206.818C208.655 186.358 212.81 165.689 215.283 144.785C217.262 128.045 213.596 111.712 206.845 96.361C202.069 85.4985 196.651 74.9275 188.051 66.2252C178.676 56.7382 167.469 52.7559 154.469 52.8066" stroke="currentColor" stroke-width="1" vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </Panel>

  <!-- PROBLEM — panel in main flow so sticky spans beyond its scroll zone -->
  <Panel id="problem" class="panel-page" background="surface" fullBleed={true}>
    <div class="problem-stage">
      <!-- SR-only full quote list (the cross-fade below is decorative) -->
      <ul class="sr-only" aria-label="Worries we hear from parents">
        {homeData.problem.quotes.map(q => <li>{q.quote}</li>)}
      </ul>

      <div class="sf-center">
        <h2 class="eyebrow sf-eyebrow">{homeData.problem.heading}</h2>

        <div class="sf-line-wrap">
          <!-- Wide track: JS pans it horizontally so the active station centres -->
          <svg
            class="sf-line"
            id="sf-line"
            width={SF_TRACK_W}
            height={SF_BAND_H}
            viewBox={`0 0 ${SF_TRACK_W} ${SF_BAND_H}`}
            style={`width:${SF_TRACK_W}px;height:${SF_BAND_H}px`}
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            {homeData.problem.quotes.map((q, i) => (
              <g
                class="sf-emotion"
                data-i={i}
                transform={`translate(${sfStationX(i) - SF_C} ${sfStationY(i) - SF_C}) scale(${SF_SCALE})`}
                set:html={emotionPaths(q.emotion)}
              />
            ))}
          </svg>

          <!-- One centred quote at a time; JS fades the active worry in -->
          <div class="sf-quotes" aria-hidden="true">
            {homeData.problem.quotes.map((q, i) => (
              <p class={`sf-quote${i === 0 ? ' is-active' : ''}`} data-i={i}>"{q.quote}"</p>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Panel>
  <!-- Scroll zone follows the panel — gives GSAP room to cross-fade the quotes -->
  <div
    id="problem-scroll-zone"
    class="problem-scroll-zone"
    style={`--quote-count: ${homeData.problem.quotes.length}`}
  ></div>

  <!-- SOLUTION — panel in main flow; scroll zone provides GSAP scroll space -->
  <Panel id="solution" class="panel-page" background="default" fullBleed={true}>
    <h2 class="sr-only">A Plan for You &amp; Your Child</h2>

    <div class="sol-stage">

      <!-- Left: text blocks, cross-fade per section -->
      <div class="sol-texts">
        {homeData.solution.sections.map((section, i) => (
          <div class={`sol-text sol-text--${i}`} aria-hidden={i > 0 ? 'true' : 'false'}>
            <p class="eyebrow">{section.eyebrow}</p>
            <h2 class="panel-heading">{section.title}</h2>
            <p class="sol-body">
              {section.linkPhrase && section.body.includes(section.linkPhrase) ? (
                <Fragment>
                  {section.body.split(section.linkPhrase)[0]}
                  <button type="button" class="sol-inline-link" data-open-plan>{section.linkPhrase}</button>
                  {section.body.split(section.linkPhrase)[1]}
                </Fragment>
              ) : section.body}
            </p>
          </div>
        ))}
      </div>

      <!-- Right: horizontal filmstrip, shifts on scroll -->
      <div class="sol-filmstrip-wrap" aria-hidden="true">
        <div class="sol-filmstrip" id="sol-filmstrip">
          {homeData.solution.sections.map((section, i) => (
            <div class={`sol-phone-item sol-phone-item--${i}`}>
              <div class="sol-phone-device">
                {section.screen && (
                  <img class="sol-phone-screen" src={section.screen} alt="" aria-hidden="true" />
                )}
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>

    <div class="sol-dots" role="tablist" aria-label="Section navigation">
      {homeData.solution.sections.map((_, i) => (
        <button
          class={`sol-dot${i === 0 ? ' is-active' : ''}`}
          role="tab"
          aria-label={`Go to section ${i + 1}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          data-index={String(i)}
        />
      ))}
    </div>
  </Panel>
  <div
    id="solution-scroll-zone"
    class="solution-scroll-zone"
    style={`--sol-count: ${homeData.solution.sections.length}`}
  ></div>

  <!-- SCIENCE — sticky z-index:4 -->
  <Panel id="science" class="panel-page" background="surface">
    <div class="panel-header">
      <Reveal><p class="eyebrow">{homeData.science.eyebrow}</p></Reveal>
      <Reveal delay={100}><h2 class="panel-heading">{homeData.science.heading}</h2></Reveal>
    </div>
    <div class="science-flow">
      {homeData.science.panels.map((panel, i) => (
        <article class={`science-item${i % 2 === 1 ? ' science-item--rev' : ''}`}>
          <div
            class="science-item__media"
            style={panel.image ? `--card-img: url('${panel.image}')` : ''}
          >
            {i === 1 && (
              <svg
                class="science-deco"
                viewBox="0 0 298 298"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                set:html={emotionPaths('Balance')}
              />
            )}
          </div>
          <div class="science-item__text">
            <h3>{panel.title}</h3>
            <p>{panel.body}</p>
            {panel.cta && (
              <a href={panel.cta.href} class="science-card__link">{panel.cta.label}</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </Panel>

  <!-- PRICING — sticky z-index:5 -->
  <Panel id="pricing" class="panel-page" background="raised">
    <div class="panel-header">
      <Reveal><p class="eyebrow">{homeData.pricing.eyebrow}</p></Reveal>
      <Reveal delay={100}><h2 class="panel-heading">{homeData.pricing.heading}</h2></Reveal>
    </div>
    <PricingBlock pricing={homeData.pricing} />
  </Panel>

  <!-- COMPARISON — sticky z-index:6 -->
  <Panel id="comparison" class="panel-page" background="surface">
    <div class="panel-header">
      <Reveal><p class="eyebrow">{homeData.comparison.eyebrow}</p></Reveal>
      <Reveal delay={100}><h2 class="panel-heading">{homeData.comparison.heading}</h2></Reveal>
      {homeData.comparison.subheading && (
        <Reveal delay={200}><p class="panel-sub">{homeData.comparison.subheading}</p></Reveal>
      )}
    </div>
    <ComparisonBlock comparison={homeData.comparison} />
  </Panel>

  <!-- SOCIAL PROOF — compact strip, auto-cycles, sits directly above footer -->
  <section
    id="social-proof"
    aria-label={homeData.socialProof.heading}
  >
    <div class="sp-content">

      <div class="sp-stage" aria-live="polite" aria-atomic="true">
        {homeData.socialProof.panels.map((panel, i) => (
          <div
            class="sp-quote"
            role="group"
            aria-label={`Quote ${i + 1} of ${homeData.socialProof.panels.length}`}
            aria-hidden={i !== 0 ? 'true' : 'false'}
          >
            <blockquote class="sp-quote__text">
              <p>"{panel.quote}"</p>
              {panel.attribution && (
                <footer>
                  <cite class="sp-quote__attr">— {panel.attribution}</cite>
                </footer>
              )}
            </blockquote>
          </div>
        ))}
      </div>

      <div class="sp-dots" role="tablist" aria-label="Quote navigation">
        {homeData.socialProof.panels.map((_, i) => (
          <button
            class={`sp-dot${i === 0 ? ' is-active' : ''}`}
            role="tab"
            aria-label={`Go to quote ${i + 1}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            data-index={String(i)}
          />
        ))}
      </div>

    </div>
  </section>

  <!-- Video modal -->
  <div class="video-modal" id="video-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Watch video">
    <div class="video-modal__backdrop"></div>
    <div class="video-modal__panel">
      <button class="video-modal__close" aria-label="Close video">&times;</button>
      <div class="video-modal__screen" aria-hidden="true">
        <svg class="video-modal__play" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="32" cy="32" r="31" stroke="currentColor" stroke-width="2"/>
          <path d="M26 22l20 10-20 10V22z" fill="currentColor"/>
        </svg>
        <p>Video coming soon</p>
      </div>
    </div>
  </div>

  <!-- 8-week plan timeline modal -->
  <div class="plan-modal" id="plan-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="plan-modal-heading">
    <div class="plan-modal__backdrop"></div>
    <div class="plan-modal__panel">
      <button class="plan-modal__close" aria-label="Close">&times;</button>

      <div class="plan-modal__header">
        <p class="eyebrow">{planTimeline.eyebrow}</p>
        <h2 id="plan-modal-heading" class="plan-modal__heading">{planTimeline.heading}</h2>
        <p class="plan-modal__intro">{planTimeline.intro}</p>
      </div>

      <div class="plan-track-wrap">
        <div class="plan-track" style={`--week-w: ${WEEK_W}px`}>
          <svg
            class="plan-wave"
            width={waveW}
            height={waveH}
            viewBox={`0 0 ${waveW} ${waveH}`}
            fill="none"
            preserveAspectRatio="none"
            aria-hidden="true"
          >
            <path d={wavePath} />
          </svg>
          {planWeeks.map((w, i) => (
            <div class="plan-week" style={`--i: ${i}`}>
              <div class="plan-week__icon"><span>{w.week}</span></div>
              <h3 class="plan-week__title">{w.title}</h3>
              <p class="plan-week__body">{w.body}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>

</BaseLayout>

<style>
  /* ── Panel stacking ──────────────────────────────────── */
  /* Non-GSAP panels stick at the masthead bottom.          */
  /* GSAP-pinned panels (problem, solution, social-proof)   */
  /* don't use CSS sticky — GSAP manages their position.    */

  /* All panels stick at the masthead bottom — CSS guarantees the slide-over  */
  :global(#hero),
  :global(#problem),
  :global(#solution),
  :global(#pricing) {
    position: sticky;
    top: var(--masthead-h);
  }

  /* Science + comparison are NOT pinned — their content can exceed one
     viewport. As normal-flow panels they scroll fully through the viewport,
     while their z-index still lets them slide up over the pinned panel before
     and lets the next panel slide over them on exit. */
  :global(#science),
  :global(#comparison) {
    position: relative;
  }

  /* Desktop dwell: hold the comparison panel back ~0.8 of a screen so the
     pricing cards get read time on BOTH sides of the card-2 swap — card 1
     dwells on entry, then card 2 dwells before the comparison rises. The
     margin sits behind the pinned pricing panel, so it's invisible — it just
     delays the comparison's arrival. */
  @media (min-width: 768px) {
    :global(#comparison) { margin-top: 80svh; }
  }

  /* Mobile: non-animated panels revert to normal flow so taller content
     is never obscured by a higher-z-index panel sliding over it early. */
  @media (max-width: 767px) {
    :global(#hero),
    :global(#problem),
    :global(#science),
    :global(#pricing) {
      position: relative;
      top: 0;
    }

    /* Solution stays sticky and needs an explicit height so its flex children
       resolve correctly. panel-page resets to height:auto on mobile, which
       collapses absolutely/percentage-sized children to 0 and exposes the
       scroll-zone background as blank white space. */
    :global(#solution) {
      height: calc(100svh - var(--masthead-h));
      overflow: hidden;
    }
  }

  /* Ascending z-index so each incoming panel covers the previous */
  :global(#hero)         { z-index: 1; background-color: var(--color-bg); }
  :global(#problem)      { z-index: 2; background-color: var(--white); }
  :global(#solution)     { z-index: 3; background-color: var(--light-beige); }
  :global(#science)      { z-index: 4; background-color: var(--white); height: auto; min-height: calc(100svh - var(--masthead-h)); overflow: visible; padding-block: var(--space-10) var(--space-16); }
  :global(#pricing)      { z-index: 5; background-color: var(--light-beige); height: auto; min-height: calc(100svh - var(--masthead-h)); overflow: visible; padding-block: var(--space-10); }
  :global(#comparison)   { z-index: 6; background-color: var(--white); height: auto; min-height: calc(100svh - var(--masthead-h)); overflow: visible; padding-block: var(--space-10) var(--space-16); }
  :global(#social-proof) { position: relative; z-index: 8; background-color: var(--spring-leaf); }

  /* ── Shared panel header ─────────────────────────────── */
  /* Used at the top of every panel for eyebrow + heading  */
  .panel-header {
    text-align: center;
    /* one consistent header→content gap across every panel */
    margin-bottom: var(--space-10);
    flex-shrink: 0; /* don't compress in flex column */
  }

  /* The main headline — identical across all 6 panels */
  .panel-heading {
    font-size: var(--text-4xl);
    font-weight: var(--weight-heading);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-snug);
    color: var(--color-text);
    margin: 0;
  }

  .panel-sub {
    max-width: 64ch;
    margin-inline: auto;
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  /* ── Eyebrow — clean uppercase label, no pill ─────────── */
  .eyebrow {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--roman-coffee);
    background: var(--pale-beige);
    border: 1px solid var(--almond-beige);
    border-radius: var(--radius-full);
    padding: 0.25em 1.4em;
    margin: 0 0 var(--space-2);
  }

  /* ── Hero ────────────────────────────────────────────── */

  /* Homepage main starts at y:0 — masthead floats over the page bg seamlessly */
  :global(.page-home main) {
    padding-top: 0;
  }

  :global(#hero) {
    position: sticky;
    top: 0; /* hero fills full viewport; other panels stick at masthead-h */
    height: 100svh;
    background: var(--light-beige);
    padding-top: var(--masthead-h);
    padding-bottom: var(--space-5);
    /* No padding-inline here — the inner .container handles it,
       matching the masthead's .container model exactly */
  }

  /* Container: side-by-side row; horizontal padding comes from
     the .container class so logo and content edges align with masthead */
  :global(#hero > .container) {
    flex-direction: row;
    align-items: center;
    gap: var(--space-5);
  }


  /* ── Left: text on page background ──────────────────── */
  .hero-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center; /* vertically centre in the panel */
    align-items: flex-start;
    gap: var(--space-5);
  }

  .hero-text h1 {
    font-size: var(--text-5xl);
    color: var(--color-heading);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-snug);
    margin: 0;
  }

  .hero__sub {
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .hero__actions {
    margin-top: var(--space-2);
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Right: image card, square-ish ───────────────────── */
  /* Media wrapper holds the square photo card + the oversized motif that
     spills past it. overflow is visible so the motif can break the edge. */
  .hero-media {
    flex: 1;
    aspect-ratio: 1 / 1;
    position: relative;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    background-image: url('/soccer2.jpg');
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }

  /* Spring-leaf tint on the image card only */
  .hero-img::before {
    content: '';
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--spring-leaf) 25%, transparent);
    pointer-events: none;
  }

  /* "Alignment" motif — pollen, oversized, highlighting the player and
     breaking out of the photo into the surrounding space. */
  .hero-alignment {
    position: absolute;
    width: 138%;
    height: auto;
    left: -27%;
    top: -18%;
    color: var(--pollen);
    transform: rotate(20deg);
    transform-origin: center;
    pointer-events: none;
    overflow: visible;
    filter: drop-shadow(0 2px 10px rgb(var(--shadow-color) / 0.25));
  }

  /* Mobile: the hero stacks — headline + actions above a full-width image
     card. Placed after the base #hero rules so it wins the cascade (the
     unconditional #hero block above otherwise re-pins it). The motif still
     spills past the card; main's overflow-x:clip keeps it off the scrollbar. */
  @media (max-width: 767px) {
    :global(#hero) {
      position: relative;
      top: 0;
      height: auto;
      min-height: calc(100svh - var(--masthead-h));
      padding-bottom: var(--space-12);
    }
    :global(#hero > .container) {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-8);
    }
    .hero-text {
      flex: 0 0 auto;
      gap: var(--space-4);
    }
    .hero-media {
      flex: 0 0 auto;
      width: 100%;
      max-width: 460px;
      align-self: center;
    }
  }


  /* ── Problem: scattered Material-shape worries ───────── */
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0;
    margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  .problem-stage {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    width: 100%;
    /* visible so the motif can break past the bubble (stays within the panel) */
    overflow: visible;
  }

  /* Scroll zone — vertical scroll distance maps to the draw/rewind sequence */
  .problem-scroll-zone {
    height: calc(var(--quote-count) * 1.4 * (100vh  - var(--masthead-h)));
    height: calc(var(--quote-count) * 1.4 * (100svh - var(--masthead-h)));
  }

  /* Eyebrow ("Sound Familiar?") + quote, centred as one group in the panel */
  .sf-center {
    flex: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
  }

  .sf-eyebrow {
    align-self: center;
    margin: 0;
    position: relative;
    z-index: 2; /* always above the line */
    transform: translateY(186px); /* nudge down off the masthead, sat close to the quotes below */
  }

  /* Camera viewport — clips the wide track; JS pans the track inside it */
  .sf-line-wrap {
    position: relative;
    width: 100%;
    height: 580px;
    overflow: hidden;
    transform: translateY(-55px); /* lift the line + quotes as a set */
  }

  /* The wide pen-line track (rendered at natural px width; JS translates X) */
  .sf-line {
    position: absolute;
    left: 0;
    top: 0;
    max-width: none; /* override the global svg { max-width:100% } reset */
    color: var(--pollen);
    overflow: visible;
    will-change: transform;
  }
  /* arcs + JS-generated connectors share one crisp 1px pollen stroke */
  .sf-line :global(path) {
    stroke: currentColor;
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* One quote at a time, centred in the viewport; JS fades the active one */
  .sf-quotes {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding-inline: var(--container-pad);
    pointer-events: none;
  }
  .sf-quote {
    grid-area: 1 / 1;
    margin: 0;
    max-width: min(94vw, 24ch);
    font-family: var(--font-heading);
    font-weight: 400;
    font-style: italic;
    font-size: var(--text-5xl);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-snug);
    color: var(--roman-coffee);
    text-align: center;
    text-wrap: balance;
    opacity: 0;
  }
  .sf-quote.is-active { opacity: 1; }

  /* Reduced motion / mobile: no pan/scrub — hide the decorative track and show
     the worries as a simple centred, readable list. */
  @media (max-width: 767px), (prefers-reduced-motion: reduce) {
    :global(#problem) {
      position: relative;
      height: auto;
      min-height: 0;
      overflow: visible;
    }
    .problem-scroll-zone { display: none; }
    /* Drop the desktop nudges that positioned the eyebrow + line against the
       animated track — on mobile the eyebrow sits as a normal heading above
       the static quote list. */
    .sf-eyebrow { transform: none; }
    .sf-line-wrap { height: auto; overflow: visible; transform: none; }
    .sf-line { display: none; }
    .sf-quotes {
      position: static;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-12);
      padding-block: var(--space-8);
    }
    .sf-quote {
      grid-area: auto;
      opacity: 1;
      font-size: var(--text-3xl);
    }
  }


  /* ── Solution: 4-section inner carousel ─────────────── */
  .solution-scroll-zone {
    /* panel lives before this zone, so subtract one panel-height */
    height: calc((var(--sol-count) - 1) * (100vh  - var(--masthead-h)));
    height: calc((var(--sol-count) - 1) * (100svh - var(--masthead-h)));
  }

  .sol-stage {
    flex: 1;
    position: relative;
    overflow: hidden;
    max-width: var(--container-max);
    width: 100%;
    margin-inline: auto;
  }

  /* ── Left half: text blocks ── */
  .sol-texts {
    position: absolute;
    top: 0; bottom: 0;
    left: var(--container-pad);
    width: calc(50% - var(--container-pad));
    display: flex;
    align-items: center;
    overflow: hidden; /* clips sliding text so sections never visually overlap */
  }

  .sol-text {
    position: absolute;
    inset: 0;
    padding-right: var(--space-8);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-5);
  }

  .sol-text[aria-hidden="true"] { pointer-events: none; }

  /* Eyebrow hugs its heading like the static panels — neutralise the flex
     gap above the heading so only the heading→body spacing stays at space-5. */
  .sol-text .eyebrow { margin-bottom: calc(var(--space-2) - var(--space-5)); }

  .sol-body {
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: var(--leading-normal);
    max-width: 46ch;
  }

  .sol-text :global(.panel-heading) {
    font-size: var(--text-5xl);
    color: var(--color-heading);
  }

  /* ── Right half: phone filmstrip ── */
  .sol-filmstrip-wrap {
    position: absolute;
    top: 0; bottom: 0; right: 0;
    width: 55%;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .sol-filmstrip {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    /* GSAP sets initial x and animates shifts */
  }

  .sol-phone-item {
    flex-shrink: 0;
    width: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sol-phone-device {
    width: 188px;
    height: 376px;
    background: transparent;
    border: none;
    border-radius: 18px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 12px 40px 0 rgb(var(--shadow-color) / 0.12);
    /* GSAP manages scale + opacity */
  }

  .sol-phone-screen {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .sol-phone-device::before,
  .sol-phone-device::after {
    content: none;
  }

  /* Indicator dots */
  .sol-dots {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    padding-block: var(--space-6);
    flex-shrink: 0;
    max-width: var(--container-max);
    width: 100%;
    margin-inline: auto;
  }

  .sol-dot {
    width: 8px; height: 8px;
    border-radius: var(--radius-full);
    background: var(--color-border-strong);
    border: none; padding: 0;
    cursor: pointer;
    transition: background var(--transition-base), transform var(--transition-base);
  }

  .sol-dot.is-active {
    background: var(--color-accent);
    transform: scale(1.4);
  }

  .sol-dot:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  /* ── Solution panel (light-beige) — spring-leaf defaults are fine ── */

  /* ── Science panel — header matches the hero (large, midnight) ── */
  :global(#science) .panel-heading {
    font-size: var(--text-5xl);
    color: var(--color-heading);
  }
  /* Header up top; cards fill the remaining height (so they can be big) */
  :global(#science) > :global(.container) {
    justify-content: center;    /* middle-align the whole content unit */
    gap: var(--space-8);
  }
  :global(#science) .panel-header { margin-bottom: 0; }

  /* ── Pricing panel — hero-matched heading + body ── */
  :global(#pricing) .panel-heading {
    font-size: var(--text-5xl);
    color: var(--color-heading);
  }
  :global(#pricing) .panel-sub {
    font-size: var(--text-base);
    color: var(--color-text);
  }

  /* Plan card colors (green fills, light-beige text, position-based stack
     shades) live in PricingBlock.astro — keyed to data-position so the top
     card stays the deeper green through the scroll-driven swap. */

  /* ── Comparison panel (taupe-beige) — midnight heading, roman-coffee eyebrow ── */
  /* ── Comparison panel — hero-matched header typography ── */
  :global(#comparison) .panel-heading {
    font-size: var(--text-5xl);
    color: var(--color-heading);
  }
  :global(#comparison) .panel-sub {
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: var(--leading-normal); /* match the homepage hero sub */
  }


  /* ── Social proof (spring-leaf) — forest eyebrow, white text ── */

  :global(#social-proof) .sp-quote__text { color: var(--light-beige); }

  :global(#social-proof) .sp-quote__attr {
    color: color-mix(in srgb, var(--white) 70%, transparent);
  }

  :global(#social-proof) .sp-dot {
    background: color-mix(in srgb, var(--white) 40%, transparent);
  }
  :global(#social-proof) .sp-dot.is-active { background: var(--forest); }

  /* ── Science — organic, alternating image + text blocks ── */
  .science-flow {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
  }

  /* "Balance" emotion motif — pollen line over the Proven-Approach photo,
     centred on it and spilling past its edges. */
  .science-deco {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(calc(-28% + 20px), -50%); /* off-centred right, into the white space */
    width: 134%;                /* larger than the photo so it breaks the edges */
    max-width: none;            /* override global svg { max-width:100% } */
    aspect-ratio: 1 / 1;
    color: var(--pollen);
    z-index: 3;                 /* over the photo + tint */
    pointer-events: none;
    overflow: visible;
  }
  .science-deco :global(path) {
    stroke: currentColor;
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }


  /* Each row: a square image block overlapping a wide text block. Odd rows
     mirror (image on the right) and stagger to the other side for an organic,
     hand-placed feel. */
  .science-item {
    display: flex;
    align-items: center;
    z-index: 1;
  }
  /* Row 1: small image + wide, short text bar — hugs the left */
  .science-item:not(.science-item--rev) {
    align-self: flex-start;
    width: min(100%, 900px);    /* longer text bar */
  }
  /* Row 2: large image + wide text block — moved to the left, pulled up so
     it interlocks with row 1 (asymmetric, hand-placed). */
  .science-item--rev {
    flex-direction: row-reverse;
    align-self: center;         /* centered, then nudged right to align the text */
    width: auto;
    margin-top: calc(-10px - var(--space-16)); /* still interlocks; pulled further up to close the vertical gap */
    margin-left: 78px;          /* shifts the centred unit ~39px right (text lines up with row 1) */
  }

  .science-item__media {
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-md);
    background-color: var(--pale-beige);
    background-image: var(--card-img, linear-gradient(135deg, var(--pale-beige), var(--almond-beige)));
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: visible;          /* let the motif spill past the photo edges */
    z-index: 2;                 /* sits over the text block */
  }
  /* spring-leaf tint over the photos, like the hero image card */
  .science-item__media::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: color-mix(in srgb, var(--spring-leaf) 22%, transparent);
    pointer-events: none;
  }
  .science-item:not(.science-item--rev) .science-item__media { flex: 0 0 clamp(160px, 17vw, 220px); }
  .science-item--rev .science-item__media          { flex: 0 0 clamp(300px, 33vw, 410px); transform: translateY(-20px); }

  .science-item__text {
    background: var(--light-beige);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    z-index: 1;
  }
  /* row 1: text fills the rest (wide, short); pull under the image edge */
  .science-item:not(.science-item--rev) .science-item__text {
    flex: 1;
    margin-left: calc(-1 * var(--space-10));
    padding-left: calc(var(--space-8) + var(--space-10));
  }
  /* row 2: wider text, slightly darker beige; pull under the image edge.
     Nudged down on its own so it sits lower than the photo. */
  .science-item--rev .science-item__text {
    flex: 0 0 clamp(360px, 40vw, 480px);
    background: color-mix(in srgb, var(--almond-beige) 40%, var(--light-beige));
    margin-right: calc(-1 * var(--space-10));
    padding-right: calc(var(--space-8) + var(--space-10));
    transform: translateY(56px);
  }

  .science-item h3 {
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-normal);
    line-height: var(--leading-snug);
    color: var(--color-heading);
    margin: 0;
  }

  .science-item p {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* "Learn More" — plain green underlined text link (like the pricing link) */
  .science-card__link {
    align-self: flex-start;
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--forest);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity var(--transition-fast);
  }
  .science-card__link:hover { opacity: 0.65; }


  @media (max-width: 767px) {
    /* stack: image on top, text below; no overlap or offset */
    .science-item,
    .science-item--rev {
      flex-direction: column;
      align-items: stretch;
      align-self: center;
      width: 100%;
      max-width: 420px;
      margin-top: 0;
    }
    .science-item__media { width: 100%; flex-basis: auto; aspect-ratio: 16 / 10; }
    .science-item:not(.science-item--rev) .science-item__text,
    .science-item--rev .science-item__text {
      margin: -24px 0 0;
      padding: calc(var(--space-8) + 24px) var(--space-6) var(--space-6);
    }

    /* ── Solution: stack text above, phones below ── */
    .sol-stage {
      display: flex;
      flex-direction: column;
      flex: 1; /* fill #solution's explicit height so 45%/flex:1 children resolve */
    }

    /* Text block: compact, top third — leaves the rest for big phones */
    .sol-texts {
      position: relative;
      left: auto;
      width: 100%;
      height: 34%;
      flex-shrink: 0;
    }

    .sol-text {
      position: absolute;
      inset: 0;
      justify-content: flex-start;
      padding-top: var(--space-4);
      padding-inline: var(--container-pad);
      padding-right: var(--space-4);
      gap: var(--space-3);
    }

    /* Smaller heading + body so the text fits its compact band */
    .sol-text :global(.panel-heading) { font-size: var(--text-2xl); }
    .sol-body { font-size: var(--text-sm); }

    /* Phone filmstrip: fills the remaining ~two-thirds.
       No justify-content — GSAP owns the horizontal x position. */
    .sol-filmstrip-wrap {
      position: relative;
      left: auto; right: auto; top: auto; bottom: auto;
      width: 100%;
      flex: 1;
      overflow: hidden;
      display: flex;
      align-items: center;
    }

    /* Big phones on mobile — sized to fill the filmstrip height (the active
       phone now sits at scale 1, so this height is the rendered height) */
    .sol-phone-item { width: auto; }
    .sol-phone-device {
      width: auto;
      height: min(54svh, 460px);
      aspect-ratio: 1 / 2;
      border-radius: 22px;
    }

  }

  /* ── Social proof: scroll-zone + quote cycling ───────── */

  /* Zone is N× panel height — gives sticky panel room to cycle quotes */
  /* sp-content: container-constrained wrapper */
  .sp-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: var(--container-max);
    width: 100%;
    margin-inline: auto;
    padding-block: var(--space-10) var(--space-6);
  }

  /* Stage clips the sliding quotes; height sized to quote content */
  .sp-stage {
    position: relative;
    overflow: hidden;
    width: 100%;
    height: clamp(100px, 14vh, 160px);
  }

  /* Each quote fills the stage; JS drives transform */
  .sp-quote {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding-inline: var(--container-pad);
    transform: translateX(100%);
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .sp-quote:first-child {
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .sp-quote { transition: none; }
  }

  .sp-quote__text {
    max-width: 48ch;
    text-align: left;
    border: none;
    padding: 0;
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: var(--weight-heading);
    font-style: italic;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
  }

  .sp-quote__text p {
    font-size: inherit;
    font-weight: inherit;
    color: inherit;
    line-height: inherit;
    margin-bottom: var(--space-4);
  }

  .sp-quote__attr {
    display: block;
    font-size: var(--text-xs);
    font-style: normal;
    font-weight: var(--weight-semibold);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
  }

  /* Indicator dots */
  .sp-dots {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    padding-block: 0;
    padding-top: var(--space-2);
    padding-bottom: var(--space-4);
    flex-shrink: 0;
  }

  .sp-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: var(--color-border-strong);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background var(--transition-base), transform var(--transition-base);
  }

  .sp-dot.is-active {
    background: var(--color-accent);
    transform: scale(1.4);
  }

  .sp-dot:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  /* ── Video modal ─────────────────────────────────────── */
  .video-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: var(--z-modal, 200);
    align-items: center;
    justify-content: center;
  }
  .video-modal[aria-hidden="false"] { display: flex; }

  .video-modal__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--midnight) 92%, transparent);
  }

  .video-modal__panel {
    position: relative;
    width: min(900px, calc(100% - var(--space-8)));
    aspect-ratio: 16 / 9;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .video-modal__close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    z-index: 2;
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    background: color-mix(in srgb, var(--midnight) 55%, transparent);
    border: none;
    border-radius: var(--radius-sm);
    color: var(--white);
    font-size: var(--text-xl);
    line-height: 1;
    cursor: pointer;
    transition: background var(--transition-fast);
  }
  .video-modal__close:hover { background: color-mix(in srgb, var(--midnight) 80%, transparent); }

  .video-modal__screen {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    color: var(--color-text-muted);
  }

  .video-modal__play {
    width: 64px;
    height: 64px;
    opacity: 0.4;
  }

  .video-modal__screen p {
    font-size: var(--text-sm);
    margin: 0;
  }

  /* ── Inline "8-week plans" link in the solution copy ── */
  .sol-inline-link {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    transition: opacity var(--transition-fast);
  }
  .sol-inline-link:hover { opacity: 0.65; }

  /* ── 8-week plan timeline modal ── */
  .plan-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: var(--z-modal, 200);
    align-items: center;
    justify-content: center;
  }
  .plan-modal[aria-hidden="false"] { display: flex; }

  /* Right-edge fade — signals more content to scroll */
  .plan-modal__panel::after {
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 140px;
    background: linear-gradient(to right, transparent, var(--color-bg) 80%);
    pointer-events: none;
    z-index: 2;
  }

  .plan-modal__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--midnight) 65%, transparent);
  }

  .plan-modal__panel {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border-radius: var(--radius-md);
    width: min(1100px, calc(100% - var(--space-6)));
    max-height: min(92vh, 860px);
    padding-block: var(--space-8);
    overflow: hidden;
  }

  .plan-modal__close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    z-index: 3;
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    background: var(--color-surface-raised);
    border: none;
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    font-size: var(--text-xl);
    line-height: 1;
    cursor: pointer;
    transition: color var(--transition-fast);
  }
  .plan-modal__close:hover { color: var(--color-text); }

  .plan-modal__header {
    padding-inline: var(--space-10);
    margin-bottom: var(--space-6);
    max-width: 62ch;
  }
  .plan-modal__heading {
    font-family: var(--font-heading);
    font-weight: var(--weight-heading);
    font-size: var(--text-4xl);
    color: var(--color-heading);
    margin: var(--space-3) 0 var(--space-4);
  }
  .plan-modal__intro {
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Horizontal pan track */
  .plan-track-wrap {
    overflow-x: auto;
    overflow-y: hidden;
    padding-inline: var(--space-10);
    padding-bottom: var(--space-4);
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    position: relative;
  }
  .plan-track-wrap::-webkit-scrollbar { display: none; }


  .plan-track {
    position: relative;
    display: flex;
    width: max-content;
    padding-top: 16px; /* icon centre lands at WAVE_BASE (44px) */
  }

  .plan-wave {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 0;
    pointer-events: none;
  }
  .plan-wave path {
    stroke: var(--color-border-strong);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 1.5 9; /* dotted */
  }

  .plan-week {
    position: relative;
    z-index: 1;
    box-sizing: border-box;
    flex: 0 0 var(--week-w);
    width: var(--week-w);
    padding-inline: var(--space-5);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    scroll-snap-align: center;
  }

  .plan-week__icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    background: var(--color-accent);
    color: var(--color-accent-text);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: var(--weight-heading);
    font-size: var(--text-base);
    /* halo so the wavy line reads as connecting into the node */
    box-shadow: 0 0 0 5px var(--color-bg);
  }

  .plan-week__title {
    font-family: var(--font-heading);
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    color: var(--color-heading);
    letter-spacing: var(--tracking-normal);
    line-height: var(--leading-snug);
    white-space: pre-line;
    margin: var(--space-4) 0 var(--space-1);
  }

  .plan-week__body {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Subtle motion: dots march along the wave; weeks rise in on open */
  @media (prefers-reduced-motion: no-preference) {
    .plan-wave path {
      animation: plan-wave-march 7s linear infinite;
    }
    @keyframes plan-wave-march {
      to { stroke-dashoffset: -101; }
    }

    .plan-week {
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.5s ease, transform 0.5s ease;
      transition-delay: calc(var(--i) * 60ms);
    }
    .plan-modal[aria-hidden="false"] .plan-week {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 767px) {
    .plan-modal__header,
    .plan-track-wrap { padding-inline: var(--space-6); }
    .plan-modal__panel { padding-block: var(--space-8) var(--space-6); }
    .plan-modal__heading { font-size: var(--text-2xl); }
  }

  /* ── Social proof: mobile overrides ── */
  @media (max-width: 767px) {
    .sp-quote__text {
      font-size: var(--text-xl);
    }
    /* Quotes run several lines longer at this width — give the (fixed-height,
       overflow-hidden) stage room so the attribution is never clipped. */
    .sp-stage {
      height: auto;
      min-height: clamp(160px, 30vh, 210px);
    }
  }
</style>

<script>
  // ── Shared setup ──────────────────────────────────────────
  const mastheadH = (document.querySelector('.masthead') as HTMLElement)?.offsetHeight ?? 64;
  const panelH = () => window.innerHeight - mastheadH;

  // ── Video modal ───────────────────────────────────────────────
  const videoModal = document.getElementById('video-modal');
  // Move to body to escape any stacking context
  if (videoModal) document.body.appendChild(videoModal);

  const videoBtn = document.getElementById('watch-video-btn');
  const closeVideoBtn = videoModal?.querySelector('.video-modal__close');
  const videoBackdrop = videoModal?.querySelector('.video-modal__backdrop');

  function openVideoModal() {
    videoModal?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeVideoModal() {
    videoModal?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  videoBtn?.addEventListener('click', openVideoModal);
  closeVideoBtn?.addEventListener('click', closeVideoModal);
  videoBackdrop?.addEventListener('click', closeVideoModal);
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && videoModal?.getAttribute('aria-hidden') === 'false') closeVideoModal();
  });

  // ── 8-week plan timeline modal ────────────────────────────────
  const planModal = document.getElementById('plan-modal');
  // Move to body so it escapes the sticky/pinned panel stacking contexts
  if (planModal) document.body.appendChild(planModal);

  const planOpenBtns = document.querySelectorAll('[data-open-plan]');
  const planClose = planModal?.querySelector('.plan-modal__close');
  const planBackdrop = planModal?.querySelector('.plan-modal__backdrop');
  const planTrackWrap = planModal?.querySelector('.plan-track-wrap') as HTMLElement | null;

  function openPlanModal() {
    planModal?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    if (planTrackWrap) planTrackWrap.scrollLeft = 0; // always start at week 1
  }
  function closePlanModal() {
    planModal?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  planOpenBtns.forEach(btn => btn.addEventListener('click', openPlanModal));
  planClose?.addEventListener('click', closePlanModal);
  planBackdrop?.addEventListener('click', closePlanModal);
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && planModal?.getAttribute('aria-hidden') === 'false') closePlanModal();
  });

  // ── Anchor nav fix for sticky panels ─────────────────────────
  // sticky elements' offsetTop reflects their current VISUAL position
  // (mastheadH + scrollY), not their natural flow position. We temporarily
  // un-stick to read the true layout offset, then restore.
  const getFlowTop = (el: HTMLElement): number => {
    const prev = el.style.position;
    el.style.position = 'static';
    const top = el.offsetTop;
    el.style.position = prev;
    return top;
  };

  document.querySelectorAll<HTMLAnchorElement>('a[href*="#"]').forEach(link => {
    link.addEventListener('click', e => {
      const hash = link.getAttribute('href')?.split('#')[1];
      if (!hash) return;
      const target = document.getElementById(hash);
      if (!target) return;
      e.preventDefault();
      window.scrollTo({ top: Math.max(0, getFlowTop(target) - mastheadH), behavior: 'smooth' });
    });
  });

  // ── Social proof carousel — auto-cycles every 5s ─────────
  const spQuotes = Array.from(document.querySelectorAll<HTMLElement>('.sp-quote'));
  const spDots   = Array.from(document.querySelectorAll<HTMLElement>('.sp-dot'));

  if (spQuotes.length > 1) {
    const quoteCount = spQuotes.length;
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    // Place quotes in a horizontal train without triggering CSS transition
    spQuotes.forEach((q, i) => {
      q.style.transition = 'none';
      q.style.transform  = `translateX(${i * 100}%)`;
    });
    // Re-enable transition after initial paint
    requestAnimationFrame(() => requestAnimationFrame(() => {
      spQuotes.forEach(q => q.style.removeProperty('transition'));
    }));

    function showQuote(idx: number) {
      current = Math.max(0, Math.min(idx, quoteCount - 1));
      spQuotes.forEach((q, i) => {
        q.style.transform = `translateX(${(i - current) * 100}%)`;
        q.setAttribute('aria-hidden', String(i !== current));
      });
      spDots.forEach((dot, i) => {
        const active = i === current;
        dot.classList.toggle('is-active', active);
        dot.setAttribute('aria-selected', String(active));
      });
    }

    function advance() {
      showQuote((current + 1) % quoteCount);
    }

    function startTimer() {
      timer = setInterval(advance, 8000);
    }

    function resetTimer() {
      clearInterval(timer);
      startTimer();
    }

    // Dot clicks: jump to quote and reset the auto-cycle
    spDots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        showQuote(i);
        resetTimer();
      });
    });

    // Pause on hover/focus, resume on leave
    const spSection = document.getElementById('social-proof');
    spSection?.addEventListener('mouseenter', () => clearInterval(timer));
    spSection?.addEventListener('mouseleave', startTimer);
    spSection?.addEventListener('focusin',    () => clearInterval(timer));
    spSection?.addEventListener('focusout',   startTimer);

    startTimer();
  }

  // ── GSAP: hero parallax + reveal fade-ins ─────────────────
  (window as any).gsapActive = true;

  (async () => {
    try {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        (window as any).gsapActive = false;
        const io = new IntersectionObserver(
          (entries) => entries.forEach((e) => {
            if (e.isIntersecting) {
              (e.target as HTMLElement).classList.add('is-revealed');
              io.unobserve(e.target);
            }
          }),
          { threshold: 0.12 }
        );
        document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
        return;
      }

      const { gsap } = await import('gsap');
      const { ScrollTrigger } = await import('gsap/ScrollTrigger');
      gsap.registerPlugin(ScrollTrigger);

      // ── Parallax depth: hero content recedes as problem slides over it ──
      gsap.to('#hero > .container > *', {
        y: '-4%',
        opacity: 0.5,
        ease: 'none',
        scrollTrigger: {
          trigger: '#problem',
          start: `top top+=${mastheadH}`,
          end: `+=${window.innerHeight * 0.6}`,
          scrub: 1,
        },
      });

      // ── Solution: scroll-driven inner section cycling ────
      const solZone     = document.getElementById('solution-scroll-zone');
      const solTexts    = Array.from(document.querySelectorAll<HTMLElement>('.sol-text'));
      const solDots     = Array.from(document.querySelectorAll<HTMLElement>('.sol-dot'));
      const filmstrip   = document.getElementById('sol-filmstrip') as HTMLElement | null;
      const filmstripWrap = filmstrip?.parentElement as HTMLElement | null;
      const phoneDivs   = Array.from(document.querySelectorAll<HTMLElement>('.sol-phone-device'));
      const phoneItems  = Array.from(document.querySelectorAll<HTMLElement>('.sol-phone-item'));

      if (solZone && solTexts.length > 1 && filmstrip && filmstripWrap) {
        const solCount = solTexts.length;

        // On mobile the active phone sits at full scale (the CSS sizes it to
        // fill the viewport height) so it doesn't overflow when scaled up;
        // on desktop the active phone grows past its neighbours.
        const isMobile = window.matchMedia('(max-width: 767px)').matches;
        const PH_ACTIVE   = isMobile ? 1    : 1.55;
        const PH_INACTIVE = isMobile ? 0.72 : 0.82;

        // Compute step from rendered positions (handles any gap/size)
        const STEP = phoneItems.length > 1
          ? phoneItems[1].getBoundingClientRect().left - phoneItems[0].getBoundingClientRect().left
          : 180;

        // Center phone 0 in the wrap
        const wrapW   = filmstripWrap.offsetWidth;
        const phoneW  = phoneItems[0]?.offsetWidth ?? 160;
        const initX   = wrapW / 2 - phoneW / 2;

        // Initialize positions
        gsap.set(filmstrip, { x: initX });
        // Each section's full text block (eyebrow + heading + body) slides:
        // the outgoing one exits left as the incoming one enters from the right.
        gsap.set(solTexts.slice(1), { xPercent: 100 });
        phoneDivs.forEach((p, i) => gsap.set(p,
          i === 0 ? { scale: PH_ACTIVE, opacity: 1 } : { scale: PH_INACTIVE, opacity: 0.45 }
        ));

        // Even pacing: every section gets an identical dwell, separated by
        // equal-length transitions — including a leading dwell before the first
        // transition and a trailing dwell after the last, so section 4 rests on
        // screen before the panel unpins, mirroring section 1's entrance.
        const TRANS = 0.28;   // scroll fraction spent moving between sections
        const DWELL = 0.72;   // scroll fraction each section holds, still
        const total = DWELL * solCount + TRANS * (solCount - 1);
        const solTl = gsap.timeline({ paused: true });
        // Reserve the full duration so the trailing dwell exists — nothing
        // animates during it, so GSAP would otherwise trim the timeline short.
        solTl.to({}, { duration: total }, 0);

        for (let i = 0; i < solCount - 1; i++) {
          const t = DWELL * (i + 1) + TRANS * i;   // transition i fires after section i's dwell

          // Slide the full text block (eyebrow included) out as the next slides in
          solTl.to(solTexts[i],     { xPercent: -100, ease: 'power2.inOut', duration: TRANS }, t);
          solTl.to(solTexts[i + 1], { xPercent:    0, ease: 'power2.inOut', duration: TRANS }, t);

          // Filmstrip slides left
          solTl.to(filmstrip, { x: initX - (i + 1) * STEP, ease: 'power2.inOut', duration: TRANS }, t);

          // Phone scales: active grows, outgoing shrinks
          solTl.to(phoneDivs[i],     { scale: PH_INACTIVE, opacity: 0.45, ease: 'power1.in',    duration: TRANS * 0.9 }, t);
          solTl.to(phoneDivs[i + 1], { scale: PH_ACTIVE,   opacity: 1,    ease: 'back.out(1.2)', duration: TRANS * 0.9 }, t);
        }

        ScrollTrigger.create({
          trigger: solZone,
          start: `top top+=${mastheadH}`,
          end: () => `+=${(solCount - 1) * panelH()}`,
          scrub: 1,
          invalidateOnRefresh: true,
          animation: solTl,
          onUpdate(self) {
            // Active section flips at the midpoint of each transition, matching
            // the even dwell/transition layout above (not uniform progress).
            const time = self.progress * total;
            let idx = 0;
            for (let i = 0; i < solCount - 1; i++) {
              if (time >= DWELL * (i + 1) + TRANS * i + TRANS / 2) idx = i + 1;
            }
            solDots.forEach((dot, i) => {
              const active = i === idx;
              dot.classList.toggle('is-active', active);
              dot.setAttribute('aria-selected', String(active));
            });
            solTexts.forEach((s, i) => {
              s.setAttribute('aria-hidden', String(i !== idx));
            });
          },
        });

        solDots.forEach((dot, i) => {
          dot.addEventListener('click', () => {
            const zoneTop = getFlowTop(solZone);
            window.scrollTo({
              top: Math.max(0, zoneTop - mastheadH + i * panelH()),
              behavior: 'smooth',
            });
          });
        });
      }

      // ── Problem: a traveling pen line, one shape + one quote at a time ──
      // Panel is pinned. The motifs are far-apart stations on a wide track,
      // bridged by wavy connectors into one unbroken polyline. Scrolling
      // advances a single draw-front (cumulative stroke-dashoffset) AND pans a
      // camera so the active station stays centred — the line travels, holds
      // to scribble a shape, fades its quote in, then travels on. Disabled
      // below 768px / reduced motion (CSS shows a static list).
      const sfZone = document.getElementById('problem-scroll-zone');
      const sfLine = document.getElementById('sf-line') as SVGSVGElement | null;
      const sfQuotes = Array.from(document.querySelectorAll<HTMLElement>('.sf-quote'));
      if (sfZone && sfLine && sfLine.parentElement && window.matchMedia('(min-width: 768px)').matches) {
        const SVGNS = 'http://www.w3.org/2000/svg';
        const wrap = sfLine.parentElement;
        const groups = Array.from(sfLine.querySelectorAll<SVGGElement>('g.sf-emotion'));

        // Point on a path, mapped into the SVG root (viewBox) coordinate space
        const rootPoint = (path: SVGPathElement, len: number) => {
          const p = path.getPointAtLength(len);
          const m = path.getCTM();
          return m ? { x: m.a * p.x + m.c * p.y + m.e, y: m.b * p.x + m.d * p.y + m.f } : p;
        };
        // Each station's centre x in track coords (viewBox px = rendered px)
        const stationCX = groups.map((g) => {
          const bb = g.getBBox();
          const m = g.getCTM()!;
          return m.a * (bb.x + bb.width / 2) + m.c * (bb.y + bb.height / 2) + m.e;
        });

        // Ordered arcs (station L→R, doc order within), tagged with station
        const arcs: { p: SVGPathElement; si: number }[] = [];
        groups.forEach((g, si) =>
          g.querySelectorAll<SVGPathElement>('path').forEach((p) => arcs.push({ p, si })));

        // Build the unbroken polyline: arc → connector → arc …  Between two
        // stations the connector is a wavy curve (the "travel"); within a
        // station it's a short straight hop (part of the scribble).
        const ordered: { el: SVGElement; si: number }[] = [];
        arcs.forEach((arc, k) => {
          if (k > 0) {
            const prev = arcs[k - 1];
            const a = rootPoint(prev.p, prev.p.getTotalLength());
            const b = rootPoint(arc.p, 0);
            const c = document.createElementNS(SVGNS, 'path');
            if (prev.si !== arc.si) {
              // long multi-hump wave between stations — the "travel" stroke
              const dx = b.x - a.x;
              const HUMPS = 2.5;
              const AMP = 120;
              const SAMP = 40;
              let d = `M ${a.x.toFixed(1)} ${a.y.toFixed(1)}`;
              for (let t = 1; t <= SAMP; t++) {
                const f = t / SAMP;
                const x = a.x + dx * f;
                const y = a.y + (b.y - a.y) * f + AMP * Math.sin(f * HUMPS * Math.PI);
                d += ` L ${x.toFixed(1)} ${y.toFixed(1)}`;
              }
              c.setAttribute('d', d);
            } else {
              c.setAttribute('d', `M ${a.x} ${a.y} L ${b.x} ${b.y}`);
            }
            c.setAttribute('class', 'sf-connector');
            sfLine.appendChild(c);
            ordered.push({ el: c, si: prev.si === arc.si ? arc.si : -1 });
          }
          ordered.push({ el: arc.p, si: arc.si });
        });

        // Prime every segment hidden; record cumulative starts + total length.
        // NOTE: vector-effect:non-scaling-stroke measures the dash in screen px,
        // but getTotalLength() is in the path's LOCAL units — and the motif arcs
        // sit inside a scale() group. Multiply by the element's CTM scale so the
        // dash length matches the on-screen stroke (otherwise arcs never hide).
        let total = 0;
        const segs = ordered.map((o) => {
          const m = o.el.getCTM();
          const sc = m ? Math.hypot(m.a, m.b) : 1;
          const len = (o.el as SVGGeometryElement).getTotalLength() * sc;
          o.el.style.strokeDasharray = String(len);
          o.el.style.strokeDashoffset = String(len);
          const s = total;
          total += len;
          return { ...o, len, s };
        });
        // Per-station draw range (first arc start → last arc end)
        const N = groups.length;
        const stStart = Array(N).fill(Infinity);
        const stEnd = Array(N).fill(0);
        segs.forEach((s) => {
          if (s.si < 0) return;
          stStart[s.si] = Math.min(stStart[s.si], s.s);
          stEnd[s.si] = Math.max(stEnd[s.si], s.s + s.len);
        });

        const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
        const FADE = 260; // length units over which a quote fades in/out

        // Even pacing: split the draw into equal phases (shape, travel, shape,
        // …) so every quote dwells the same regardless of its line-length. The
        // pen just speeds up on longer shapes and slows on shorter ones.
        const Dbounds = [stStart[0]];
        for (let k = 0; k < N; k++) {
          Dbounds.push(stEnd[k]);
          if (k < N - 1) Dbounds.push(stStart[k + 1]);
        }
        const PHASES = Dbounds.length - 1; // shapes + travels

        ScrollTrigger.create({
          trigger: sfZone,
          start: 'top bottom',   // begin as soon as the panel is fully in view
          end: 'bottom bottom',  // ...through the end of the scroll zone
          scrub: 1, // ease the draw-front so each connector visibly draws into its shape
          invalidateOnRefresh: true,
          onUpdate(self) {
            // finish the whole line a bit before the end so the last shape
            // holds complete before the next panel slides in
            const SF_FINISH = 0.85;
            const dp = Math.min(1, self.progress / SF_FINISH); // 0→1 draw progress
            const fp = dp * PHASES;
            const pi = Math.min(PHASES - 1, Math.floor(fp));
            const D = lerp(Dbounds[pi], Dbounds[pi + 1], fp - pi); // equal scroll per phase

            // 1) advance the single draw-front along the whole polyline
            for (const s of segs) {
              const drawn = D - s.s;
              s.el.style.strokeDashoffset = String(drawn <= 0 ? s.len : drawn >= s.len ? 0 : s.len - drawn);
            }

            // 2) pan the camera: hold on a station while scribbling, lerp along
            //    the connector while traveling between stations
            let camX = stationCX[0];
            if (D >= stEnd[N - 1]) camX = stationCX[N - 1];
            else for (let k = 0; k < N; k++) {
              if (D <= stEnd[k]) { camX = stationCX[k]; break; }
              if (k < N - 1 && D < stStart[k + 1]) {
                camX = lerp(stationCX[k], stationCX[k + 1], (D - stEnd[k]) / (stStart[k + 1] - stEnd[k]));
                break;
              }
            }
            sfLine.style.transform = `translateX(${wrap.clientWidth / 2 - camX}px)`;

            // 3) fade in the quote of whichever station the front is on
            sfQuotes.forEach((q, k) => {
              const dist = D < stStart[k] ? stStart[k] - D : D > stEnd[k] ? D - stEnd[k] : 0;
              q.style.opacity = String(Math.max(0, Math.min(1, 1 - dist / FADE)));
            });
          },
        });
      }

      // ── Science blocks: each of the 4 sub-blocks travels into its lockup ──
      // The two halves of each row drift in from their own direction and settle
      // as the row nears the viewport centre. Scrubbed (not a one-shot) so the
      // motion is always visible scrolling into/through the section. Relative
      // offsets ('+=' / '-=') preserve the resting CSS transforms on the rev row.
      //   row 1 (photo + text):  photo bottom→top,  text right→left
      //   row 2 (text + photo):  text top→bottom,   photo left→right
      gsap.utils.toArray<HTMLElement>('#science .science-item').forEach((el, i) => {
        const media = el.querySelector<HTMLElement>('.science-item__media');
        const text = el.querySelector<HTMLElement>('.science-item__text');
        const moves = i % 2 === 1
          ? { media: { x: '-=40' }, text: { y: '-=40' } }    // row 2: photo left→right, text top→bottom
          : { media: { y: '+=110' }, text: { x: '+=40' } };  // row 1: photo bottom→top (bigger), text right→left

        [
          [media, moves.media],
          [text, moves.text],
        ].forEach(([node, offset]) => {
          if (!node) return;
          gsap.from(node as HTMLElement, {
            ...(offset as Record<string, string>),
            ease: 'none',
            scrollTrigger: {
              trigger: el,
              start: 'top bottom',
              end: 'top center+=60',
              scrub: true,
              invalidateOnRefresh: true,
            },
          });
        });
      });

      // ── Reveal fade-ins ──────────────────────────────────────
      document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
        ScrollTrigger.create({
          trigger: el,
          start: 'top bottom-=80',
          onEnter: () => el.classList.add('is-revealed'),
          once: true,
        });
      });

    } catch (err) {
      console.warn('[alignd] GSAP initialization failed — skipping animations.', err);
    }
  })();
</script>
