---
import BaseLayout from '../layouts/BaseLayout.astro';

// Enumerate the token names per group. Values are read LIVE from the CSS at
// runtime (var() for specimens, getComputedStyle for the spec labels), so this
// page reflects the skin automatically — change a token and it updates here.

const palette = [
  '--white', '--secondary-grey', '--prime-grey', '--dark-grey', '--midnight',
  '--spring-leaf', '--forest', '--pollen', '--roman-coffee', '--red',
  '--light-beige', '--pale-beige', '--taupe-beige', '--heavy-beige', '--almond-beige', '--blush',
];

const colorGroups = [
  ['Surfaces',       ['--color-bg', '--color-surface', '--color-surface-raised', '--color-surface-overlay']],
  ['Text',           ['--color-heading', '--color-text', '--color-text-muted', '--color-text-subtle']],
  ['Borders',        ['--color-border', '--color-border-strong']],
  ['Accent · primary', ['--color-accent', '--color-accent-hover', '--color-accent-text']],
  ['Secondary',      ['--color-secondary', '--color-secondary-hover', '--color-secondary-text']],
  ['Masthead',       ['--masthead-bg', '--masthead-text']],
  ['Footer',         ['--footer-bg', '--footer-text', '--footer-text-muted', '--footer-border']],
];

const fonts = [
  ['--font-heading', 'Lora — headings'],
  ['--font-body', 'Figtree — body & UI'],
  ['--font-mono', 'Monospace — code'],
];

const typeScale = [
  '--text-2xs', '--text-xs', '--text-sm', '--text-base', '--text-lg', '--text-xl',
  '--text-2xl', '--text-3xl', '--text-4xl', '--text-5xl', '--text-6xl',
];

const weights = [
  '--weight-normal', '--weight-medium', '--weight-semibold', '--weight-bold', '--weight-black', '--weight-heading',
];

const leadings = ['--leading-tight', '--leading-snug', '--leading-normal', '--leading-heading', '--leading-body'];
const trackings = ['--tracking-tight', '--tracking-snug', '--tracking-normal', '--tracking-wide', '--tracking-wider'];

const spacing = [
  '--space-1', '--space-2', '--space-3', '--space-4', '--space-5', '--space-6',
  '--space-8', '--space-10', '--space-12', '--space-14', '--space-16', '--space-20',
];

const radii = ['--radius-sm', '--radius-md', '--radius-media', '--radius-full'];
const shadows = ['--shadow-sm'];
const zindex = ['--z-masthead'];
const transitions = ['--transition-fast', '--transition-base', '--transition-slow'];

// UI line-icon set — one system: 24×24 viewBox, currentColor, round caps/joins,
// single 1.6 stroke (applied in CSS), no fills. Keeps every icon visually equal.
const icons = [
  { label: 'Chevron', view: '0 0 24 24', paths: '<path d="M6 9l6 6 6-6"/>' },
  { label: 'Close', view: '0 0 24 24', paths: '<path d="M6 6l12 12M6 18 18 6"/>' },
  { label: 'Menu', view: '0 0 24 24', paths: '<path d="M3 6h18M3 12h18M3 18h18"/>' },
  { label: 'Arrow', view: '0 0 24 24', paths: '<path d="M4 12h15M13 6l6 6-6 6"/>' },
  { label: 'Play', view: '0 0 24 24', paths: '<circle cx="12" cy="12" r="9"/><path d="M10 8.5v7l6-3.5z"/>' },
  { label: 'Capability', view: '0 0 24 24', paths: '<path d="M9 18h6M10 21h4M12 3a6 6 0 0 0-3.6 10.8c.5.4.9 1 1 1.7l.1.5h5l.1-.5c.1-.7.5-1.3 1-1.7A6 6 0 0 0 12 3z"/>' },
  { label: 'Opportunity', view: '0 0 24 24', paths: '<path d="M12 3 4 7.5v9L12 21l8-4.5v-9L12 3zM4 7.5 12 12m0 0 8-4.5M12 12v9"/>' },
  { label: 'Motivation', view: '0 0 24 24', paths: '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/>' },
];

const toc = [
  ['logo', 'Logo'], ['colors', 'Colors'], ['type', 'Typography'], ['spacing', 'Spacing'],
  ['radius', 'Radius'], ['shadow', 'Shadow'], ['photo', 'Photo treatment'], ['icons', 'Icons'], ['system', 'Z-index & motion'],
  ['buttons', 'Buttons'], ['elements', 'Text elements'], ['patterns', 'Patterns'],
];
---

<BaseLayout
  title="Design System"
  description="Living reference for alignd's design tokens and components."
  noindex={true}
>
  <div class="ds">
    <header class="ds-hero">
      <p class="ds-kicker">Internal · living reference</p>
      <h1>Design System</h1>
      <p class="ds-intro">
        Every value below is read live from the CSS tokens. When you apply the
        brand skin (<code>skin.css</code> / <code>structure.css</code>), this page
        updates automatically — the swatches and specimens use <code>var()</code>,
        and the spec labels are resolved at runtime.
      </p>
      <nav class="ds-toc" aria-label="Sections">
        {toc.map(([id, label]) => <a href={`#${id}`} class="ds-toc__link">{label}</a>)}
      </nav>
    </header>

    <!-- ── LOGO ── -->
    <section id="logo" class="ds-section">
      <div class="ds-section__head"><h2>Logo</h2></div>
      <div class="ds-logo-grid">
        <div class="ds-logo-swatch ds-logo-swatch--light">
          <img src="/alignd_logo_fullcolor.svg" alt="alignd logo" class="ds-logo-img" width="183" height="28" />
          <span class="ds-logo-label">On light</span>
        </div>
        <div class="ds-logo-swatch ds-logo-swatch--dark">
          <img src="/alignd_logo_reversed.svg" alt="alignd logo" class="ds-logo-img" width="183" height="28" />
          <span class="ds-logo-label">On dark</span>
        </div>
        <div class="ds-logo-swatch ds-logo-swatch--beige">
          <img src="/alignd_logo_fullcolor.svg" alt="alignd logo" class="ds-logo-img" width="183" height="28" />
          <span class="ds-logo-label">On beige</span>
        </div>
      </div>
    </section>

    <!-- ── COLORS ── -->
    <section id="colors" class="ds-section">
      <div class="ds-section__head"><h2>Colors</h2></div>

      {colorGroups.map(([title, tokens]) => (
        <div class="ds-group">
          <h3 class="ds-group__title">{title}</h3>
          <div class="ds-swatches">
            {tokens.map(t => (
              <figure class="ds-swatch" data-var={t} data-kind="color">
                <div class="ds-swatch__chip" style={`background: var(${t})`}></div>
                <figcaption>
                  <code class="ds-name">{t}</code>
                  <code class="ds-val" data-hex></code>
                  <code class="ds-ref" data-raw></code>
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      ))}

      <div class="ds-group">
        <h3 class="ds-group__title">Raw palette</h3>
        <div class="ds-swatches ds-swatches--palette">
          {palette.map(t => (
            <figure class="ds-swatch" data-var={t} data-kind="color">
              <div class="ds-swatch__chip" style={`background: var(${t})`}></div>
              <figcaption>
                <code class="ds-name">{t}</code>
                <code class="ds-val" data-hex></code>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- ── TYPOGRAPHY ── -->
    <section id="type" class="ds-section">
      <div class="ds-section__head"><h2>Typography</h2></div>

      <div class="ds-group">
        <h3 class="ds-group__title">Font families</h3>
        {fonts.map(([t, label]) => (
          <div class="ds-font-row" data-var={t}>
            <p class="ds-font-sample" style={`font-family: var(${t})`}>Healthy habits, aligned</p>
            <div class="ds-meta">
              <code class="ds-name">{t}</code>
              <span class="ds-label">{label}</span>
              <code class="ds-ref" data-raw></code>
            </div>
          </div>
        ))}
      </div>

      <div class="ds-group">
        <h3 class="ds-group__title">Type scale</h3>
        {typeScale.map(t => (
          <div class="ds-type-row" data-var={t} data-kind="size" data-pxprop="font-size">
            <div class="ds-type-meta">
              <code class="ds-name">{t}</code>
              <code class="ds-val"><span data-px></span></code>
              <code class="ds-ref" data-raw></code>
            </div>
            <p class="ds-type-sample" style={`font-size: var(${t})`}>Healthy habits</p>
          </div>
        ))}
      </div>

      <div class="ds-group">
        <h3 class="ds-group__title">Weights</h3>
        {weights.map(t => (
          <div class="ds-line-row" data-var={t}>
            <p class="ds-weight-sample" style={`font-weight: var(${t})`}>Aligned · the quick brown fox</p>
            <div class="ds-meta"><code class="ds-name">{t}</code><code class="ds-val" data-raw></code></div>
          </div>
        ))}
      </div>

      <div class="ds-group">
        <h3 class="ds-group__title">Line height</h3>
        {leadings.map(t => (
          <div class="ds-leading-row" data-var={t}>
            <div class="ds-meta"><code class="ds-name">{t}</code><code class="ds-val" data-raw></code></div>
            <p class="ds-leading-sample" style={`line-height: var(${t})`}>
              Most families can see that their child's relationship with screens has
              shifted — but they don't always know what to do about it, or where to start.
            </p>
          </div>
        ))}
      </div>

      <div class="ds-group">
        <h3 class="ds-group__title">Letter spacing</h3>
        {trackings.map(t => (
          <div class="ds-line-row" data-var={t}>
            <p class="ds-track-sample" style={`letter-spacing: var(${t})`}>Aligned digital wellness</p>
            <div class="ds-meta"><code class="ds-name">{t}</code><code class="ds-val" data-raw></code></div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── SPACING ── -->
    <section id="spacing" class="ds-section">
      <div class="ds-section__head"><h2>Spacing</h2></div>
      <div class="ds-group">
        {spacing.map(t => (
          <div class="ds-space-row" data-var={t} data-kind="size" data-pxprop="width">
            <code class="ds-name">{t}</code>
            <div class="ds-space-track"><div class="ds-space-bar" style={`width: var(${t})`}></div></div>
            <code class="ds-val"><span data-px></span></code>
            <code class="ds-ref" data-raw></code>
          </div>
        ))}
      </div>
    </section>

    <!-- ── RADIUS ── -->
    <section id="radius" class="ds-section">
      <div class="ds-section__head"><h2>Radius</h2></div>
      <div class="ds-tiles">
        {radii.map(t => (
          <figure class="ds-tile" data-var={t}>
            <div class="ds-radius-box" style={`border-radius: var(${t})`}></div>
            <figcaption><code class="ds-name">{t}</code><code class="ds-val" data-raw></code></figcaption>
          </figure>
        ))}
      </div>
    </section>

    <!-- ── SHADOW ── -->
    <section id="shadow" class="ds-section">
      <div class="ds-section__head"><h2>Shadow</h2></div>
      <div class="ds-tiles">
        {shadows.map(t => (
          <figure class="ds-tile" data-var={t}>
            <div class="ds-shadow-box" style={`box-shadow: var(${t})`}></div>
            <figcaption><code class="ds-name">{t}</code></figcaption>
          </figure>
        ))}
      </div>
    </section>

    <!-- ── PHOTO TREATMENT ── -->
    <section id="photo" class="ds-section">
      <div class="ds-section__head"><h2>Photo treatment</h2><p class="ds-note">Applied to every content photo &amp; feature card.</p></div>
      <div class="ds-photo">
        <div class="ds-photo__card" aria-hidden="true"></div>
        <dl class="ds-defs ds-photo__specs">
          <div class="ds-def"><dt>Corner radius</dt><dd><code class="ds-name">--radius-media</code> · 24px</dd></div>
          <div class="ds-def"><dt>Clip</dt><dd><code class="ds-name">overflow: hidden</code></dd></div>
          <div class="ds-def"><dt>Tint overlay</dt><dd><code class="ds-name">--spring-leaf</code> @ 22–25%</dd></div>
        </dl>
      </div>
    </section>

    <!-- ── ICONS ── -->
    <section id="icons" class="ds-section">
      <div class="ds-section__head"><h2>Icons</h2><p class="ds-note">Line icons — 24×24 viewBox, <code>currentColor</code>, round caps/joins, 1.6 stroke.</p></div>
      <div class="ds-icons">
        {icons.map(ic => (
          <figure class="ds-icon">
            <svg viewBox={ic.view} aria-hidden="true" set:html={ic.paths} />
            <figcaption><code class="ds-name">{ic.label}</code></figcaption>
          </figure>
        ))}
      </div>
    </section>

    <!-- ── Z-INDEX & MOTION ── -->
    <section id="system" class="ds-section">
      <div class="ds-section__head"><h2>Z-index &amp; motion</h2></div>
      <div class="ds-group">
        <h3 class="ds-group__title">Z-index</h3>
        <dl class="ds-defs">
          {zindex.map(t => (
            <div class="ds-def" data-var={t}><dt><code class="ds-name">{t}</code></dt><dd><code class="ds-val" data-raw></code></dd></div>
          ))}
        </dl>
      </div>
      <div class="ds-group">
        <h3 class="ds-group__title">Transitions</h3>
        <dl class="ds-defs">
          {transitions.map(t => (
            <div class="ds-def" data-var={t}><dt><code class="ds-name">{t}</code></dt><dd><code class="ds-val" data-raw></code></dd></div>
          ))}
        </dl>
      </div>
    </section>

    <!-- ── BUTTONS ── -->
    <section id="buttons" class="ds-section">
      <div class="ds-section__head"><h2>Buttons</h2><p class="ds-note">Global <code>.btn</code> classes — fully token-driven.</p></div>
      <div class="ds-buttons">
        <button class="btn btn--primary" type="button">Primary</button>
        <button class="btn btn--secondary" type="button">Secondary</button>
        <button class="btn btn--ghost" type="button">Ghost</button>
        <button class="btn btn--primary btn--lg" type="button">Primary · large</button>
        <button class="btn btn--secondary btn--lg" type="button">Secondary · large</button>
      </div>
    </section>

    <!-- ── TEXT ELEMENTS ── -->
    <section id="elements" class="ds-section">
      <div class="ds-section__head"><h2>Text elements</h2><p class="ds-note">Base HTML elements from <code>typography.css</code>.</p></div>
      <div class="ds-elements">
        <!-- Rendered as a styled <p> (not a real <h1>) so the page keeps exactly
             one <h1> — the page hero. Visual specimen is identical to an h1. -->
        <p class="ds-h1-specimen">Heading 1</p>
        <h2>Heading 2</h2>
        <h3>Heading 3</h3>
        <h4>Heading 4</h4>
        <h5>Heading 5</h5>
        <h6>Heading 6</h6>
        <p class="lead">This is a lead paragraph — it steps up from body size to introduce a section with a little more presence.</p>
        <p>This is a standard body paragraph. We give families a clear, structured path to rebuilding healthier digital habits, with <strong>emphasis</strong> shown inline and an <a href="#elements">inline link</a> for reference.</p>
        <blockquote>A blockquote — used for the testimonial quotes, set in italic serif.</blockquote>
        <p>Inline <code>code</code> sample.</p>
      </div>
    </section>

    <!-- ── PATTERNS ── -->
    <section id="patterns" class="ds-section">
      <div class="ds-section__head"><h2>Patterns</h2><p class="ds-note">Composed from tokens — these mirror the site's recurring building blocks.</p></div>

      <div class="ds-group">
        <h3 class="ds-group__title">Eyebrow tag</h3>
        <span class="eyebrow">How it works</span>
      </div>

      <div class="ds-group">
        <h3 class="ds-group__title">Card</h3>
        <article class="ds-card">
          <h3>Clinical Experience</h3>
          <p>A card surface using <code>--color-bg</code>, <code>--color-border</code>, <code>--radius-md</code> and <code>--space-8</code> padding.</p>
          <button class="btn btn--secondary" type="button">Learn more</button>
        </article>
      </div>

      <div class="ds-group">
        <h3 class="ds-group__title">Form fields</h3>
        <div class="ds-form-grid">
          <div class="field">
            <label class="field__label">Default</label>
            <input class="field__input" type="text" placeholder="Placeholder text" />
          </div>
          <div class="field">
            <label class="field__label">Active / filled</label>
            <input class="field__input" type="text" value="Jane Smith" />
          </div>
          <div class="field field--error">
            <label class="field__label">Error</label>
            <input class="field__input" type="text" value="bad@" />
            <span class="field__error-msg">Please enter a valid email address.</span>
          </div>
        </div>
      </div>

      <div class="ds-group">
        <h3 class="ds-group__title">Section header</h3>
        <div class="ds-pattern-header">
          <span class="eyebrow">Always evidence-based</span>
          <h2 class="ds-pattern-heading">Grounded in science</h2>
          <p class="ds-pattern-sub">Body / subheading copy — base size, full text color, sitting under a display heading. Same treatment as the hero sub and every page intro.</p>
        </div>
      </div>

      <div class="ds-group">
        <h3 class="ds-group__title">On-color usage</h3>
        <p class="ds-note">No pure white on color. Dark and colored surfaces take warm beige text; the accent is <strong>pollen</strong> on dark, <strong>forest / spring-leaf</strong> on light.</p>
        <div class="ds-oncolor">
          <div class="ds-oncolor__tile ds-oncolor__tile--dark">
            <span class="eyebrow ds-eyebrow--pollen">On dark</span>
            <p class="ds-oncolor__text">Almond-beige body · pollen accent &amp; link hover. Logo wordmark in heavy-beige.</p>
          </div>
          <div class="ds-oncolor__tile ds-oncolor__tile--green">
            <span class="eyebrow ds-eyebrow--frost">On green</span>
            <p class="ds-oncolor__text">Pale-beige text on the brand spring-leaf; forest reserved for feathered divider lines.</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .ds {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-12) var(--container-pad) var(--space-20);
  }

  /* ── Hero ── */
  .ds-hero { margin-bottom: var(--space-14); }
  .ds-kicker {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-subtle);
    margin-bottom: var(--space-3);
  }
  .ds-intro {
    max-width: 60ch;
    margin-top: var(--space-4);
    color: var(--color-text-muted);
  }
  .ds-toc {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-8);
  }
  .ds-toc__link {
    font-size: var(--text-sm);
    color: var(--color-text);
    padding: var(--space-1) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: var(--color-surface-raised);
    transition: background var(--transition-fast);
  }
  .ds-toc__link:hover { background: var(--color-surface-overlay); }

  /* ── Sections ── */
  /* Logo */
  .ds-logo-grid {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .ds-logo-swatch {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-8) var(--space-10);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    min-width: 220px;
  }
  .ds-logo-swatch--light { background: var(--white); }
  .ds-logo-swatch--dark  { background: var(--midnight); }
  .ds-logo-swatch--beige { background: var(--light-beige); }
  .ds-logo-img { height: 40px; width: auto; }
  .ds-logo-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }
  .ds-logo-swatch--dark .ds-logo-label { color: var(--secondary-grey); }

  .ds-section {
    padding-top: var(--space-12);
    margin-top: var(--space-12);
    border-top: 1px solid var(--color-border);
    scroll-margin-top: calc(var(--masthead-h) + var(--space-4));
  }
  .ds-section__head { margin-bottom: var(--space-8); }
  .ds-section__head h2 { margin: 0; }
  .ds-note { margin-top: var(--space-2); color: var(--color-text-muted); font-size: var(--text-sm); }

  .ds-group { margin-bottom: var(--space-10); }
  .ds-group__title {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-subtle);
    margin-bottom: var(--space-5);
  }

  /* Shared code/label styling */
  .ds-name, .ds-val, .ds-ref {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    display: block;
  }
  .ds-name { color: var(--color-text); }
  .ds-val { color: var(--color-text-muted); }
  .ds-ref { color: var(--color-text-subtle); }
  .ds-label { font-size: var(--text-sm); color: var(--color-text-muted); }

  /* ── Color swatches ── */
  .ds-swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-5);
  }
  .ds-swatches--palette {
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  }
  .ds-swatch { margin: 0; }
  .ds-swatch__chip {
    height: 72px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    margin-bottom: var(--space-2);
  }
  .ds-swatch figcaption { display: flex; flex-direction: column; gap: 2px; }

  /* ── Type ── */
  .ds-font-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }
  .ds-font-sample { font-size: var(--text-2xl); color: var(--color-text); margin: 0; }
  .ds-meta { display: flex; flex-direction: column; gap: 2px; text-align: right; align-items: flex-end; }

  .ds-type-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-6);
    align-items: baseline;
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }
  .ds-type-meta { display: flex; flex-direction: column; gap: 2px; }
