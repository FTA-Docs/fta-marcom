---
import '../styles/global.css';
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonical?: string;
  loadGSAP?: boolean;
  bodyClass?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'alignd helps families navigate care coordination across education, health, and development.',
  ogImage = '/soccer2.jpg',
  ogImageAlt = 'alignd — personalized, evidence-based plans for family digital wellness',
  canonical,
  loadGSAP = false,
  bodyClass = '',
  noindex = false,
} = Astro.props;

const siteUrl = 'https://alignd.care';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
// OG/Twitter images must be absolute URLs — resolve relative paths against the site origin.
const ogImageUrl = ogImage.startsWith('http') ? ogImage : siteUrl + ogImage;
const fullTitle = title === 'alignd' ? title : title + ' | alignd';
const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Family Technology Advisors, Inc.',
    alternateName: 'alignd',
    url: siteUrl,
    logo: siteUrl + '/alignd_logo_fullcolor.svg',
    contactPoint: [
      {
        '@type': 'ContactPoint',
        email: 'support@alignd.care',
        contactType: 'customer support',
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    url: siteUrl,
    name: 'alignd',
  },
]);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Lora:ital,wght@0,500;1,500&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content="alignd" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={jsonLd} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <Masthead />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  main {
    padding-top: var(--masthead-h);
    /* Clip decorative motifs that intentionally spill past the page edges so
       they never trigger a horizontal scrollbar on narrow viewports. `clip`
       (not `hidden`) leaves the vertical axis visible, so the homepage's
       position:sticky panels and GSAP pinning are unaffected. */
    overflow-x: clip;
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-4);
    background: var(--color-accent);
    color: var(--color-accent-text);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-weight: var(--weight-semibold);
    z-index: calc(var(--z-masthead) + 10);
    transition: top var(--transition-fast);
  }

  .skip-link:focus {
    top: var(--space-4);
  }
</style>
