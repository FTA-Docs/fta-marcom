---
import siteData from '../../content/site.json';
---

<footer class="footer" role="contentinfo">
  <div class="footer__inner container">
    <div class="footer__brand">
      <img src="/alignd_logo_reversed.svg" alt="alignd" class="footer__logo-img" width="160" height="24" />
      <p class="footer__tagline">{siteData.tagline}</p>
    </div>

    <nav class="footer__nav" aria-label="Footer navigation">
      <ul class="footer__nav-list" role="list">
        {siteData.footer.links.map((item) => (
          <li>
            <a href={item.href} class="footer__nav-link">{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="footer__contacts">
      <dl class="footer__contact-list">
        {siteData.footer.contacts.map((contact) => (
          <>
            <dt class="footer__contact-label">{contact.label}</dt>
            <dd class="footer__contact-value">
              <a href={`mailto:${contact.email}`} class="footer__contact-link">{contact.email}</a>
            </dd>
          </>
        ))}
      </dl>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container">
      <p class="footer__copyright">{siteData.footer.copyright}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--footer-bg);
    color: var(--footer-text);
    padding-top: var(--space-10);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 2fr 1fr 2fr;
    gap: var(--space-10);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--footer-border);
  }

  .footer__logo-img {
    display: block;
    height: 34px; /* same size as the masthead logo */
    width: 222px;
    margin-bottom: var(--space-3);
    flex-shrink: 0;
  }

  .footer__tagline {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--heavy-beige); /* match the logo wordmark */
    line-height: var(--leading-normal);
    max-width: 34ch;
    margin: 0;
  }

  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Footer wayfinding — matches the main nav (text-sm / medium), never larger */
  .footer__nav-link {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    color: var(--footer-text);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__nav-link:hover {
    color: var(--pollen);
  }

  .footer__contact-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3) var(--space-5);
    align-items: baseline;
    margin: 0;
  }

  /* Accent labels — pollen against the midnight ground */
  .footer__contact-label {
    font-size: var(--text-2xs);
    font-weight: var(--weight-semibold);
    color: var(--pollen);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  .footer__contact-value {
    margin: 0;
  }

  .footer__contact-link {
    font-size: var(--text-sm);
    font-weight: var(--weight-normal);
    color: var(--footer-text);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__contact-link:hover {
    color: var(--pollen);
  }

  .footer__bottom {
    padding-block: var(--space-5);
  }

  .footer__copyright {
    font-size: var(--text-xs);
    line-height: var(--leading-normal);
    color: var(--footer-text-muted);
    text-align: center;
    margin: 0;
  }

  @media (max-width: 767px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer__brand {
      grid-column: span 2;
    }
  }
</style>
