<script>
  // ── Shared setup ──────────────────────────────────────────
  const mastheadH = (document.querySelector('.masthead') as HTMLElement)?.offsetHeight ?? 64;
  const panelH = () => window.innerHeight - mastheadH;

  // ── Modal focus management (shared) ───────────────────────────
  // Keyboard users must not be able to Tab out behind an open dialog, and focus
  // must return to whatever opened it on close (WCAG 2.4.3 / 2.1.2).
  const getFocusable = (container: HTMLElement): HTMLElement[] =>
    Array.from(
      container.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
      )
    ).filter(el => el.offsetParent !== null);

  function trapTab(e: KeyboardEvent, modal: HTMLElement) {
    if (e.key !== 'Tab') return;
    const focusable = getFocusable(modal);
    if (!focusable.length) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  }

  // ── Video modal ───────────────────────────────────────────────
  // DORMANT: the hero "Watch Video" trigger was removed for now, so #watch-video-btn
  // is absent and this modal never opens (the ?. below no-ops). Kept wired so
  // restoring the button re-enables it. Remove this block + markup + CSS if the
  // video is dropped for good.
  const videoModal = document.getElementById('video-modal');
  // Move to body to escape any stacking context
  if (videoModal) document.body.appendChild(videoModal);

  const videoBtn = document.getElementById('watch-video-btn');
  const closeVideoBtn = videoModal?.querySelector<HTMLElement>('.video-modal__close');
  const videoBackdrop = videoModal?.querySelector('.video-modal__backdrop');
  let videoReturnFocus: HTMLElement | null = null;

  function openVideoModal() {
    videoReturnFocus = document.activeElement as HTMLElement;
    videoModal?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    closeVideoBtn?.focus();
  }
  function closeVideoModal() {
    videoModal?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    videoReturnFocus?.focus();
  }

  videoBtn?.addEventListener('click', openVideoModal);
  closeVideoBtn?.addEventListener('click', closeVideoModal);
  videoBackdrop?.addEventListener('click', closeVideoModal);
  videoModal?.addEventListener('keydown', e => trapTab(e, videoModal));
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && videoModal?.getAttribute('aria-hidden') === 'false') closeVideoModal();
  });

  // ── 8-week plan timeline modal ────────────────────────────────
  const planModal = document.getElementById('plan-modal');
  // Move to body so it escapes the sticky/pinned panel stacking contexts
  if (planModal) document.body.appendChild(planModal);

  const planOpenBtns = document.querySelectorAll('[data-open-plan]');
  const planClose = planModal?.querySelector<HTMLElement>('.plan-modal__close');
  const planBackdrop = planModal?.querySelector('.plan-modal__backdrop');
  const planTrackWrap = planModal?.querySelector('.plan-track-wrap') as HTMLElement | null;
  let planReturnFocus: HTMLElement | null = null;

  function openPlanModal() {
    planReturnFocus = document.activeElement as HTMLElement;
    planModal?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    if (planTrackWrap) planTrackWrap.scrollLeft = 0; // always start at week 1
    planClose?.focus();
  }
  function closePlanModal() {
    planModal?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    planReturnFocus?.focus();
  }

  planOpenBtns.forEach(btn => btn.addEventListener('click', openPlanModal));
  planClose?.addEventListener('click', closePlanModal);
  planBackdrop?.addEventListener('click', closePlanModal);
  planModal?.addEventListener('keydown', e => trapTab(e, planModal));
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && planModal?.getAttribute('aria-hidden') === 'false') closePlanModal();
  });

  // ── Anchor nav fix for sticky panels ─────────────────────────
  // sticky elements' offsetTop reflects their current VISUAL position
  // (mastheadH + scrollY), not their natural flow position. We temporarily
  // un-stick to read the true layout offset, then restore.
  const getFlowTop = (el: HTMLElement): number => {
    const prev = el.style.position;
    el.style.position = 'static';
    const top = el.offsetTop;
    el.style.position = prev;
    return top;
  };

  document.querySelectorAll<HTMLAnchorElement>('a[href*="#"]').forEach(link => {
    link.addEventListener('click', e => {
      const hash = link.getAttribute('href')?.split('#')[1];
      if (!hash) return;
      const target = document.getElementById(hash);
      if (!target) return;
      e.preventDefault();
      window.scrollTo({ top: Math.max(0, getFlowTop(target) - mastheadH), behavior: 'smooth' });
      // Move keyboard focus to the target so AT/keyboard users land there too
      // (smooth-scroll alone leaves focus on the link). tabindex=-1 makes the
      // section programmatically focusable without adding it to the tab order.
      if (!target.hasAttribute('tabindex')) target.setAttribute('tabindex', '-1');
      target.focus({ preventScroll: true });
    });
  });

  // ── Social proof carousel — auto-cycles every 5s ─────────
  const spQuotes = Array.from(document.querySelectorAll<HTMLElement>('.sp-quote'));
  const spDots   = Array.from(document.querySelectorAll<HTMLElement>('.sp-dot'));

  if (spQuotes.length > 1) {
    const quoteCount = spQuotes.length;
    // Respect reduced-motion: keep dot navigation, but don't auto-advance.
    const spReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    // Place quotes in a horizontal train without triggering CSS transition
    spQuotes.forEach((q, i) => {
      q.style.transition = 'none';
      q.style.transform  = `translateX(${i * 100}%)`;
    });
    // Re-enable transition after initial paint
    requestAnimationFrame(() => requestAnimationFrame(() => {
      spQuotes.forEach(q => q.style.removeProperty('transition'));
    }));

    function showQuote(idx: number) {
      current = Math.max(0, Math.min(idx, quoteCount - 1));
      spQuotes.forEach((q, i) => {
        q.style.transform = `translateX(${(i - current) * 100}%)`;
        q.setAttribute('aria-hidden', String(i !== current));
      });
      spDots.forEach((dot, i) => {
        const active = i === current;
        dot.classList.toggle('is-active', active);
        dot.setAttribute('aria-selected', String(active));
      });
    }

    function advance() {
      showQuote((current + 1) % quoteCount);
    }

    function startTimer() {
      if (spReduced) return; // no auto-advance under reduced-motion
      timer = setInterval(advance, 8000);
    }

    function resetTimer() {
      clearInterval(timer);
      startTimer();
    }

    // Dot clicks: jump to quote and reset the auto-cycle
    spDots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        showQuote(i);
        resetTimer();
      });
    });

    // Pause on hover/focus, resume on leave
    const spSection = document.getElementById('social-proof');
    spSection?.addEventListener('mouseenter', () => clearInterval(timer));
    spSection?.addEventListener('mouseleave', startTimer);
    spSection?.addEventListener('focusin',    () => clearInterval(timer));
    spSection?.addEventListener('focusout',   startTimer);

    startTimer();
  }

  // ── Problem panel "Sound Familiar?": scroll-driven, not auto-playing ──
  // The panel is pinned (CSS sticky); as the reader scrolls the problem scroll
  // zone, each worry slides in one at a time. Driven by a plain scroll listener
  // (not GSAP) so the range is measured live from the real element positions:
  // the cycle runs from the moment the panel pins until just before the
  // solution panel slides up over it, so all worries are seen in sequence.
  // Runs at every width when motion is OK — phones get the same scroll-driven
  // carousel as tablet/desktop; only reduced-motion falls back to the static list.
  {
    const sfProblemZone = document.getElementById('problem-scroll-zone');
    const sfQuotes = Array.from(document.querySelectorAll<HTMLElement>('.sf-quote'));
    const sfDots   = Array.from(document.querySelectorAll<HTMLElement>('.sf-dot'));
    const sfMotion = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (sfProblemZone && sfQuotes.length > 1 && sfMotion) {
      const sfCount = sfQuotes.length;
      // Hold the last worry this fraction of a screen before the solution covers it
      const SF_TAIL = 0.6;
      // Extra hold on the FIRST worry (in screens). Unlike the Solution panel,
      // this cycle starts the instant the panel pins — the first quote gets no
      // entrance linger — so it needs its own lead-in or it flies past on arrival.
      // Must match --sf-lead in the CSS (the zone height reserves this scroll).
      const SF_LEAD = 0.5;
      let sfCurrent = -1;

      const setWorry = (idx: number) => {
        const i = Math.max(0, Math.min(sfCount - 1, idx));
        if (i === sfCurrent) return;
        sfCurrent = i;
        sfQuotes.forEach((q, k) => {
          q.classList.toggle('is-active', k === i);
          q.classList.toggle('is-past', k < i);
        });
        sfDots.forEach((dot, k) => {
          const active = k === i;
          dot.classList.toggle('is-active', active);
          dot.setAttribute('aria-selected', String(active));
        });
      };

      // Scroll span over which the worries cycle — measured live so it tracks
      // the real layout (zone isn't sticky, so its position is reliable).
      const sfRange = () => {
        const winH = window.innerHeight;
        const zoneTop = sfProblemZone.getBoundingClientRect().top + window.scrollY;
        const pinStart = zoneTop - winH;                          // panel finishes pinning
        const solTop = zoneTop + sfProblemZone.offsetHeight;      // solution panel flow-top
        const coverCentre = solTop - (mastheadH + winH) / 2;      // solution reaches the centre
        const cycleEnd = coverCentre - SF_TAIL * (winH - mastheadH);
        return { pinStart, span: Math.max(1, cycleEnd - pinStart) };
      };

      // Worry 0 owns a lead-in band of (SF_LEAD + base); worries 1…n each own
      // one `base`. The zone is taller by SF_LEAD, so `base` stays the same
      // ~0.67 screen the later worries had — only the first quote lingers longer.
      const updateWorry = () => {
        const { pinStart, span } = sfRange();
        const s = window.scrollY - pinStart;                        // 0…span
        const lead = SF_LEAD * (window.innerHeight - mastheadH);    // first-quote lead
        const base = Math.max(1, (span - lead) / sfCount);          // per-quote share
        setWorry(s < lead + base ? 0 : 1 + Math.floor((s - lead - base) / base));
      };

      window.addEventListener('scroll', updateWorry, { passive: true });
      window.addEventListener('resize', updateWorry);
      updateWorry();

      // Dots jump to the middle of their worry's band (band 0 is wider by the lead)
      sfDots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          const { pinStart, span } = sfRange();
          const lead = SF_LEAD * (window.innerHeight - mastheadH);
          const base = Math.max(1, (span - lead) / sfCount);
          const centre = i === 0 ? (lead + base) / 2 : lead + base * (i + 0.5);
          window.scrollTo({ top: Math.max(0, pinStart + centre), behavior: 'smooth' });
        });
      });
    }
  }

  // ── Solution on phone: static stacked list, every step readable ──
  // The GSAP carousel (gated ≥768) is what normally toggles aria-hidden on the
  // inactive steps; at ≤767 all four are shown, so expose them all to AT.
  if (window.matchMedia('(max-width: 767px)').matches) {
    document.querySelectorAll('.sol-text[aria-hidden="true"]')
      .forEach((t) => t.removeAttribute('aria-hidden'));
  }

  // ── GSAP: hero parallax + reveal fade-ins ─────────────────
  (window as any).gsapActive = true;

  (async () => {
    try {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        (window as any).gsapActive = false;
        const io = new IntersectionObserver(
          (entries) => entries.forEach((e) => {
            if (e.isIntersecting) {
              (e.target as HTMLElement).classList.add('is-revealed');
              io.unobserve(e.target);
            }
          }),
          { threshold: 0.12 }
        );
        document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
        return;
      }

      const { gsap } = await import('gsap');
      const { ScrollTrigger } = await import('gsap/ScrollTrigger');
      gsap.registerPlugin(ScrollTrigger);

      // ── Parallax depth: hero content recedes as problem slides over it ──
      // Desktop only — on phones the panels are static (no scroll-jack), so the
      // hero stays put rather than fading/parallaxing under the next panel.
      if (window.matchMedia('(min-width: 768px)').matches) {
        gsap.to('#hero > .container > *', {
          y: '-4%',
          opacity: 0.5,
          ease: 'none',
          scrollTrigger: {
            trigger: '#problem',
            start: `top top+=${mastheadH}`,
            end: `+=${window.innerHeight * 0.6}`,
            scrub: 1,
          },
        });
      }

      // ── Solution: scroll-driven inner section cycling ────
      const solZone     = document.getElementById('solution-scroll-zone');
      const solTexts    = Array.from(document.querySelectorAll<HTMLElement>('.sol-text'));
      const solDots     = Array.from(document.querySelectorAll<HTMLElement>('.sol-dot'));
      const filmstrip   = document.getElementById('sol-filmstrip') as HTMLElement | null;
      const filmstripWrap = filmstrip?.parentElement as HTMLElement | null;
      const phoneDivs   = Array.from(document.querySelectorAll<HTMLElement>('.sol-phone-device'));
      const phoneItems  = Array.from(document.querySelectorAll<HTMLElement>('.sol-phone-item'));

      if (solZone && solTexts.length > 1 && filmstrip && filmstripWrap
          && window.matchMedia('(min-width: 768px)').matches) {
        const solCount = solTexts.length;

        // On mobile the active phone sits at full scale (the CSS sizes it to
        // fill the viewport height) so it doesn't overflow when scaled up;
        // on desktop the active phone grows past its neighbours.
        const isMobile = window.matchMedia('(max-width: 767px)').matches;
        const PH_ACTIVE   = isMobile ? 1    : 1.55;
        const PH_INACTIVE = isMobile ? 0.72 : 0.82;

        // Compute step from rendered positions (handles any gap/size)
        const STEP = phoneItems.length > 1
          ? phoneItems[1].getBoundingClientRect().left - phoneItems[0].getBoundingClientRect().left
          : 180;

        // Center phone 0 in the wrap
        const wrapW   = filmstripWrap.offsetWidth;
        const phoneW  = phoneItems[0]?.offsetWidth ?? 160;
        const initX   = wrapW / 2 - phoneW / 2;

        // Initialize positions
        gsap.set(filmstrip, { x: initX });
        // Each section's full text block (eyebrow + heading + body) slides:
        // the outgoing one exits left as the incoming one enters from the right.
        gsap.set(solTexts.slice(1), { xPercent: 100 });
        phoneDivs.forEach((p, i) => gsap.set(p,
          i === 0 ? { scale: PH_ACTIVE, opacity: 1 } : { scale: PH_INACTIVE, opacity: 0.45 }
        ));

        // Pacing — values are in units of one screen-height of scroll (the
        // ScrollTrigger end below is `total × panelH`, so 1 timeline unit = 1
        // panelH). Every step slides identically (TRANS) and each later step
        // holds the same (DWELL); a full step ≈ 0.68 screen, matching the pace
        // of the "Sound Familiar?" worries above.
        //   LEAD is a deliberately short hold on step 0: the intro already gets
        //   ~a full screen of on-screen time as the panel slides up and pins, so
        //   a full DWELL on top of that made the first step feel stuck.
        // Keep these in sync with --sol-lead / --sol-step / --sol-tail in the
        // CSS — the scroll-zone height is derived from the same numbers.
        const TRANS = 0.23;   // screens of scroll spent sliding between steps
        const DWELL = 0.67;   // screens each later step holds, still — matches the
                              //   "Sound Familiar?" worries (0.67) so the two
                              //   carousels feel identical; the last step's hold +
                              //   the 0.6 tail below = 1.27, mirroring the last worry.
        const LEAD  = 0.24;   // screens step 0 holds before the first slide — kept
                              //   short on purpose: the panel's slide-up entrance
                              //   already gives step 0 ~1 screen of linger that the
                              //   worries' first quote never gets (its cycle starts
                              //   right at the pin), so a full DWELL here would make
                              //   the intro feel stuck.
        const total = LEAD + (solCount - 1) * (DWELL + TRANS);
        const solTl = gsap.timeline({ paused: true });
        // Reserve the full duration so the trailing dwell exists — nothing
        // animates during it, so GSAP would otherwise trim the timeline short.
        solTl.to({}, { duration: total }, 0);

        for (let i = 0; i < solCount - 1; i++) {
          const t = LEAD + i * (DWELL + TRANS);   // transition i fires after step i's hold

          // Slide the full text block (eyebrow included) out as the next slides in
          solTl.to(solTexts[i],     { xPercent: -100, ease: 'power2.inOut', duration: TRANS }, t);
          solTl.to(solTexts[i + 1], { xPercent:    0, ease: 'power2.inOut', duration: TRANS }, t);

          // Filmstrip slides left
          solTl.to(filmstrip, { x: initX - (i + 1) * STEP, ease: 'power2.inOut', duration: TRANS }, t);

          // Phone scales: active grows, outgoing shrinks
          solTl.to(phoneDivs[i],     { scale: PH_INACTIVE, opacity: 0.45, ease: 'power1.in',    duration: TRANS * 0.9 }, t);
          solTl.to(phoneDivs[i + 1], { scale: PH_ACTIVE,   opacity: 1,    ease: 'back.out(1.2)', duration: TRANS * 0.9 }, t);
        }

        ScrollTrigger.create({
          trigger: solZone,
          start: `top top+=${mastheadH}`,
          end: () => `+=${total * panelH()}`,
          scrub: 1,
          invalidateOnRefresh: true,
          animation: solTl,
          onUpdate(self) {
            // Active section flips at the midpoint of each transition, matching
            // the even dwell/transition layout above (not uniform progress).
            const time = self.progress * total;
            let idx = 0;
            for (let i = 0; i < solCount - 1; i++) {
              if (time >= LEAD + i * (DWELL + TRANS) + TRANS / 2) idx = i + 1;
            }
            solDots.forEach((dot, i) => {
              const active = i === idx;
              dot.classList.toggle('is-active', active);
              dot.setAttribute('aria-selected', String(active));
            });
            solTexts.forEach((s, i) => {
              s.setAttribute('aria-hidden', String(i !== idx));
            });
          },
        });

        // Scroll a dot to the middle of its step's hold (steps are no longer
        // evenly 1-screen apart — step 0's LEAD hold is shorter).
        const dwellCenter = (i: number) => i === 0
          ? LEAD / 2
          : LEAD + (i - 1) * (DWELL + TRANS) + TRANS + DWELL / 2;
        solDots.forEach((dot, i) => {
          dot.addEventListener('click', () => {
            const zoneTop = getFlowTop(solZone);
            window.scrollTo({
              top: Math.max(0, zoneTop - mastheadH + dwellCenter(i) * panelH()),
              behavior: 'smooth',
            });
          });
        });
      }

      // ── Science blocks: each of the 4 sub-blocks travels into its lockup ──
      // The two halves of each row drift in from their own direction and settle
      // as the row nears the viewport centre. Scrubbed (not a one-shot) so the
      // motion is always visible scrolling into/through the section. Relative
      // offsets ('+=' / '-=') preserve the resting CSS transforms on the rev row.
      //   row 1 (photo + text):  photo bottom→top,  text right→left
      //   row 2 (text + photo):  text top→bottom,   photo left→right
      // Gated to ≥768: on phone the rows are a centred vertical stack and the
      // relative '+=' offsets would leave residual transforms that overflow.
      const sciDesktop = window.matchMedia('(min-width: 768px)').matches;
      if (sciDesktop) gsap.utils.toArray<HTMLElement>('#science .science-item').forEach((el, i) => {
        const media = el.querySelector<HTMLElement>('.science-item__media');
        const text = el.querySelector<HTMLElement>('.science-item__text');
        const moves = i % 2 === 1
          ? { media: { x: '-=40' }, text: { y: '-=40' } }    // row 2: photo left→right, text top→bottom
          : { media: { y: '+=110' }, text: { x: '+=40' } };  // row 1: photo bottom→top (bigger), text right→left

        [
          [media, moves.media],
          [text, moves.text],
        ].forEach(([node, offset]) => {
          if (!node) return;
          gsap.from(node as HTMLElement, {
            ...(offset as Record<string, string>),
            ease: 'none',
            scrollTrigger: {
              trigger: el,
              start: 'top bottom',
              end: 'top center+=60',
              scrub: true,
              invalidateOnRefresh: true,
            },
          });
        });
      });

      // ── Reveal fade-ins ──────────────────────────────────────
      document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
        ScrollTrigger.create({
          trigger: el,
          start: 'top bottom-=80',
          onEnter: () => el.classList.add('is-revealed'),
          once: true,
        });
      });

    } catch (err) {
      console.warn('[alignd] GSAP initialization failed — skipping animations.', err);
    }
  })();
</script>
