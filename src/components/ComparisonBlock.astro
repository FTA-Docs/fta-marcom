---
interface ComparisonRow {
  label: string;
  alignd: string;
  traditional: string;
  parentalTech: string;
}

interface Props {
  comparison: {
    eyebrow: string;
    heading: string;
    subheading?: string;
    cols: string[];
    rows: ComparisonRow[];
  };
}

const { comparison } = Astro.props;
const { cols, rows } = comparison;
---

<div class="comparison-block">
  <div class="cmp-table-wrap">
    <table class="cmp-table">
      <thead>
        <tr>
          <th scope="col"></th>
          <th scope="col" class="cmp-table__alignd">{cols[0]}</th>
          <th scope="col">{cols[1]}</th>
          <th scope="col">{cols[2]}</th>
        </tr>
      </thead>
      <tbody>
        {rows.map(row => (
          <tr>
            <th scope="row">{row.label}</th>
            <td class="cmp-table__alignd">{row.alignd}</td>
            <td>{row.traditional}</td>
            <td>{row.parentalTech}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .comparison-block {
    padding-bottom: var(--space-10);
  }

  .cmp-table-wrap {
    overflow-x: auto;
  }

  .cmp-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: var(--text-sm);
    min-width: 720px;
  }

  .cmp-table {
    table-layout: fixed;
  }

  .cmp-table th,
  .cmp-table td {
    padding: var(--space-4) var(--space-5);
    text-align: left;
    border-bottom: none;
    vertical-align: top;
    line-height: var(--leading-normal);
  }

  /* Column widths: label / alignd / traditional / parental-tech */
  .cmp-table thead th:first-child,
  .cmp-table tbody th { width: 20%; }
  .cmp-table thead th.cmp-table__alignd { width: 30%; }
  .cmp-table thead th:nth-child(3),
  .cmp-table thead th:nth-child(4) { width: 25%; }

  .cmp-table tbody tr:nth-child(odd) td,
  .cmp-table tbody tr:nth-child(odd) th {
    background: var(--light-beige);
  }

  /* Subtle darker green on filled rows so the alignd column stripes in sync */
  .cmp-table tbody tr:nth-child(odd) td.cmp-table__alignd {
    background: color-mix(in srgb, var(--spring-leaf) 95%, black);
  }

  .cmp-table thead th {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-normal);
    text-transform: none;
    color: var(--color-heading);
  }

  .cmp-table tbody th {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-normal);
    color: var(--color-text);
    vertical-align: top;
  }

  .cmp-table td {
    color: var(--color-text);
  }

  /* Highlighted alignd column */
  .cmp-table__alignd {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    background: var(--spring-leaf);
  }

  .cmp-table td.cmp-table__alignd,
  .cmp-table th.cmp-table__alignd,
  .cmp-table thead th.cmp-table__alignd {
    color: var(--white);
  }

  .cmp-table thead th.cmp-table__alignd {
    border-radius: var(--radius-md) var(--radius-md) 0 0;
  }

  .cmp-table tbody tr:last-child td.cmp-table__alignd {
    border-radius: 0 0 var(--radius-md) var(--radius-md);
  }

  /* Mobile: fit the whole comparison within the viewport — no horizontal
     scroll. Shrink type + padding so all four columns sit side by side. */
  @media (max-width: 767px) {
    .cmp-table-wrap { overflow-x: visible; }

    .cmp-table {
      min-width: 0;
      font-size: var(--text-xs);
      table-layout: fixed;
    }

    .cmp-table th,
    .cmp-table td {
      padding: var(--space-3) var(--space-2);
      line-height: var(--leading-snug);
      overflow-wrap: break-word;
    }

    .cmp-table thead th {
      letter-spacing: var(--tracking-normal);
    }

    /* Row-label column gets a bit more room; split the rest across options */
    .cmp-table thead th:first-child { width: 26%; }
    .cmp-table thead th:not(:first-child) { width: 24.6%; }

    /* Hyphenate cleanly if a long label/word must break */
    .cmp-table tbody th { hyphens: auto; }
  }
</style>
