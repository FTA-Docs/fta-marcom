---
interface Plan {
  name: string;
  price: string;
  period: string;
  note?: string;
  description: string;
  cta: { label: string; href: string };
  primary?: boolean;
}

interface ComparisonRow {
  label: string;
  traditional: string;
  alignd: string;
}

interface Props {
  pricing: {
    plans: Plan[];
    valueHighlights: string[];
    comparison: {
      eyebrow: string;
      heading: string;
      cols: string[];
      rows: ComparisonRow[];
    };
  };
}

const { pricing } = Astro.props;
const { plans, valueHighlights, comparison } = pricing;
---

<div class="pricing-block">

  <div class="pricing-layout">

    <!-- Left: stacked plan cards -->
    <div class="plan-stack" id="plan-stack">
      {plans.map((plan, i) => (
        <article
          class="plan-card"
          data-position={i === 0 ? 'front' : 'back'}
          aria-label={plan.name}
        >
          <div class="plan-card__header">
            <h3 class="plan-card__name">{plan.name}</h3>
            <div class="plan-card__price-row">
              <span class="plan-card__price">{plan.price}</span>
              <span class="plan-card__period">{plan.period}</span>
              {plan.note && <span class="plan-card__note">{plan.note}</span>}
            </div>
          </div>
          <p class="plan-card__description">{plan.description}</p>
          <a
            href={plan.cta.href}
            class={`btn ${i === 0 ? 'btn--primary' : 'btn--secondary'} plan-card__cta`}
          >{plan.cta.label}</a>
        </article>
      ))}
    </div>

    <!-- Right: value highlights + compare link -->
    <div class="pricing-highlights">
      <ul class="value-highlights" role="list">
        {valueHighlights.map(h => (
          <li class="value-highlight">
            <span class="value-highlight__check" aria-hidden="true">✓</span>
            <span>{h}</span>
          </li>
        ))}
      </ul>
      <button class="compare-btn" id="compare-btn">Compare to traditional therapy</button>
    </div>

  </div>

  <!-- Comparison modal -->
  <div class="cmp-modal" id="cmp-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-label={comparison.heading}>
    <div class="cmp-modal__backdrop"></div>
    <div class="cmp-modal__panel">
      <button class="cmp-modal__close" aria-label="Close comparison">&times;</button>
      <h3 class="cmp-modal__heading">{comparison.heading}</h3>
      <div class="cmp-modal__table-wrap">
        <table class="cmp-table">
          <thead>
            <tr>
              <th scope="col"></th>
              <th scope="col">{comparison.cols[0]}</th>
              <th scope="col" class="cmp-table__alignd">{comparison.cols[1]}</th>
            </tr>
          </thead>
          <tbody>
            {comparison.rows.map(row => (
              <tr>
                <th scope="row">{row.label}</th>
                <td>{row.traditional}</td>
                <td class="cmp-table__alignd">{row.alignd}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>

<style>
  .pricing-block {
    padding-bottom: var(--space-10);
  }

  /* ── Two-column layout ── */
  .pricing-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  /* ── Card stack ── */
  .plan-stack {
    position: relative;
    height: clamp(300px, 42vh, 380px);
    margin-bottom: 40px; /* space for back card bottom overflow */
  }

  .plan-card {
    position: absolute;
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    transition:
      top 0.45s cubic-bezier(0.34, 1.3, 0.64, 1),
      left 0.45s cubic-bezier(0.34, 1.3, 0.64, 1),
      right 0.45s cubic-bezier(0.34, 1.3, 0.64, 1),
      bottom 0.45s cubic-bezier(0.34, 1.3, 0.64, 1),
      transform 0.45s cubic-bezier(0.34, 1.3, 0.64, 1),
      opacity 0.3s ease;
  }

  /* Front card: narrower on the right so back card is visible */
  .plan-card[data-position="front"] {
    top: 0;
    left: 0;
    bottom: 0;
    right: 80px;
    border: 2px solid var(--color-text);
    z-index: 2;
    opacity: 1;
    transform: none;
    cursor: default;
  }

  /* Back card: offset down-right, extends to full stack width */
  .plan-card[data-position="back"] {
    top: 36px;
    left: 60px;
    bottom: -36px;
    right: 0;
    border: 1px solid var(--color-border);
    z-index: 1;
    opacity: 0.8;
    transform: rotate(1.5deg);
    cursor: pointer;
  }

  .plan-card[data-position="back"]:hover {
    opacity: 0.95;
  }

  .plan-card__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .plan-card__name {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin: 0;
  }

  .plan-card__price-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .plan-card__price {
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
  }

  .plan-card__period {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .plan-card__note {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .plan-card__description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
    flex: 1;
  }

  .plan-card__cta {
    align-self: flex-start;
  }

  /* ── Value highlights ── */
  .pricing-highlights {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-top: var(--space-2);
  }

  .value-highlights {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .value-highlight {
    display: flex;
    gap: var(--space-3);
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: var(--leading-normal);
    align-items: flex-start;
  }

  .value-highlight__check {
    font-weight: var(--weight-bold);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .compare-btn {
    background: none;
    border: none;
    padding: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    text-align: left;
  }

  .compare-btn:hover {
    color: var(--color-text);
  }

  /* ── Comparison modal ── */
  .cmp-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: var(--z-modal, 200);
    align-items: center;
    justify-content: center;
  }

  .cmp-modal[aria-hidden="false"] {
    display: flex;
  }

  .cmp-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .cmp-modal__panel {
    position: relative;
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    max-width: 860px;
    width: calc(100% - var(--space-8));
    max-height: 85vh;
    overflow-y: auto;
  }

  .cmp-modal__close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    background: none;
    border: none;
    font-size: var(--text-xl);
    line-height: 1;
    cursor: pointer;
    color: var(--color-text-muted);
  }

  .cmp-modal__close:hover {
    color: var(--color-text);
  }

  .cmp-modal__heading {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    margin: 0 0 var(--space-6);
    padding-right: var(--space-8);
  }

  .cmp-modal__table-wrap {
    overflow-x: auto;
  }

  .cmp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .cmp-table th,
  .cmp-table td {
    padding: var(--space-4) var(--space-5);
    text-align: left;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
    line-height: var(--leading-normal);
  }

  .cmp-table thead th {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
  }

  .cmp-table tbody th {
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    width: 16%;
  }

  .cmp-table td {
    color: var(--color-text-muted);
  }

  .cmp-table__alignd {
    color: var(--color-text) !important;
    font-weight: var(--weight-medium);
  }

  /* ── Responsive ── */
  @media (max-width: 767px) {
    .pricing-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    /* On mobile, break out of the absolute-stacked card effect and
       show both plan cards as normal stacked blocks */
    .plan-stack {
      height: auto;
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      margin-bottom: 0;
    }

    .plan-card {
      position: static !important;
      transform: none !important;
      opacity: 1 !important;
      width: 100%;
    }

    .value-highlights {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // ── Card swap ────────────────────────────────────────────
  const stack = document.getElementById('plan-stack');
  const cards = stack ? Array.from(stack.querySelectorAll<HTMLElement>('.plan-card')) : [];

  if (stack && cards.length === 2) {
    function swapCards() {
      cards.forEach(card => {
        card.dataset.position = card.dataset.position === 'front' ? 'back' : 'front';
      });
    }

    stack.addEventListener('click', (e) => {
      const card = (e.target as Element).closest<HTMLElement>('.plan-card');
      if (!card || card.dataset.position === 'front') return;
      // Let CTA links through — only swap on non-link clicks
      if ((e.target as Element).closest('a')) return;
      swapCards();
    });
  }

  // ── Comparison modal ──────────────────────────────────────
  const modal  = document.getElementById('cmp-modal');
  const openBtn = document.getElementById('compare-btn');

  // Move modal to <body> so it escapes the #pricing sticky stacking context
  // (z-index: 5), allowing position:fixed + z-index:200 to cover the full viewport.
  if (modal) document.body.appendChild(modal);

  function openModal()  {
    modal?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    modal?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openModal);
  modal?.querySelector('.cmp-modal__backdrop')?.addEventListener('click', closeModal);
  modal?.querySelector('.cmp-modal__close')?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.getAttribute('aria-hidden') === 'false') closeModal();
  });
</script>
