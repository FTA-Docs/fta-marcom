---
interface Props {
  id: string;
  label: string;
  class?: string;
}

const { id, label, class: className } = Astro.props;
const combinedClass = ['h-scroller', className].filter(Boolean).join(' ');
---

<div id={id} class={combinedClass} aria-label={label} role="region">
  <div class="h-scroller__track" role="list">
    <slot />
  </div>
</div>

<style>
  .h-scroller {
    flex: 1;          /* fill remaining height in the panel flex column */
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .h-scroller__track {
    flex: 1;
    display: flex;
    align-items: center;
    gap: var(--space-6);
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    padding-inline: var(--container-pad);
    padding-block: var(--space-4);
  }

  .h-scroller__track::-webkit-scrollbar { height: 4px; }
  .h-scroller__track::-webkit-scrollbar-track { background: var(--color-border); }
  .h-scroller__track::-webkit-scrollbar-thumb {
    background: var(--color-text-muted);
    border-radius: var(--radius-full);
  }

  @media (prefers-reduced-motion: reduce) {
    .h-scroller__track {
      flex-wrap: wrap;
      overflow-x: visible;
    }
  }
</style>
