---
import BaseLayout from '../layouts/BaseLayout.astro';
import Panel from '../components/Panel.astro';
import PricingBlock from '../components/PricingBlock.astro';
import ComparisonBlock from '../components/ComparisonBlock.astro';
import Reveal from '../components/Reveal.astro';
import homeData from '../../content/home.json';
import planTimeline from '../../content/plan-timeline.json';

// Wavy dotted connector for the 8-week plan timeline (coded, not an image).
// WEEK_W must match the .plan-week width in CSS so icon centres line up.
const WEEK_W = 280;
const WAVE_BASE = 44;  // y of the icon centres within the wave SVG (= track pad-top 16 + icon radius 28)
const WAVE_AMP = 22;
const planWeeks = planTimeline.weeks;
const waveW = WEEK_W * planWeeks.length;
const waveH = WAVE_BASE + WAVE_AMP + 4;
let wavePath = `M ${WEEK_W / 2} ${WAVE_BASE}`;
for (let i = 0; i < planWeeks.length - 1; i++) {
  const x0 = WEEK_W / 2 + i * WEEK_W;
  const x1 = x0 + WEEK_W;
  const peakY = i % 2 === 0 ? WAVE_BASE - WAVE_AMP : WAVE_BASE + WAVE_AMP;
  wavePath += ` C ${x0 + WEEK_W * 0.4} ${peakY}, ${x0 + WEEK_W * 0.6} ${peakY}, ${x1} ${WAVE_BASE}`;
}
---

<BaseLayout title="alignd" loadGSAP={true} bodyClass="page-home">

  <!-- HERO — sticky z-index:1, CSS handles stacking -->
  <Panel id="hero" class="panel-page" background="default">
    <div class="hero">
      <Reveal><h1>{homeData.hero.headline}</h1></Reveal>
      <Reveal delay={150}><p class="lead hero__sub">{homeData.hero.subheadline}</p></Reveal>
      <Reveal delay={300}>
        <div class="hero__actions">
          <button id="watch-video-btn" class="btn btn--primary btn--lg" type="button">
            {homeData.hero.cta.label}
          </button>
          <a href={homeData.hero.cta2.href} class="btn btn--secondary btn--lg">
            {homeData.hero.cta2.label}
          </a>
        </div>
      </Reveal>
    </div>
  </Panel>

  <!-- PROBLEM — scroll zone drives a horizontal quote carousel while pinned -->
  <div
    id="problem-scroll-zone"
    class="problem-scroll-zone"
    style={`--quote-count: ${homeData.problem.quotes.length}`}
  >
    <Panel id="problem" class="panel-page" background="surface" fullBleed={true}>
      <div class="problem-stage">
        <div class="problem-header">
          <h2 class="panel-heading">{homeData.problem.heading}</h2>
          <p class="panel-sub">{homeData.problem.subheading}</p>
        </div>

        <!-- SR-only full quote list (the carousel below is decorative) -->
        <ul class="sr-only" aria-label="Worries we hear from parents">
          {homeData.problem.quotes.map(q => <li>{q}</li>)}
        </ul>

        <div class="quote-strip-wrap" aria-hidden="true">
          <div class="quote-strip" id="quote-strip">
            {homeData.problem.quotes.map((q, i) => (
              <div class={`quote-card${i === 0 ? ' is-active' : ''}`} data-index={i}>
                <p class="quote-card__text">"{q}"</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </Panel>
  </div>

  <!-- SOLUTION — 4 inner sections, scroll-driven; z-index:3 -->
  <div
    id="solution-scroll-zone"
    class="solution-scroll-zone"
    style={`--sol-count: ${homeData.solution.sections.length}`}
  >
    <Panel id="solution" class="panel-page" background="default" fullBleed={true}>
      <h2 class="sr-only">A Plan for You &amp; Your Child</h2>

      <div class="sol-stage">

        <!-- Left: text blocks, cross-fade per section -->
        <div class="sol-texts">
          {homeData.solution.sections.map((section, i) => (
            <div class={`sol-text sol-text--${i}`} aria-hidden={i > 0 ? 'true' : 'false'}>
              <p class="eyebrow">{section.eyebrow}</p>
              <h2 class="panel-heading">{section.title}</h2>
              <p class="sol-body">
                {section.linkPhrase && section.body.includes(section.linkPhrase) ? (
                  <Fragment>
                    {section.body.split(section.linkPhrase)[0]}
                    <button type="button" class="sol-inline-link" data-open-plan>{section.linkPhrase}</button>
                    {section.body.split(section.linkPhrase)[1]}
                  </Fragment>
                ) : section.body}
              </p>
            </div>
          ))}
        </div>

        <!-- Right: horizontal filmstrip, shifts on scroll -->
        <div class="sol-filmstrip-wrap" aria-hidden="true">
          <div class="sol-filmstrip" id="sol-filmstrip">
            {homeData.solution.sections.map((_, i) => (
              <div class={`sol-phone-item sol-phone-item--${i}`}>
                <div class="sol-phone-device"></div>
              </div>
            ))}
          </div>
        </div>

      </div>

      <div class="sol-dots" role="tablist" aria-label="Section navigation">
        {homeData.solution.sections.map((_, i) => (
          <button
            class={`sol-dot${i === 0 ? ' is-active' : ''}`}
            role="tab"
            aria-label={`Go to section ${i + 1}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            data-index={String(i)}
          />
        ))}
      </div>
    </Panel>
  </div>

  <!-- SCIENCE — sticky z-index:4 -->
  <Panel id="science" class="panel-page" background="surface">
    <div class="panel-header">
      <Reveal><p class="eyebrow">{homeData.science.eyebrow}</p></Reveal>
      <Reveal delay={100}><h2 class="panel-heading">{homeData.science.heading}</h2></Reveal>
    </div>
    <div class="science-grid">
      {homeData.science.panels.map((panel, i) => (
        <Reveal delay={i * 100}>
          <article class="science-card">
            <h3>{panel.title}</h3>
            <p>{panel.body}</p>
            {panel.cta && (
              <a href={panel.cta.href} class="btn btn--secondary">{panel.cta.label}</a>
            )}
          </article>
        </Reveal>
      ))}
    </div>
  </Panel>

  <!-- PRICING — sticky z-index:5 -->
  <Panel id="pricing" class="panel-page" background="raised">
    <div class="panel-header">
      <Reveal><h2 class="panel-heading">{homeData.pricing.heading}</h2></Reveal>
      <Reveal delay={100}><p class="panel-sub">{homeData.pricing.subheading}</p></Reveal>
    </div>
    <PricingBlock pricing={homeData.pricing} />
  </Panel>

  <!-- COMPARISON — sticky z-index:6 -->
  <Panel id="comparison" class="panel-page" background="surface">
    <div class="panel-header">
      <Reveal><p class="eyebrow">{homeData.comparison.eyebrow}</p></Reveal>
      <Reveal delay={100}><h2 class="panel-heading">{homeData.comparison.heading}</h2></Reveal>
      {homeData.comparison.subheading && (
        <Reveal delay={200}><p class="panel-sub">{homeData.comparison.subheading}</p></Reveal>
      )}
    </div>
    <ComparisonBlock comparison={homeData.comparison} />
  </Panel>

  <!-- SOCIAL PROOF — scroll zone gives GSAP room to cycle quotes -->
  <!-- Zone height = quotes × panel height so panel stays sticky throughout -->
  <div
    class="social-scroll-zone"
    id="social-scroll-zone"
    style={`--quote-count: ${homeData.socialProof.panels.length}`}
  >
    <section
      id="social-proof"
      class="panel-page"
      aria-label={homeData.socialProof.heading}
    >
      <!-- sp-content constrains to container-max without using .container
           (which would trigger the global flex:1 rule and break stage height) -->
      <div class="sp-content">

        <div class="panel-header sp-header">
          <h2 class="eyebrow">{homeData.socialProof.heading}</h2>
        </div>

        <div class="sp-stage" aria-live="polite" aria-atomic="true">
          {homeData.socialProof.panels.map((panel, i) => (
            <div
              class="sp-quote"
              role="group"
              aria-label={`Quote ${i + 1} of ${homeData.socialProof.panels.length}`}
              aria-hidden={i !== 0 ? 'true' : 'false'}
            >
              <blockquote class="sp-quote__text">
                <p>"{panel.quote}"</p>
                {panel.attribution && (
                  <footer>
                    <cite class="sp-quote__attr">— {panel.attribution}</cite>
                  </footer>
                )}
              </blockquote>
            </div>
          ))}
        </div>

        <div class="sp-dots" role="tablist" aria-label="Quote navigation">
          {homeData.socialProof.panels.map((_, i) => (
            <button
              class={`sp-dot${i === 0 ? ' is-active' : ''}`}
              role="tab"
              aria-label={`Go to quote ${i + 1}`}
              aria-selected={i === 0 ? 'true' : 'false'}
              data-index={String(i)}
            />
          ))}
        </div>

      </div>
    </section>
  </div>

  <!-- Video modal -->
  <div class="video-modal" id="video-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Watch video">
    <div class="video-modal__backdrop"></div>
    <div class="video-modal__panel">
      <button class="video-modal__close" aria-label="Close video">&times;</button>
      <div class="video-modal__screen" aria-hidden="true">
        <svg class="video-modal__play" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="32" cy="32" r="31" stroke="currentColor" stroke-width="2"/>
          <path d="M26 22l20 10-20 10V22z" fill="currentColor"/>
        </svg>
        <p>Video coming soon</p>
      </div>
    </div>
  </div>

  <!-- 8-week plan timeline modal -->
  <div class="plan-modal" id="plan-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="plan-modal-heading">
    <div class="plan-modal__backdrop"></div>
    <div class="plan-modal__panel">
      <button class="plan-modal__close" aria-label="Close">&times;</button>

      <div class="plan-modal__header">
        <p class="eyebrow">{planTimeline.eyebrow}</p>
        <h2 id="plan-modal-heading" class="plan-modal__heading">{planTimeline.heading}</h2>
        <p class="plan-modal__intro">{planTimeline.intro}</p>
      </div>

      <div class="plan-track-wrap">
        <div class="plan-track" style={`--week-w: ${WEEK_W}px`}>
          <svg
            class="plan-wave"
            width={waveW}
            height={waveH}
            viewBox={`0 0 ${waveW} ${waveH}`}
            fill="none"
            preserveAspectRatio="none"
            aria-hidden="true"
          >
            <path d={wavePath} />
          </svg>
          {planWeeks.map((w, i) => (
            <div class="plan-week" style={`--i: ${i}`}>
              <div class="plan-week__icon"><span>{w.week}</span></div>
              <h3 class="plan-week__title">{w.title}</h3>
              <p class="plan-week__body">{w.body}</p>
            </div>
          ))}
        </div>
      </div>

      <p class="plan-modal__hint" aria-hidden="true">Scroll to explore →</p>
    </div>
  </div>

</BaseLayout>

<style>
  /* ── Panel stacking ──────────────────────────────────── */
  /* Non-GSAP panels stick at the masthead bottom.          */
  /* GSAP-pinned panels (problem, solution, social-proof)   */
  /* don't use CSS sticky — GSAP manages their position.    */

  /* All panels stick at the masthead bottom — CSS guarantees the slide-over  */
  :global(#hero),
  :global(#problem),
  :global(#solution),
  :global(#science),
  :global(#pricing),
  :global(#social-proof) {
    position: sticky;
    top: var(--masthead-h);
  }

  /* Comparison is NOT pinned — its table can exceed one viewport, and a
     sticky panel can't scroll to reveal its own overflow. As a normal-flow
     panel it scrolls fully through the viewport (so every row is visible),
     while its z-index still lets it slide up over the pinned pricing panel
     on entry and lets social-proof slide over it on exit. */
  :global(#comparison) {
    position: relative;
  }

  /* Desktop dwell: hold the comparison panel back ~0.8 of a screen so the
     pricing cards get read time on BOTH sides of the card-2 swap — card 1
     dwells on entry, then card 2 dwells before the comparison rises. The
     margin sits behind the pinned pricing panel, so it's invisible — it just
     delays the comparison's arrival. */
  @media (min-width: 768px) {
    :global(#comparison) { margin-top: 80svh; }
  }

  /* Mobile: non-animated panels revert to normal flow so taller content
     is never obscured by a higher-z-index panel sliding over it early. */
  @media (max-width: 767px) {
    :global(#hero),
    :global(#science),
    :global(#pricing) {
      position: relative;
      top: 0;
    }

    /* Problem, Solution, and Social Proof stay sticky and need explicit
       heights so their flex children resolve correctly.
       panel-page resets to height:auto on mobile, which collapses
       absolutely/percentage-sized children to 0 and exposes the
       scroll-zone background as blank white space. */
    :global(#problem),
    :global(#solution),
    :global(#social-proof) {
      height: calc(100svh - var(--masthead-h));
      overflow: hidden;
    }
  }

  /* Ascending z-index so each incoming panel covers the previous */
  :global(#hero)         { z-index: 1; background-color: var(--color-bg); }
  :global(#problem)      { z-index: 2; background-color: var(--color-surface); }
  :global(#solution)     { z-index: 3; background-color: var(--color-bg); }
  :global(#science)      { z-index: 4; background-color: var(--color-surface); }
  :global(#pricing)      { z-index: 5; background-color: var(--color-surface-raised); height: auto; min-height: calc(100svh - var(--masthead-h)); overflow: visible; padding-block: var(--space-10); }
  :global(#comparison)   { z-index: 6; background-color: var(--color-surface); height: auto; min-height: calc(100svh - var(--masthead-h)); overflow: visible; padding-block: var(--space-10); }
  :global(#social-proof) { z-index: 7; background-color: var(--color-bg); }

  /* ── Shared panel header ─────────────────────────────── */
  /* Used at the top of every panel for eyebrow + heading  */
  .panel-header {
    text-align: center;
    /* one consistent header→content gap across every panel */
    margin-bottom: var(--space-10);
    flex-shrink: 0; /* don't compress in flex column */
  }

  /* The main headline — identical across all 6 panels */
  .panel-heading {
    font-size: var(--text-4xl);
    font-weight: var(--weight-heading);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-snug);
    color: var(--color-text);
    margin: 0;
  }

  .panel-sub {
    max-width: 60ch;
    margin-inline: auto;
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  /* ── Eyebrow — a subtle pill tag above the heading ───── */
  .eyebrow {
    display: inline-block;
    align-self: flex-start; /* hug content inside the flex sol-text column */
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: var(--color-surface-raised);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }

  /* ── Hero ────────────────────────────────────────────── */
  .hero {
    max-width: 72ch;
    text-align: left;
    padding: var(--space-8) var(--container-pad);
  }

  .hero h1 {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-6);
  }

  .hero__sub {
    margin-bottom: var(--space-8);
    color: var(--color-text-muted);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* ── Problem: quote carousel ─────────────────────────── */
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0;
    margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  .problem-scroll-zone {
    /* one screen to settle, plus a fraction of a screen per extra quote
       so the carousel scrubs through each one while the panel stays pinned */
    height: calc((1 + (var(--quote-count) - 1) * 0.6) * (100vh  - var(--masthead-h)));
    height: calc((1 + (var(--quote-count) - 1) * 0.6) * (100svh - var(--masthead-h)));
  }

  .problem-stage {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-12);
    width: 100%;
    overflow: hidden;
  }

  .problem-header {
    text-align: center;
    max-width: 42rem;
    padding: 0 var(--space-6);
  }

  .problem-header .panel-sub {
    margin-top: var(--space-4);
  }

  /* Filmstrip of quotes — the centred one is scaled up + opaque, neighbours
     recede (see the GSAP timeline). Full-bleed width; ends clipped. */
  .quote-strip-wrap {
    width: 100%;
    overflow: hidden;
    /* room above/below so the bubble tails aren't clipped */
    padding-block: var(--space-10);
  }

  .quote-strip {
    display: flex;
    align-items: center;
    gap: var(--space-12);
    width: max-content;
    will-change: transform;
  }

  /* Speech bubbles — roomy, with the quote centred in lots of open space */
  .quote-card {
    flex: 0 0 auto;
    width: clamp(300px, 66vw, 640px);
    min-height: clamp(190px, 28vh, 290px);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: 36px;
    padding: var(--space-12);
    position: relative;
    transform-origin: center center;
    /* Resting (non-active) state — also the first paint before GSAP runs */
    opacity: 0.4;
    transform: scale(0.78);
  }

  .quote-card.is-active {
    opacity: 1;
    transform: scale(1.16);
  }

  /* Tail — a rotated square sitting over the bottom edge, showing only its
     two outer borders so the bubble outline runs down to the point */
  .quote-card::after {
    content: '';
    position: absolute;
    bottom: -14px;
    left: 14%;
    width: 28px;
    height: 28px;
    background: var(--color-bg);
    border-right: 1.5px solid var(--color-border);
    border-bottom: 1.5px solid var(--color-border);
    border-bottom-right-radius: 7px;
    transform: rotate(45deg);
  }

  .quote-card__text {
    font-family: var(--font-heading);
    font-weight: var(--weight-heading);
    font-style: italic;
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
    color: var(--color-text);
    margin: 0;
    text-align: center;
    max-width: 30ch;
  }

  /* Reduced motion: a plain, manually-scrollable row of full quotes */
  .quote-strip-wrap.is-static {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: var(--space-2) 0;
  }

  .quote-strip-wrap.is-static .quote-card {
    opacity: 1;
    transform: none;
    scroll-snap-align: center;
  }


  /* ── Solution: 4-section inner carousel ─────────────── */
  .solution-scroll-zone {
    height: calc(var(--sol-count) * (100vh  - var(--masthead-h)));
    height: calc(var(--sol-count) * (100svh - var(--masthead-h)));
  }

  .sol-stage {
    flex: 1;
    position: relative;
    overflow: hidden;
    max-width: var(--container-max);
    width: 100%;
    margin-inline: auto;
  }

  /* ── Left half: text blocks ── */
  .sol-texts {
    position: absolute;
    top: 0; bottom: 0;
    left: var(--container-pad);
    width: calc(50% - var(--container-pad));
    display: flex;
    align-items: center;
    overflow: hidden; /* clips sliding text so sections never visually overlap */
  }

  .sol-text {
    position: absolute;
    inset: 0;
    padding-inline: var(--container-pad);
    padding-right: var(--space-8);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-5);
  }

  .sol-text[aria-hidden="true"] { pointer-events: none; }

  /* Only the content (heading + body) slides — eyebrow stays put */
  .sol-text__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .sol-body {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-width: 46ch;
  }

  /* ── Right half: phone filmstrip ── */
  .sol-filmstrip-wrap {
    position: absolute;
    top: 0; bottom: 0; right: 0;
    width: 55%;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .sol-filmstrip {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    /* GSAP sets initial x and animates shifts */
  }

  .sol-phone-item {
    flex-shrink: 0;
    width: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sol-phone-device {
    width: 188px;
    height: 376px;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: 28px;
    position: relative;
    /* GSAP manages scale + opacity */
  }

  .sol-phone-device::before {
    content: '';
    position: absolute;
    top: 10px; left: 50%;
    transform: translateX(-50%);
    width: 52px; height: 13px;
    background: var(--color-bg);
    border-radius: 7px;
  }

  .sol-phone-device::after {
    content: '';
    position: absolute;
    bottom: 8px; left: 50%;
    transform: translateX(-50%);
    width: 52px; height: 4px;
    background: var(--color-border);
    border-radius: 2px;
  }

  /* Indicator dots */
  .sol-dots {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    padding-block: var(--space-6);
    flex-shrink: 0;
    max-width: var(--container-max);
    width: 100%;
    margin-inline: auto;
  }

  .sol-dot {
    width: 8px; height: 8px;
    border-radius: var(--radius-full);
    background: var(--color-border-strong);
    border: none; padding: 0;
    cursor: pointer;
    transition: background var(--transition-base), transform var(--transition-base);
  }

  .sol-dot.is-active {
    background: var(--color-accent);
    transform: scale(1.4);
  }

  .sol-dot:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  /* ── Science cards ───────────────────────────────────── */
  .science-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    align-items: stretch;
  }

  .science-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    height: 100%;
  }

  .science-card h3 {
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-normal);
    line-height: var(--leading-snug);
  }

  .science-card p {
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    flex: 1;
    margin: 0;
  }

  @media (max-width: 767px) {
    .science-grid { grid-template-columns: 1fr; }

    /* ── Solution: stack text above, phones below ── */
    .sol-stage {
      display: flex;
      flex-direction: column;
