---
import BaseLayout from '../layouts/BaseLayout.astro';
import authData from '../../content/auth.json';

const { signin } = authData;
---

<BaseLayout title={signin.meta.title} description={signin.meta.description}>
  <div class="auth-page">
    <div class="auth-card">
      <h1 class="auth-heading">{signin.heading}</h1>

      <!-- Social auth -->
      <div class="auth-social">
        <button class="auth-social-btn" type="button">
          <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          {signin.social.google}
        </button>

        <button class="auth-social-btn" type="button">
          <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#F25022" d="M1 1h10v10H1z"/>
            <path fill="#7FBA00" d="M13 1h10v10H13z"/>
            <path fill="#00A4EF" d="M1 13h10v10H1z"/>
            <path fill="#FFB900" d="M13 13h10v10H13z"/>
          </svg>
          {signin.social.microsoft}
        </button>
      </div>

      <!-- OR divider -->
      <div class="auth-divider" role="separator">
        <span>{signin.divider}</span>
      </div>

      <!-- Email / password form -->
      <form class="auth-form" method="post" action="#">
        <div class="auth-field">
          <label class="auth-label" for="signin-email">{signin.fields.email.label}</label>
          <div class="auth-input-wrap">
            <input
              id="signin-email"
              class="auth-input"
              type="email"
              name="email"
              placeholder={signin.fields.email.placeholder}
              autocomplete="email"
              required
            />
          </div>
        </div>

        <div class="auth-field">
          <label class="auth-label" for="signin-password">{signin.fields.password.label}</label>
          <div class="auth-input-wrap">
            <input
              id="signin-password"
              class="auth-input"
              type="password"
              name="password"
              placeholder={signin.fields.password.placeholder}
              autocomplete="current-password"
              required
            />
            <button class="auth-eye" type="button" aria-label={signin.passwordToggle.show} data-target="signin-password">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <a href="#" class="auth-forgot">{signin.forgot}</a>

        <button class="auth-submit btn btn--primary" type="submit">{signin.submit}</button>
      </form>

      <p class="auth-switch">
        {signin.switch.prompt} <a href="/signup">{signin.switch.link}</a>
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .auth-page {
    min-height: calc(100svh - var(--masthead-h));
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-10) var(--container-pad);
  }

  .auth-card {
    width: 100%;
    max-width: 440px;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-block: auto;
  }

  .auth-heading {
    font-size: var(--text-4xl);
    font-weight: var(--weight-heading);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-2);
  }

  /* Social buttons */
  .auth-social {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .auth-social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    width: 100%;
    padding: var(--space-4);
    background: var(--light-beige);
    border: 1.5px solid var(--almond-beige);
    border-radius: var(--radius-full);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--dark-grey);
    cursor: pointer;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }

  .auth-social-btn:hover {
    background: var(--heavy-beige);
    border-color: var(--almond-beige);
  }

  /* OR divider */
  .auth-divider {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .auth-divider::before,
  .auth-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  /* Form */
  .auth-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .auth-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .auth-label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .auth-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .auth-input {
    width: 100%;
    padding: var(--space-4);
    padding-right: var(--space-12);
    background: var(--light-beige);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .auth-input::placeholder { color: var(--color-text-muted); }

  .auth-input:focus {
    border-color: var(--form-active-outline);
  }

  .auth-eye {
    position: absolute;
    right: var(--space-4);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
  }

  .auth-eye:hover { color: var(--color-text); }

  .auth-forgot {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    align-self: flex-start;
    margin-top: calc(-1 * var(--space-2));
  }

  .auth-forgot:hover { color: var(--color-text); }

  .auth-submit {
    width: 100%;
    justify-content: center;
    padding-block: var(--space-4);
    margin-top: var(--space-2);
  }

  .auth-switch {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .auth-switch a {
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.auth-eye').forEach(btn => {
    btn.addEventListener('click', () => {
      const input = document.getElementById(btn.dataset.target ?? '') as HTMLInputElement;
      if (!input) return;
      const isPassword = input.type === 'password';
      input.type = isPassword ? 'text' : 'password';
      btn.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
    });
  });
</script>
