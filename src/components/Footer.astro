---
import siteData from '../../content/site.json';

const buildTime = new Date().toLocaleString('en-US', {
  year: 'numeric', month: 'short', day: 'numeric',
  hour: '2-digit', minute: '2-digit', timeZoneName: 'short',
});
---

<footer class="footer" role="contentinfo">
  <div class="footer__inner container">
    <div class="footer__brand">
      <span class="footer__logo">alignd</span>
      <p class="footer__tagline">{siteData.tagline}</p>
    </div>

    <nav class="footer__nav" aria-label="Footer navigation">
      <ul class="footer__nav-list" role="list">
        {siteData.footer.links.map((item) => (
          <li>
            <a href={item.href} class="footer__nav-link">{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="footer__contacts">
      <dl class="footer__contact-list">
        {siteData.footer.contacts.map((contact) => (
          <>
            <dt class="footer__contact-label">{contact.label}</dt>
            <dd class="footer__contact-value">
              <a href={`mailto:${contact.email}`} class="footer__contact-link">{contact.email}</a>
            </dd>
          </>
        ))}
      </dl>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container">
      <p class="footer__copyright">{siteData.footer.copyright}</p>
      <!-- TODO: remove before launch -->
      <p class="footer__build-time">Last updated: {buildTime}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--footer-bg);
    color: var(--footer-text);
    padding-top: var(--space-10);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 2fr 1fr 2fr;
    gap: var(--space-10);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--footer-border);
  }

  .footer__logo {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--weight-heading);
    letter-spacing: var(--tracking-tight);
    color: var(--footer-link-hover);
    display: block;
    margin-bottom: var(--space-2);
  }

  .footer__tagline {
    font-size: var(--text-xs);
    color: var(--footer-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__nav-link {
    font-size: var(--text-sm);
    line-height: 1.4;
    color: var(--footer-link);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__nav-link:hover {
    color: var(--footer-link-hover);
  }

  .footer__contact-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3) var(--space-4);
    align-items: baseline;
    margin: 0;
  }

  .footer__contact-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--footer-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  .footer__contact-value {
    margin: 0;
  }

  .footer__contact-link {
    font-size: var(--text-sm);
    color: var(--footer-link);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__contact-link:hover {
    color: var(--footer-link-hover);
  }

  .footer__bottom {
    padding-block: var(--space-6);
  }

  .footer__copyright {
    font-size: var(--text-xs);
    color: var(--footer-text-muted);
    text-align: center;
    margin: 0;
  }

  .footer__build-time {
    font-size: var(--text-xs);
    color: var(--footer-text-muted);
    text-align: center;
    margin: var(--space-2) 0 0;
    opacity: 0.6;
  }

  @media (max-width: 767px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer__brand {
      grid-column: span 2;
    }
  }
</style>
