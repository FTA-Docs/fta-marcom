<script>
  const root = getComputedStyle(document.documentElement);
  const raw = (n: string) => root.getPropertyValue(n).trim();

  function rgbToHex(value: string): string {
    const v = value.trim();
    const nums = v.match(/[\d.]+/g);
    if (!nums) return value;
    let [r, g, b, a] = nums.map(Number);
    // Mixed colors (color-mix) compute to `color(srgb r g b / a)` with 0–1
    // channels; plain rgb()/rgba() uses 0–255. Normalize the former to 0–255.
    if (/^color\(/i.test(v)) { r *= 255; g *= 255; b *= 255; }
    const hex = '#' + [r, g, b].map(x => Math.round(x).toString(16).padStart(2, '0')).join('');
    return a !== undefined && a < 1 ? `${hex} · ${Math.round(a * 100)}%` : hex;
  }

  // Resolve a token to its used value by applying it to an off-screen probe.
  function resolve(name: string, prop: string): string {
    const probe = document.createElement('div');
    probe.style.position = 'absolute';
    probe.style.visibility = 'hidden';
    probe.style.setProperty(prop, `var(${name})`);
    document.body.appendChild(probe);
    const v = getComputedStyle(probe).getPropertyValue(prop);
    probe.remove();
    return v;
  }

  document.querySelectorAll<HTMLElement>('[data-var]').forEach(el => {
    const name = el.dataset.var!;
    const kind = el.dataset.kind;

    const rawEl = el.querySelector('[data-raw]');
    if (rawEl) rawEl.textContent = raw(name);

    if (kind === 'color') {
      const hexEl = el.querySelector('[data-hex]');
      if (hexEl) hexEl.textContent = rgbToHex(resolve(name, 'color'));
    }

    if (kind === 'size') {
      const pxEl = el.querySelector('[data-px]');
      const prop = el.dataset.pxprop || 'width';
      if (pxEl) pxEl.textContent = resolve(name, prop);
    }
  });
</script>
