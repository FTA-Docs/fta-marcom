---
import BaseLayout from '../layouts/BaseLayout.astro';
import Panel from '../components/Panel.astro';
import notFound from '../../content/404.json';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist." noindex={true}>

  <Panel>
    <div class="not-found">
      <span class="not-found__code" aria-hidden="true">{notFound.code}</span>
      <h1>{notFound.heading}</h1>
      <p>{notFound.body}</p>
      <div class="not-found__actions">
        <a href="/" class="btn btn--primary">{notFound.homeLabel}</a>
        <a href="/support-faqs" class="btn btn--secondary">{notFound.supportLabel}</a>
      </div>
    </div>
  </Panel>

</BaseLayout>

<style>
  .not-found {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    align-items: center;
    padding-block: var(--space-20);
  }

  .not-found__code {
    font-size: var(--text-6xl);
    font-weight: var(--weight-black);
    color: var(--color-text-subtle);
    line-height: 1;
    display: block;
  }

  .not-found__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
