---
import siteData from '../../content/site.json';
---

<header class="masthead" role="banner">
  <div class="masthead__inner container">
    <a href="/" class="masthead__logo" aria-label="alignd — go to homepage">
      <img src="/alignd_logo_fullcolor.svg" alt="alignd" class="masthead__logo-img" width="222" height="34" />
    </a>

    <button
      class="masthead__hamburger"
      aria-expanded="false"
      aria-controls="masthead-nav"
      aria-label="Open navigation menu"
    >
      <span class="hamburger-bar" aria-hidden="true"></span>
      <span class="hamburger-bar" aria-hidden="true"></span>
      <span class="hamburger-bar" aria-hidden="true"></span>
    </button>

    <nav id="masthead-nav" class="masthead__nav" aria-label="Main navigation">
      <ul role="list" class="masthead__nav-list">
        {siteData.nav.map((item) => (
          <li>
            <a href={item.href} class="masthead__nav-link">{item.label}</a>
          </li>
        ))}
      </ul>
      <div class="masthead__actions">
        <a href={siteData.cta.signIn.href} class="btn btn--secondary">{siteData.cta.signIn.label}</a>
        <a href={siteData.cta.getStarted.href} class="btn btn--primary">{siteData.cta.getStarted.label}</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .masthead {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-masthead);
    height: var(--masthead-h);
    background-color: var(--masthead-bg);
  }

  .masthead__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: var(--space-6);
  }

  .masthead__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .masthead__logo-img {
    height: 34px;
    width: 222px;
    display: block;
  }

  .masthead__nav {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .masthead__nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .masthead__nav-link {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--masthead-text);
    text-decoration: none;
    transition: opacity var(--transition-fast);
    white-space: nowrap;
  }

  .masthead__nav-link:hover {
    opacity: 0.7;
  }

  .masthead__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .masthead__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: var(--space-2);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  .hamburger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--masthead-text);
    border-radius: 1px;
    transition:
      transform var(--transition-fast),
      opacity var(--transition-fast);
  }

  /* Tablet + mobile: the full horizontal nav (logo + 4 links + 2 CTAs) needs
     ~990px to fit, so collapse to the hamburger menu below the desktop breakpoint. */
  @media (max-width: 1023px) {
    .masthead__hamburger {
      display: flex;
    }

    /* Open: morph the three bars into an X (bars are 2px tall, 5px gap, so the
       outer bars travel 7px to meet at the centre line, then rotate). */
    .masthead__hamburger[aria-expanded='true'] .hamburger-bar:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .masthead__hamburger[aria-expanded='true'] .hamburger-bar:nth-child(2) {
      opacity: 0;
    }
    .masthead__hamburger[aria-expanded='true'] .hamburger-bar:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    .masthead__nav {
      display: none;
      /* Cover the whole viewport below the masthead, fully opaque. Absolute
         (not fixed) so it's contained by the fixed .masthead regardless of the
         masthead's backdrop-filter; top:100% drops it just under the bar and
         the svh height fills the rest of the screen. */
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      height: calc(100svh - var(--masthead-h));
      background: var(--white);
      flex-direction: column;
      /* Centre the links + buttons as one group, then bias it upward: the
         extra bottom padding shrinks the centring box from below, so the group
         sits a little higher — more space under the buttons, less over the
         links. */
      justify-content: center;
      align-items: flex-start;
      gap: var(--space-8);
      padding: var(--space-6) var(--space-6) var(--space-12);
    }

    .masthead__nav.is-open {
      display: flex;
    }

    .masthead__nav-list {
      flex-direction: column;
      align-items: center;
      gap: var(--space-2);
      width: 100%;
    }

    .masthead__nav-link {
      display: block;
      padding: var(--space-3) var(--space-2);
      font-size: var(--text-lg);
      line-height: var(--leading-snug);
      text-align: center;
      width: 100%;
    }

    .masthead__actions {
      width: 100%;
      flex-direction: column;
    }

    .masthead__actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  const hamburger = document.querySelector<HTMLButtonElement>('.masthead__hamburger');
  const nav = document.querySelector<HTMLElement>('#masthead-nav');

  function openNav() {
    if (!nav || !hamburger) return;
    nav.classList.add('is-open');
    hamburger.setAttribute('aria-expanded', 'true');
    hamburger.setAttribute('aria-label', 'Close navigation menu');
  }

  function closeNav() {
    if (!nav || !hamburger) return;
    nav.classList.remove('is-open');
    hamburger.setAttribute('aria-expanded', 'false');
    hamburger.setAttribute('aria-label', 'Open navigation menu');
  }

  hamburger?.addEventListener('click', () => {
    const isOpen = nav?.classList.contains('is-open');
    if (isOpen) {
      closeNav();
    } else {
      openNav();
    }
  });

  // Close the menu when a link inside it is tapped — otherwise same-page anchor
  // links (e.g. /#pricing) just scroll and leave the panel open over the page.
  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => closeNav());
  });

  document.addEventListener('click', (event) => {
    if (!nav || !hamburger) return;
    const target = event.target as Node;
    if (!hamburger.contains(target) && !nav.contains(target)) {
      closeNav();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && nav?.classList.contains('is-open')) {
      closeNav();
      hamburger?.focus();
    }
  });
</script>
