---
import BaseLayout from '../layouts/BaseLayout.astro';
import Panel from '../components/Panel.astro';
import Reveal from '../components/Reveal.astro';
import MissionContent from '../../content/about/mission.md';
import ClinicalContent from '../../content/about/clinical.md';
import ComBContent from '../../content/about/com-b.md';
import TechnologyContent from '../../content/about/technology.md';
import FoundingTeamContent from '../../content/about/founding-team.md';
import teamData from '../../content/about/team.json';
import combData from '../../content/about/com-b.json';
import techData from '../../content/about/technology.json';
import pageData from '../../content/about/page.json';
import { emotionPaths } from '../lib/emotions';
---

<BaseLayout
  title={pageData.meta.title}
  description={pageData.meta.description}
>

  <!-- Hero / Our Mission — text left, image right (matches the homepage hero) -->
  <Panel size="sm">
    <div class="about-split about-hero">
      <div class="about-split__text">
        <Reveal><p class="eyebrow">{pageData.mission.eyebrow}</p></Reveal>
        <Reveal delay={50}><h1>{pageData.mission.heading}</h1></Reveal>
        <Reveal delay={100}>
          <div class="prose about-hero__prose">
            <MissionContent />
          </div>
        </Reveal>
      </div>
      <Reveal delay={150} class="about-split__visual">
        <figure class="about-figure">
          <div class="about-figure__frame">
            <img src="/teenageband.png" alt={pageData.mission.imageAlt} />
          </div>
          <svg class="about-figure__motif" viewBox="0 0 298 298" fill="none" aria-hidden="true" set:html={emotionPaths('Clarity')} />
        </figure>
      </Reveal>
    </div>
  </Panel>

  <!-- Clinical Experience — photo (circle) left, text right -->
  <Panel background="surface" class="about-pad">
    <div class="about-split about-split--reverse">
      <div class="about-split__text">
        <Reveal><h2>{pageData.clinical.heading}</h2></Reveal>
        <Reveal delay={100}>
          <div class="prose">
            <ClinicalContent />
          </div>
        </Reveal>
      </div>
      <Reveal delay={150} class="about-split__visual">
        <figure class="about-figure about-figure--circle">
          <div class="about-figure__frame">
            <span class="about-figure__placeholder">{pageData.clinical.placeholder}</span>
          </div>
          <figcaption class="about-figure__caption">{pageData.clinical.caption}</figcaption>
        </figure>
      </Reveal>
    </div>
  </Panel>

  <!-- About COM-B — text left, line-motif Venn right -->
  <Panel background="default" class="about-pad">
    <div class="about-split">
      <div class="about-split__text">
        <Reveal><h2>{pageData.comb.heading}</h2></Reveal>
        <Reveal delay={100}>
          <div class="prose">
            <ComBContent />
          </div>
        </Reveal>
      </div>
      <Reveal delay={150} class="about-split__visual">
        <!-- No role="img": the per-node labels/descriptions below are meaningful
             content and should be read by AT. Only the decorative overlap circles
             are hidden. -->
        <div class="comb">
          <span class="comb__circle comb__circle--cap" aria-hidden="true"></span>
          <span class="comb__circle comb__circle--opp" aria-hidden="true"></span>
          <span class="comb__circle comb__circle--mot" aria-hidden="true"></span>

          <div class="comb__label comb__label--cap">
            <svg class="comb__icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 18h6M10 21h4M12 3a6 6 0 0 0-3.6 10.8c.5.4.9 1 1 1.7l.1.5h5l.1-.5c.1-.7.5-1.3 1-1.7A6 6 0 0 0 12 3z"/>
            </svg>
            <span class="comb__title">{combData.nodes[0].label}</span>
            <span class="comb__desc">{combData.nodes[0].desc}</span>
          </div>

          <div class="comb__label comb__label--opp">
            <svg class="comb__icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 3 4 7.5v9L12 21l8-4.5v-9L12 3zM4 7.5 12 12m0 0 8-4.5M12 12v9"/>
            </svg>
            <span class="comb__title">{combData.nodes[1].label}</span>
            <span class="comb__desc">{combData.nodes[1].desc}</span>
          </div>

          <div class="comb__label comb__label--mot">
            <svg class="comb__icon comb__icon--fill" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/>
            </svg>
            <span class="comb__title">{combData.nodes[2].label}</span>
            <span class="comb__desc">{combData.nodes[2].desc}</span>
          </div>

          <span class="comb__center">{combData.center}</span>
        </div>
      </Reveal>
    </div>
  </Panel>

  <!-- Our Technology — intro + "Five Structural Layers" table -->
  <Panel background="surface" class="about-pad">
    <div class="about-section">
      <Reveal><h2>{pageData.technology.heading}</h2></Reveal>
      <Reveal delay={100}>
        <div class="prose about-prose-narrow">
          <TechnologyContent />
        </div>
      </Reveal>
      <Reveal delay={150}>
        <div class="tech-layers">
          <button type="button" class="tech-layers__link" data-open-tech>{techData.linkText}</button>
          <p class="tech-layers__intro">
            {techData.layersIntro.includes(techData.linkPhrase) ? (
              <Fragment>
                {techData.layersIntro.split(techData.linkPhrase)[0]}
                <button type="button" class="tech-inline-link" data-open-tech>{techData.linkPhrase}</button>
                {techData.layersIntro.split(techData.linkPhrase)[1]}
              </Fragment>
            ) : techData.layersIntro}
          </p>
        </div>
      </Reveal>
    </div>

    <!-- Technology deep-dive modal: the five structural layers table -->
    <div class="tech-modal" id="tech-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="tech-modal-heading">
      <div class="tech-modal__backdrop"></div>
      <div class="tech-modal__panel">
        <button class="tech-modal__close" aria-label="Close">&times;</button>
        <div class="tech-modal__header">
          <h2 id="tech-modal-heading" class="tech-modal__heading">{techData.modalHeading}</h2>
        </div>
        <div class="tech-table-wrap">
          <table class="tech-table">
            <thead>
              <tr>
                <th scope="col">{techData.cols[0]}</th>
                <th scope="col">{techData.cols[1]}</th>
                <th scope="col">{techData.cols[2]}</th>
              </tr>
            </thead>
            <tbody>
              {techData.layers.map(layer => (
                <tr>
                  <th scope="row">{layer.name}</th>
                  <td>{layer.adds}</td>
                  <td>{layer.why}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </Panel>

  <!-- Founding Team -->
  <Panel background="default" class="about-pad">
    <div class="about-section">
      <Reveal><h2>{pageData.team.heading}</h2></Reveal>
      <Reveal delay={100}>
        <div class="prose team-intro">
          <FoundingTeamContent />
        </div>
      </Reveal>
      <div class="team-grid">
        {teamData.members.map((member, i) => (
          <Reveal delay={i * 80}>
            <div class="team-card">
              <div class="team-avatar" aria-hidden="true">
                {member.headshot && <img src={member.headshot} alt={member.name} />}
              </div>
              <span class="team-name">{member.name}</span>
              <span class="team-title">{member.title}</span>
              <button
                class="team-bio-btn"
                data-id={member.id}
                aria-label={pageData.team.bioButtonAria.replace('{name}', member.name)}
              >{pageData.team.bioButton}</button>
            </div>
          </Reveal>
        ))}
      </div>

      <!-- Bio Modal -->
      <div class="bio-modal" id="bio-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="bio-modal-name">
        <div class="bio-modal__backdrop"></div>
        <div class="bio-modal__panel">
          <button class="bio-modal__close" aria-label={pageData.team.modalCloseAria}>&times;</button>
          <div class="bio-modal__avatar"></div>
          <h3 class="bio-modal__name" id="bio-modal-name"></h3>
          <p class="bio-modal__title"></p>
          <p class="bio-modal__bio"></p>
          <a class="bio-modal__linkedin" href="#" target="_blank" rel="noopener noreferrer">{pageData.team.linkedinLabel}</a>
        </div>
      </div>
    </div>
  </Panel>

</BaseLayout>

<style>
  /* Content sections: tighter than the default section padding so the
     page reads at a density closer to the rest of the site */
  :global(.about-pad) {
    padding-block: var(--space-12);
  }

  .about-hero__prose {
    max-width: 60ch;
    margin-top: var(--space-5);
  }

  .about-section {
    align-items: start;
  }

  .about-section h2 {
    margin-top: 0;
    margin-bottom: var(--space-5);
  }

  /* Body copy matches the homepage hero sub: base size, full text color */
  .prose :global(p) {
    color: var(--color-text);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
  }

  .prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(strong) {
    color: var(--color-text);
    font-weight: var(--weight-semibold);
  }

  /* ── Two-column split (text + visual) ── */
  .about-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .about-split__text h2 {
    margin-top: 0;
    margin-bottom: var(--space-5);
  }

  .about-split--reverse .about-split__text { order: 2; }
  .about-split--reverse .about-split__visual { order: 1; }

  .about-prose-narrow { max-width: 64ch; }

  /* ── Photo figure (placeholder) ── */
  .about-figure { margin: 0; position: relative; }

  /* Clarity motif — drawn over the phone in the photo, spilling past the left
     edge into the whitespace (like the homepage science-panel motif). */
  .about-figure__motif {
    display: none; /* motif over photo hidden — re-enable by removing this line */
    position: absolute;
    left: -24%;
    bottom: -24%;
    width: 68%;
    aspect-ratio: 1 / 1;
    color: var(--pollen);
    overflow: visible;
    max-width: none;
    pointer-events: none;
    z-index: 2;
  }
  .about-figure__motif :global(path) {
    stroke: currentColor;
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .about-figure__frame {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-media);
    background: var(--color-surface-raised);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Spring-leaf tint over the Mission photo — matches the homepage hero card */
  .about-hero .about-figure__frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--spring-leaf) 25%, transparent);
    pointer-events: none;
    z-index: 1;
  }

  .about-figure__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Circular portrait variant — centered, sized down from the full column */
  .about-figure--circle {
    max-width: 360px;
    margin-inline: auto;
  }
  .about-figure--circle .about-figure__frame {
    border-radius: var(--radius-full);
  }

  .about-figure__placeholder {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-subtle);
  }

  .about-figure__caption {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
  }

  /* ── COM-B Venn (coded, not an image) ── */
  .comb {
    position: relative;
    width: 100%;
    max-width: 420px;
    margin-inline: auto;
    aspect-ratio: 1 / 1;
  }

  /* Filled translucent beige circles — overlaps darken into the Venn shape */
  .comb__circle {
    position: absolute;
    width: 64%;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-full);
    background: var(--almond-beige);
    opacity: 0.32;
  }

  .comb__circle--cap { top: 0; left: 50%; transform: translateX(-50%); }
  .comb__circle--opp { bottom: 0; left: 0; }
  .comb__circle--mot { bottom: 0; right: 0; }

  .comb__label {
    position: absolute;
    width: 40%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-1);
    pointer-events: none;
  }

  .comb__label--cap { top: 9%;  left: 50%; transform: translateX(-50%); }
  .comb__label--opp { bottom: 13%; left: 9%; }
  .comb__label--mot { bottom: 13%; right: 9%; }

  .comb__icon {
    width: 26px;
    height: 26px;
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .comb__icon--fill {
    fill: var(--color-accent);
    stroke: none;
  }

  .comb__title {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    color: var(--color-text);
  }

  .comb__desc {
    font-size: var(--text-xs);
    line-height: var(--leading-snug);
    color: var(--color-text-muted);
  }

  .comb__center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
  }

  /* ── Technology "Five Structural Layers" table ──
     Borrows the homepage comparison table's striping + typography; no
     highlighted (green) column here — every row is an Alignd layer. */
  .tech-layers { margin-top: var(--space-8); }

  /* "Take a closer look" — heading-scale link that opens the layers modal */
  .tech-layers__link {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: var(--weight-semibold);
    font-size: var(--text-xl);
    color: var(--color-accent);
    background: none;
    border: none;
    padding: 0;
    margin: 0 0 var(--space-3);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity var(--transition-fast);
  }
  .tech-layers__link:hover { opacity: 0.7; }
  .tech-layers__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .tech-layers__intro {
    color: var(--color-text);
    line-height: var(--leading-normal);
    max-width: 64ch;
    margin: 0;
  }

  /* Inline "five structural layers" link inside the intro copy */
  .tech-inline-link {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    transition: opacity var(--transition-fast);
  }
  .tech-inline-link:hover { opacity: 0.7; }
  .tech-inline-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .tech-table-wrap { overflow-x: auto; }

  .tech-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    table-layout: fixed;
    font-size: var(--text-sm);
    /* Three text columns need room; scrolls horizontally on narrower screens. */
    min-width: 760px;
  }

  .tech-table th,
  .tech-table td {
    padding: var(--space-3) var(--space-5);
    text-align: left;
    vertical-align: top;
    line-height: var(--leading-normal);
  }

  /* Layer-name column narrower; the two explanation columns split the rest */
  .tech-table thead th:first-child,
  .tech-table tbody th { width: 26%; }

  /* Zebra striping, matching the comparison table */
  .tech-table tbody tr:nth-child(odd) td,
  .tech-table tbody tr:nth-child(odd) th {
    background: var(--light-beige);
  }

  .tech-table thead th {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-normal);
    color: var(--color-heading);
  }

  .tech-table tbody th {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    vertical-align: top;
  }

  .tech-table td { color: var(--color-text); }

  /* ── Technology deep-dive modal (holds the five-layers table) ── */
  .tech-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: var(--z-modal, 100);
    align-items: center;
    justify-content: center;
  }
  .tech-modal[aria-hidden="false"] { display: flex; }

  .tech-modal__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--midnight) 65%, transparent);
  }

  .tech-modal__panel {
    position: relative;
    background: var(--color-bg);
    border-radius: var(--radius-md);
    width: min(1100px, calc(100% - var(--space-6)));
    max-height: min(90vh, 820px);
    padding: var(--space-10) var(--space-8) var(--space-8);
    overflow: auto;
  }

  .tech-modal__close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    background: none;
    border: none;
    font-size: var(--text-xl);
    line-height: 1;
    cursor: pointer;
    color: var(--color-text-muted);
  }
  .tech-modal__close:hover { color: var(--color-text); }

  .tech-modal__header { margin-bottom: var(--space-6); }

  .tech-modal__heading {
    font-family: var(--font-heading);
    font-weight: var(--weight-heading);
    font-size: var(--text-2xl);
    color: var(--color-heading);
    margin: 0;
  }

  .team-intro {
    max-width: 64ch;
    margin-bottom: var(--space-10);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .team-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
  }

  .team-avatar {
    width: clamp(150px, 15vw, 196px);
    height: clamp(150px, 15vw, 196px);
    border-radius: var(--radius-full);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    aspect-ratio: 1;
    overflow: hidden;
    margin-bottom: var(--space-2);
  }

  .team-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .team-name {
    font-weight: var(--weight-heading);
    font-size: var(--text-lg);
  }

  .team-title {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .team-bio-btn {
    margin-top: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-accent);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .team-bio-btn:hover {
    opacity: 0.7;
  }

  .team-bio-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Bio Modal */
  .bio-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: var(--z-modal, 100);
    align-items: center;
    justify-content: center;
  }

  .bio-modal[aria-hidden="false"] {
    display: flex;
  }

  .bio-modal__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--midnight) 60%, transparent);
  }

  .bio-modal__panel {
    position: relative;
    background: var(--color-surface, var(--white));
    border-radius: var(--radius-md);
    padding: var(--space-10);
    max-width: 480px;
    width: calc(100% - var(--space-8));
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-3);
  }

  .bio-modal__close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    background: none;
    border: none;
    font-size: var(--text-xl);
    line-height: 1;
    cursor: pointer;
    color: var(--color-text-muted);
  }

  .bio-modal__close:hover {
    color: var(--color-text);
  }

  .bio-modal__avatar {
    width: 96px;
    height: 96px;
    border-radius: var(--radius-full);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    overflow: hidden;
    flex-shrink: 0;
  }

  .bio-modal__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bio-modal__name {
    font-size: var(--text-xl);
    font-weight: var(--weight-heading);
    margin: 0;
  }

  .bio-modal__title {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .bio-modal__bio {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
    text-align: left;
  }

  .bio-modal__linkedin {
    font-size: var(--text-sm);
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .bio-modal__linkedin:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .about-split {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    /* Always show text above the visual when stacked */
    .about-split--reverse .about-split__text { order: 0; }
    .about-split--reverse .about-split__visual { order: 0; }

    .about-figure__frame { aspect-ratio: 3 / 2; }

    /* Technology table: scroll horizontally; pin the layer-name column so the
       descriptions scroll underneath it (mirrors the comparison table). */
    .tech-table {
      min-width: 640px;
      font-size: var(--text-sm);
    }
    .tech-table th,
    .tech-table td {
      padding: var(--space-3) var(--space-4);
      line-height: var(--leading-snug);
    }
    .tech-table thead th:first-child,
    .tech-table tbody th { width: 148px; }
    .tech-table thead th:first-child,
    .tech-table th[scope="row"] {
      position: sticky;
      left: 0;
      z-index: 2;
      background: var(--color-bg);
    }
    .tech-table tbody tr:nth-child(odd) th[scope="row"] {
      background: var(--light-beige);
    }

    /* Modal fills more of the small screen so the table has room */
    .tech-modal__panel {
      width: calc(100% - var(--space-4));
      max-height: 92vh;
      padding: var(--space-8) var(--space-5) var(--space-5);
    }
  }

  @media (max-width: 640px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script define:vars={{ teamData }}>
  // Shared modal wiring: focus return + trap (WCAG 2.4.3 / 2.1.2), Escape and
  // backdrop close, and body-scroll lock. Returns { open, close }. Relies on the
  // BEM convention that the close button / backdrop end in __close / __backdrop.
  function createModal(modalEl) {
    const closeBtn = modalEl.querySelector('[class*="__close"]');
    const backdrop = modalEl.querySelector('[class*="__backdrop"]');
    let returnFocus = null;

    const focusable = () =>
      Array.from(
        modalEl.querySelectorAll('a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])')
      ).filter(el => el.offsetParent !== null);

    function open() {
      returnFocus = document.activeElement;
      modalEl.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      (closeBtn || modalEl).focus();
    }
    function close() {
      modalEl.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (returnFocus) returnFocus.focus();
    }

    closeBtn?.addEventListener('click', close);
    backdrop?.addEventListener('click', close);
    modalEl.addEventListener('keydown', e => {
      if (e.key !== 'Tab') return;
      const f = focusable();
      if (!f.length) return;
      const first = f[0];
      const last = f[f.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && modalEl.getAttribute('aria-hidden') === 'false') close();
    });

    return { open, close };
  }

  // ── Founding-team bio modal ──
  const bioModalEl = document.getElementById('bio-modal');
  if (bioModalEl) {
    const bioModal = createModal(bioModalEl);
    document.querySelectorAll('.team-bio-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const member = teamData.members.find(m => m.id === btn.dataset.id);
        if (!member) return;
        bioModalEl.querySelector('.bio-modal__name').textContent = member.name;
        bioModalEl.querySelector('.bio-modal__title').textContent = member.title;
        bioModalEl.querySelector('.bio-modal__bio').textContent = member.bio;
        bioModalEl.querySelector('.bio-modal__avatar').innerHTML = member.headshot
          ? `<img src="${member.headshot}" alt="${member.name}" />`
          : '';
        bioModalEl.querySelector('.bio-modal__linkedin').href = member.linkedin || '#';
        bioModal.open();
      });
    });
  }

  // ── Technology "closer look" modal (holds the five-layers table) ──
  const techModalEl = document.getElementById('tech-modal');
  if (techModalEl) {
    // Move to body so it escapes any transformed ancestor (Reveal) stacking.
    document.body.appendChild(techModalEl);
    const techModal = createModal(techModalEl);
    document.querySelectorAll('[data-open-tech]').forEach(btn =>
      btn.addEventListener('click', techModal.open));
  }
</script>
