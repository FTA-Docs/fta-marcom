---
interface Plan {
  name: string;
  price: string;
  period: string;
  note?: string;
  description: string;
  linkPhrase?: string;
  cta: { label: string; href: string };
  primary?: boolean;
}

interface Props {
  pricing: {
    plans: Plan[];
    valueHighlights: string[];
  };
}

const { pricing } = Astro.props;
const { plans, valueHighlights } = pricing;
---

<div class="pricing-block">

  <div class="pricing-layout">

    <!-- Left: stacked plan cards -->
    <div class="plan-stack" id="plan-stack">
      {plans.map((plan, i) => (
        <article
          class="plan-card"
          data-position={i === 0 ? 'front' : 'back'}
          aria-label={plan.name}
        >
          <div class="plan-card__header">
            <h3 class="plan-card__name">{plan.name}</h3>
            <div class="plan-card__price-row">
              <span class="plan-card__price">{plan.price}</span>
              <span class="plan-card__period">{plan.period}</span>
              {plan.note && <span class="plan-card__note">{plan.note}</span>}
            </div>
          </div>
          <p class="plan-card__description">
            {plan.linkPhrase && plan.description.includes(plan.linkPhrase) ? (
              <Fragment>
                {plan.description.split(plan.linkPhrase)[0]}
                <button type="button" class="plan-inline-link" data-open-plan>{plan.linkPhrase}</button>
                {plan.description.split(plan.linkPhrase)[1]}
              </Fragment>
            ) : plan.description}
          </p>
          <a
            href={plan.cta.href}
            class={`btn ${i === 0 ? 'btn--primary' : 'btn--secondary'} plan-card__cta`}
          >{plan.cta.label}</a>
        </article>
      ))}
    </div>

    <!-- Right: value highlights + compare link -->
    <div class="pricing-highlights">
      <ul class="value-highlights" role="list">
        {valueHighlights.map(h => (
          <li class="value-highlight">
            <span class="value-highlight__check" aria-hidden="true">✓</span>
            <span>{h}</span>
          </li>
        ))}
      </ul>
    </div>

  </div>

</div>

<style>
  .pricing-block {
    padding-bottom: var(--space-10);
  }

  /* ── Two-column layout ── */
  .pricing-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  /* ── Card stack ── */
  .plan-stack {
    position: relative;
    height: clamp(300px, 42vh, 380px);
    margin-bottom: 40px; /* space for back card bottom overflow */
  }

  .plan-card {
    position: absolute;
    border-radius: var(--radius-md);
    padding: var(--space-8);
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    transition:
      top 0.45s cubic-bezier(0.34, 1.3, 0.64, 1),
      left 0.45s cubic-bezier(0.34, 1.3, 0.64, 1),
      right 0.45s cubic-bezier(0.34, 1.3, 0.64, 1),
      bottom 0.45s cubic-bezier(0.34, 1.3, 0.64, 1),
      transform 0.2s ease-out,
      opacity 0.3s ease;
  }

  /* ── Scroll-linked fan ──
     The two cards fan apart and re-stack as the pricing panel scrolls
     through its span, revealing the second plan without a click. The motion
     lives in `transform`, written per-frame by the scroll handler in the
     script below (the swap's slide rides on the position offsets above).
     Resting transforms are declared per-position so the stack looks right
     before the script runs. */

  /* Front card: narrower on the right so back card is visible */
  .plan-card[data-position="front"] {
    top: 0;
    left: 0;
    bottom: 0;
    right: 80px;
    border: 2px solid var(--color-text);
    z-index: 2;
    opacity: 1;
    transform: none;
    cursor: default;
  }

  /* Back card: offset down-right, extends to full stack width */
  .plan-card[data-position="back"] {
    top: 36px;
    left: 60px;
    bottom: -36px;
    right: 0;
    border: 1px solid var(--color-border);
    z-index: 1;
    opacity: 0.8;
    transform: rotate(1.5deg);
  }

  .plan-card__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .plan-card__name {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin: 0;
  }

  .plan-card__price-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .plan-card__price {
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
  }

  .plan-card__period {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .plan-card__note {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .plan-card__description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
    flex: 1;
  }

  .plan-inline-link {
    font: inherit;
    color: var(--color-text);
    background: none;
    border: none;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
    transition: opacity var(--transition-fast);
  }
  .plan-inline-link:hover { opacity: 0.65; }

  .plan-card__cta {
    align-self: flex-start;
  }

  /* ── Value highlights ── */
  .pricing-highlights {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-top: var(--space-2);
  }

  .value-highlights {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .value-highlight {
    display: flex;
    gap: var(--space-3);
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: var(--leading-normal);
    align-items: flex-start;
  }

  .value-highlight__check {
    font-weight: var(--weight-bold);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* ── Responsive ── */
  @media (max-width: 767px) {
    .pricing-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    /* On mobile, break out of the absolute-stacked card effect and
       show both plan cards as normal stacked blocks */
    .plan-stack {
      height: auto;
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      margin-bottom: 0;
    }

    .plan-card {
      position: static !important;
      transform: none !important;
      opacity: 1 !important;
      width: 100%;
    }

    .value-highlights {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const stack = document.getElementById('plan-stack');
  const cards = stack ? Array.from(stack.querySelectorAll<HTMLElement>('.plan-card')) : [];
  const panel = document.getElementById('pricing');

  if (stack && panel && cards.length === 2) {
    const panelEl = panel;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const desktop = window.matchMedia('(min-width: 768px)');

    // Current fan amount (0 = resting stack, 1 = fully fanned). The scroll
    // handler drives it; swapCards re-applies at the current value.
    let fan = 0;

    // ── Apply the fan as a transform on each card ──────────────
    // Written as a literal transform string (no CSS var/calc/longhands —
    // those proved unreliable to render). The swap's slide rides on the
    // position offsets in CSS; this only owns rotation + the fan spread.
    function applyFan() {
      cards.forEach(card => {
        if (card.dataset.position === 'back') {
          // swing down-right and rotate further out to read as a 2nd card
          card.style.transform =
            `translate(${(fan * 44).toFixed(1)}px, ${(fan * 16).toFixed(1)}px) ` +
            `rotate(${(1.5 + fan * 4).toFixed(2)}deg)`;
        } else {
          // nudge up-left so the pair spreads like a hand of cards
          card.style.transform =
            `translate(${(fan * -34).toFixed(1)}px, ${(fan * -6).toFixed(1)}px) ` +
            `rotate(${(fan * -2.5).toFixed(2)}deg)`;
        }
      });
    }

    // Put card 2 (the second plan) on top, or restore card 1 — driven by
    // scroll position in updateFan. Toggling data-position lets the CSS
    // transition animate the z-swap (front ↔ back offsets).
    function setCard2OnTop(onTop: boolean) {
      const card2OnTop = cards[1].dataset.position === 'front';
      if (onTop === card2OnTop) return;
      cards.forEach(c => {
        c.dataset.position = c.dataset.position === 'front' ? 'back' : 'front';
      });
    }

    // ── Scroll-linked fan + z-swap ────────────────────────────
    // Driven by viewport-relative rects (robust — unlike offset math, these
    // stay correct through the sticky/GSAP-pinned panels above):
    //   • the cards fan apart as the panel pins (`reveal` in) and re-stack as
    //     the comparison panel rises to cover it (`cover` out), and
    //   • card 1 is on top by default; once the panel is in view and the user
    //     scrolls past SWAP_AT, card 2 swaps to the top (and back on scroll up).
    const comp = document.getElementById('comparison');
    const masthead =
      parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--masthead-h')) || 0;
    // The swap is keyed to the UNCLAMPED comparison position (coverRaw, in
    // viewport-heights): ~1 + dwell at the pin, dropping past 1 as it rises.
    // Swapping above 1 fires the swap while the comparison is still a screen
    // below the fold — held back by the dwell margin on #comparison — so card
    // 2 gets a moment on top before the comparison panel rises over the cards.
    const SWAP_AT = 1.35;   // swap when the comparison is ~1.35 screens away
    const SWAP_HYST = 0.06; // hysteresis so it doesn't flicker at the threshold

    let ticking = false;

    function updateFan() {
      ticking = false;
      if (reduceMotion.matches || !desktop.matches) {
        if (fan !== 0) { fan = 0; applyFan(); }
        return;
      }
      const vh = window.innerHeight;
      const span = Math.max(1, vh - masthead);
      const pricingTop = panelEl.getBoundingClientRect().top;
      const reveal = Math.min(1, Math.max(0, (vh - pricingTop) / span));
      let coverRaw = 99; // comparison position in viewport-heights (unclamped)
      if (comp) coverRaw = comp.getBoundingClientRect().top / vh;
      const cover = Math.min(1, Math.max(0, coverRaw));
      fan = reveal * cover;

      // Scroll-driven z-swap — only once the panel is actually in view.
      const card2OnTop = cards[1].dataset.position === 'front';
      if (reveal > 0.5) {
        if (!card2OnTop && coverRaw < SWAP_AT) setCard2OnTop(true);
        else if (card2OnTop && coverRaw > SWAP_AT + SWAP_HYST) setCard2OnTop(false);
      } else if (card2OnTop) {
        setCard2OnTop(false); // restore the default before the panel is in view
      }

      applyFan();
    }

    function onScroll() {
      if (!ticking) { ticking = true; requestAnimationFrame(updateFan); }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', updateFan, { passive: true });
    reduceMotion.addEventListener('change', updateFan);
    desktop.addEventListener('change', updateFan);
    updateFan();
  }
</script>
